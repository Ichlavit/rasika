                    </div>
                </div>
            </div>
        </section>

        <!-- CLIENT BLOCK 3: SCOTIABANK -->
        <section class="bg-rasika-surface/40 backdrop-blur-sm border border-white/10 rounded-[2.5rem] p-6 lg:p-12 flex flex-col lg:flex-row gap-10 lg:gap-16 items-center shadow-2xl">
            <div class="w-full lg:w-5/12 flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight flex items-center gap-4">
                        <div class="w-12 h-12 shrink-0 bg-white/5 border border-white/10 rounded-xl p-1.5 flex items-center justify-center shadow-inner">
                            <img src="/images/logos/scotiabank_logo.svg" alt="Scotiabank Perú" class="w-full h-full object-contain" style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));" />
