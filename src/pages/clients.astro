---
// src/pages/clients.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.clients;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Floating CTA Animation */
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }
        
        /* Bottom Scroll Glow Class */
        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }
        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }

        /* Message Glow */
        @keyframes msg-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(94, 166, 176, 0.05); transform: translateY(0); }
            50% { box-shadow: 0 0 20px rgba(94, 166, 176, 0.15); transform: translateY(-4px); }
        }
        .animate-msg-glow { animation: msg-glow 3s infinite ease-in-out; }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-50 mix-blend-screen filter saturate-150 contrast-150">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
<header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="openMentorWithMessage()">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            ¡Pruébame! <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <section class="pt-36 pb-12 px-6 relative text-center">
        <div class="max-w-4xl mx-auto">
            <div class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-rasika-accent uppercase bg-rasika-accent/10 rounded-full border border-rasika-accent/20">
                Casos de Éxito
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-white" data-i18n="clients-title">
                Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Partners</span>
            </h1>
            <p class="text-lg text-gray-400 font-medium leading-relaxed max-w-2xl mx-auto" data-i18n="clients-desc">
                Organizaciones e instituciones educativas que confían en nuestra simbiosis digital para potenciar la formación de sus equipos.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-24 relative z-10 space-y-16">

        <!-- CLIENT BLOCK 1: CLASE EJECUTIVA UC -->
        <section class="bg-rasika-surface/40 backdrop-blur-sm border border-white/10 rounded-[2.5rem] p-6 lg:p-12 flex flex-col lg:flex-row gap-10 lg:gap-16 items-center shadow-2xl">
            <div class="w-full lg:w-5/12 flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight flex items-center gap-4">
                        <div class="w-12 h-12 shrink-0 bg-white/5 border border-white/10 rounded-xl p-1.5 flex items-center justify-center shadow-inner">
                            <img src="/images/logos/uc_logo.svg" alt="Clase Ejecutiva UC" class="w-full h-full object-contain" style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));" />
                        </div>
                        Clase Ejecutiva UC
                    </h2>
                    <span class="text-rasika-accent font-mono text-xs font-bold border border-rasika-accent/30 bg-rasika-accent/10 px-3 py-1.5 rounded-full tracking-widest shrink-0">2021 - 2026</span>
                </div>
                
                <div class="bg-[#1A1D21] p-8 rounded-[2rem] border border-white/5 relative shadow-lg flex-1">
                    <i data-lucide="quote" class="absolute top-6 right-6 w-10 h-10 text-white/5"></i>
                    <div class="flex gap-1 mb-5 text-[#FFE600]">
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                    </div>
                    <h4 class="text-white font-bold text-lg mb-3 leading-snug">"Innovación tecnológica que escala sin perder calidad."</h4>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8 italic">
                        "La integración de avatares ultra-realistas nos permitió generar un volumen inmenso de contenido académico manteniendo el estándar de exigencia de la universidad, reduciendo los tiempos de estudio drásticamente."
                    </p>
                    
                    <div class="flex items-center gap-4 mt-auto">
                        <div class="w-12 h-12 rounded-full bg-[#2A2F35] border border-white/10 overflow-hidden shrink-0 flex items-center justify-center">
                            <img src="/images/png/samantha_villarroel.png" alt="Samantha Villarroel" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\\'http://www.w3.org/2000/svg\\' viewBox=\\'0 0 24 24\\' fill=\\'none\\' stroke=\\'currentColor\\' stroke-width=\\'2\\' stroke-linecap=\\'round\\' stroke-linejoin=\\'round\\'%3E%3Cpath d=\\'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\\'/%3E%3Ccircle cx=\\'12\\' cy=\\'7\\' r=\\'4\\'/%3E%3C/svg%3E'; this.classList.add('p-2','text-gray-500');" />
                        </div>
                        <div>
                            <p class="text-white font-bold text-sm">Samantha Villarroel</p>
                            <p class="text-gray-500 text-xs font-medium">Ingeniera en Operaciones Académicas</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-7/12 client-slider-container relative rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 shadow-2xl aspect-video bg-black group isolate">
                <div class="slider-track flex w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]">
                    
                    <!-- Slide 1: Interactive Courses -->
                    <div class="slide-item w-full h-full shrink-0 relative flex flex-col justify-end">
                        
                        <video preload="metadata" loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-60">
                            <source src="/videos/glimpses/tde_scorm.mp4" type="video/mp4">
                        </video>
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0c0e] via-black/40 to-transparent pointer-events-none"></div>
                        <div class="relative z-10 p-8 w-full flex justify-between items-end">
                            <div class="max-w-[70%]">
                                <div class="text-[10px] font-extrabold text-rasika-accent mb-2 uppercase tracking-widest">Curso Interactivo</div>
                                <h3 class="text-2xl font-bold text-white leading-tight">Interactive Courses</h3>
                            </div>
                            <button onclick="launchDemo('Cursos Interactivos', 'Módulo SCORM', 'Clase Ejecutiva UC', '2026', 'Desarrollo de cursos interactivos con empaquetado HTML5 y SCORM.', '/courses/rise_template_SCORM/index.html')" class="px-5 py-2.5 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm text-sm flex items-center gap-2">
                                Ver Demo <i data-lucide="play" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Slide 2: AI Generated Sequences -->
                    <div class="slide-item w-full h-full shrink-0 relative flex flex-col justify-end">
                        <video preload="metadata" loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-60">
                            <source src="/videos/standalone/ai_ultrarealistic.mp4" type="video/mp4">
                        </video>
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0c0e] via-black/40 to-transparent pointer-events-none"></div>
                        <div class="relative z-10 p-8 w-full flex justify-between items-end">
                            <div class="max-w-[70%]">
                                <div class="text-[10px] font-extrabold text-rasika-accent mb-2 uppercase tracking-widest">IA Ultra-Realista</div>
                                <h3 class="text-2xl font-bold text-white leading-tight">AI Generated Sequences</h3>
                            </div>
                            <button onclick="launchDemo('Secuencias de Video IA', 'IA Ultra-Realista', 'Clase Ejecutiva UC', '2024', 'Videos en alta definición con presentadores hiperrealistas mediante Inteligencia Artificial.', '/videos/standalone/ai_ultrarealistic.mp4')" class="px-5 py-2.5 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm text-sm flex items-center gap-2">
                                Ver Demo <i data-lucide="play" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="absolute top-6 right-6 flex gap-2 z-20">
                    <button class="slider-prev p-2 rounded-full bg-black/40 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white transition-all backdrop-blur-sm">
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                    <button class="slider-next p-2 rounded-full bg-black/40 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white transition-all backdrop-blur-sm">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </div>
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-20 slider-dots-container"></div>
            </div>
        </section>

        <!-- CLIENT BLOCK 2: EY -->
        <section class="bg-rasika-surface/40 backdrop-blur-sm border border-white/10 rounded-[2.5rem] p-6 lg:p-12 flex flex-col-reverse lg:flex-row gap-10 lg:gap-16 items-center shadow-2xl">
            <div class="w-full lg:w-7/12 client-slider-container relative rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 shadow-2xl aspect-video bg-black group isolate">
                <div class="slider-track flex w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]">
                    
                    <!-- Slide 1: TAX Bootcamp -->
                    <div class="slide-item w-full h-full shrink-0 relative flex flex-col justify-end">
                        <video preload="metadata" loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-60">
                            <source src="/videos/glimpses/tax_scorm.mp4" type="video/mp4">
                        </video>
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0c0e] via-black/40 to-transparent pointer-events-none"></div>
                        <div class="relative z-10 p-8 w-full flex justify-between items-end">
                            <div class="max-w-[70%]">
                                <div class="text-[10px] font-extrabold text-rasika-accent mb-2 uppercase tracking-widest">Producción SCORM</div>
                                <h3 class="text-2xl font-bold text-white leading-tight">TAX Bootcamp</h3>
                            </div>
                            <button onclick="launchDemo('TAX Bootcamp', 'Módulo Interactivo SCORM', 'EY', '2024', 'Desarrollo de paquete SCORM con evaluaciones y multimedia para bootcamp intensivo.', '/courses/tax_scorm/index.html')" class="px-5 py-2.5 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm text-sm flex items-center gap-2">
                                Ver Demo <i data-lucide="play" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Slide 2: LMS Custom Integration -->
                    <div class="slide-item w-full h-full shrink-0 relative flex flex-col justify-end">
    <video preload="metadata" loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-60">
        <source src="/videos/glimpses/talentlms_demo.mp4" type="video/mp4">
    </video>

    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0c0e] via-black/40 to-transparent pointer-events-none"></div>
    
    <div class="relative z-10 p-8 w-full flex justify-between items-end">
        <div class="max-w-[70%]">
            <div class="text-[10px] font-extrabold text-rasika-accent mb-2 uppercase tracking-widest">LMS & Bots</div>
            <h3 class="text-2xl font-bold text-white leading-tight">LMS Custom Integration</h3>
        </div>
        <button onclick="launchDemo('LMS Custom Integration', 'Integración Nativa', 'EY', '2024', 'Integración personalizada y automatización de procesos en el LMS.', 'https://eycapacitacion.talentlms.com/index/autologin/key:dnc75k8464pb6gubgnex17777594971740,redirect:learner/courseinfo/id:217')" class="px-5 py-2.5 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm text-sm flex items-center gap-2">
            Ver Demo <i data-lucide="play" class="w-4 h-4"></i>
        </button>
    </div>
</div>

                </div>

                <div class="absolute top-6 right-6 flex gap-2 z-20">
                    <button class="slider-prev p-2 rounded-full bg-black/40 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white transition-all backdrop-blur-sm">
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                    <button class="slider-next p-2 rounded-full bg-black/40 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white transition-all backdrop-blur-sm">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </div>
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-20 slider-dots-container"></div>
            </div>

            <div class="w-full lg:w-5/12 flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight flex items-center gap-4">
                        <div class="w-12 h-12 shrink-0 bg-white/5 border border-white/10 rounded-xl p-1.5 flex items-center justify-center shadow-inner">
                            <img src="/images/logos/ey_logo.svg" alt="EY" class="w-full h-full object-contain" style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));" />
                        </div>
                        EY (Ernst & Young)
                    </h2>
                    <span class="text-rasika-accent font-mono text-xs font-bold border border-rasika-accent/30 bg-rasika-accent/10 px-3 py-1.5 rounded-full tracking-widest shrink-0">2022 - 2026</span>
                </div>
                
                <div class="bg-[#1A1D21] p-8 rounded-[2rem] border border-white/5 relative shadow-lg flex-1">
                    <i data-lucide="quote" class="absolute top-6 right-6 w-10 h-10 text-white/5"></i>
                    <div class="flex gap-1 mb-5 text-[#FFE600]">
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                        <i data-lucide="star" class="fill-current w-4 h-4"></i>
                    </div>
                    <h4 class="text-white font-bold text-lg mb-3 leading-snug">"Elevaron nuestros estándares de capacitación."</h4>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8 italic">
                        "La consultoría instruccional de Rasika y sus módulos SCORM gamificados revolucionaron nuestra forma de hacer onboarding. La calidad visual y la interactividad mantienen a nuestros consultores comprometidos de principio a fin."
                    </p>
                    
                    <div class="flex items-center gap-4 mt-auto">
                        <div class="w-12 h-12 rounded-full bg-[#2A2F35] border border-white/10 overflow-hidden shrink-0 flex items-center justify-center">
                            <img src="/images/png/sandra_arenas.png" alt="Sandra Arenas" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\\'http://www.w3.org/2000/svg\\' viewBox=\\'0 0 24 24\\' fill=\\'none\\' stroke=\\'currentColor\\' stroke-width=\\'2\\' stroke-linecap=\\'round\\' stroke-linejoin=\\'round\\'%3E%3Cpath d=\\'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\\'/%3E%3Ccircle cx=\\'12\\' cy=\\'7\\' r=\\'4\\'/%3E%3C/svg%3E'; this.classList.add('p-2','text-gray-500');" />
                        </div>
                        <div>
                            <p class="text-white font-bold text-sm">Sandra Arenas</p>
                            <p class="text-gray-500 text-xs font-medium">Gerente OTEC EY Learning</p>
