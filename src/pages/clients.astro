    <script is:inline>
// Mobile Menu Toggle Logic
document.addEventListener('DOMContentLoaded', () => {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if(mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
            // Toggle visibility and flexbox stacking
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            
            // Swap hamburger icon for 'X' icon
            const icon = mobileBtn.querySelector('i');
            if (mobileMenu.classList.contains('hidden')) {
                icon.setAttribute('data-lucide', 'menu');
            } else {
                icon.setAttribute('data-lucide', 'x');
            }
            if(window.lucide) lucide.createIcons();
        });
    }
});

        // Multi-Slider Logic & Lazy Video Playback
        document.addEventListener('DOMContentLoaded', () => {
            const sliders = document.querySelectorAll('.client-slider-container');
            
            sliders.forEach(container => {
                const track = container.querySelector('.slider-track');
                const slides = container.querySelectorAll('.slide-item');
                const dotsContainer = container.querySelector('.slider-dots-container');
                const btnPrev = container.querySelector('.slider-prev');
                const btnNext = container.querySelector('.slider-next');
                const totalSlides = slides.length;
                let currentSlide = 0;
                let interval;
                let isVisible = false;

                function pauseAllVideos() {
                    slides.forEach(slide => {
                        const vid = slide.querySelector('video');
                        if (vid) vid.pause();
                    });
                }

                function playCurrentVideo() {
                    if (!isVisible) return;
                    pauseAllVideos();
                    if (slides[currentSlide]) {
                        const currentVid = slides[currentSlide].querySelector('video');
                        if (currentVid) {
                            const playPromise = currentVid.play();
                            if (playPromise !== undefined) {
                                playPromise.catch(e => console.log('Video play prevented:', e));
                            }
                        }
                    }
                }

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        isVisible = entry.isIntersecting;
                        if (isVisible) {
                            playCurrentVideo();
                        } else {
                            pauseAllVideos();
                        }
                    });
                }, { threshold: 0.33 });
                
                observer.observe(container);

                if(totalSlides <= 1) {
                    if(btnPrev) btnPrev.style.display = 'none';
                    if(btnNext) btnNext.style.display = 'none';
                    if(dotsContainer) dotsContainer.style.display = 'none';
                    return;
                }

                for(let i=0; i<totalSlides; i++) {
                    const dot = document.createElement('button');
                    dot.className = i === 0 ? 'w-8 h-1.5 rounded-full bg-rasika-accent transition-all duration-300' : 'w-2 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-all duration-300';
                    dot.addEventListener('click', () => { goToSlide(i); });
                    dotsContainer.appendChild(dot);
                }
                const dots = dotsContainer.querySelectorAll('button');

                function updateSlider() {
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                    dots.forEach((dot, index) => {
                        dot.className = index === currentSlide 
                            ? 'w-8 h-1.5 rounded-full bg-rasika-accent transition-all duration-300' 
                            : 'w-2 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-all duration-300';
                    });
                    playCurrentVideo();
                }

                function nextSlide() {
                    currentSlide = (currentSlide + 1) % totalSlides;
                    updateSlider();
                    resetInterval();
                }

                function prevSlide() {
                    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                    updateSlider();
                    resetInterval();
                }

                function goToSlide(index) {
                    currentSlide = index;
                    updateSlider();
                    resetInterval();
                }

                function startInterval() {
                    interval = setInterval(nextSlide, 6000);
                }

                function resetInterval() {
                    clearInterval(interval);
                    startInterval();
                }

                if(btnNext) btnNext.addEventListener('click', nextSlide);
                if(btnPrev) btnPrev.addEventListener('click', prevSlide);

                startInterval();
            });
        });

        // Floating CTA Logic
        window.openMentorWithMessage = function() {
            const fab = document.getElementById('mentor-fab');
            const chatWindow = document.getElementById('mentor-window');
            const tooltip = document.getElementById('mentor-cta-tooltip');
            
            if (tooltip) tooltip.style.display = 'none';

            if (fab && chatWindow && chatWindow.style.display === 'none') {
                fab.click();
                setTimeout(() => {
                    const msgBox = document.getElementById('mentor-messages');
                    if (msgBox) {
                        const msgDiv = document.createElement('div');
                        msgDiv.className = 'bg-[#2A2F35] text-gray-200 border border-white/5 p-3 rounded-2xl rounded-tl-sm text-sm self-start max-w-[85%] mt-2 mb-2 animate-msg-glow';
                        msgDiv.innerHTML = `¡Hola! Revisa nuestros casos de éxito. ¿Qué tipo de producción estás buscando para tu equipo?`;
                        msgBox.appendChild(msgDiv);
                        msgBox.scrollTop = msgBox.scrollHeight;
                    }
                }, 500);
            }
        };

        window.addEventListener('scroll', () => {
            const tooltip = document.getElementById('mentor-cta-tooltip');
            if (!tooltip) return;
            const scrollPosition = window.innerHeight + window.scrollY;
            const threshold = document.body.offsetHeight - 200;
            if (scrollPosition >= threshold) {
                tooltip.classList.add('cta-glow-active');
            } else {
                tooltip.classList.remove('cta-glow-active');
            }
        });

        // Modal Logic
        const modal = document.getElementById('demo-modal');
        const demoTitleModal = document.getElementById('demo-title-modal');
        const demoSubtitle = document.getElementById('demo-subtitle');
        const demoClient = document.getElementById('demo-client');
        const demoYear = document.getElementById('demo-year');
        const demoDescModal = document.getElementById('demo-desc-modal');

        function launchDemo(courseName, formatType, clientName, year, description, courseUrl) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => modal.classList.remove('opacity-0'), 10);
            
            demoTitleModal.innerText = courseName;
            demoSubtitle.innerText = `Desplegando formato: ${formatType}`;
            demoClient.innerText = clientName;
            demoYear.innerText = year;
            demoDescModal.innerText = description;

            const playerArea = document.getElementById('player-container');
            
            if (courseUrl.toLowerCase().endsWith('.mp4')) {
                playerArea.innerHTML = `
                    <div class="w-fit max-w-full rounded-3xl overflow-hidden shadow-2xl ring-1 ring-inset ring-white/10 bg-black relative flex items-center justify-center isolate [transform:translateZ(0)]">
                        <video src="${courseUrl}" controls autoplay class="max-w-full w-auto max-h-[65vh] outline-none block rounded-3xl"></video>
                    </div>
                `;
            } else {
                playerArea.innerHTML = `
                    <div class="w-full aspect-video rounded-3xl overflow-hidden shadow-2xl ring-1 ring-inset ring-white/10 bg-[#0f1114] relative flex items-center justify-center isolate [transform:translateZ(0)]" style="max-height: 65vh; max-width: calc(65vh * 16 / 9);">
                        <iframe src="${courseUrl}" class="relative z-10 w-full h-full border-0 bg-white rounded-3xl" allowfullscreen></iframe>
                    </div>
                `;
            }
            if (window.lucide) lucide.createIcons();
        }

        function closeDemo() {
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                const playerArea = document.getElementById('player-container');
                if(playerArea) playerArea.innerHTML = '';
            }, 300);
        }

        // Translation Logic
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();

            let currentLang = document.documentElement.lang || "es";
            const toggleBtn = document.getElementById('lang-toggle');

            const translations = {
                es: {
                    "nav-demos": "Demos",
                    "nav-lms": "LMS & Bots",
                    "nav-clients": "Clientes",
                    "nav-pricing": "Precios",
                    "nav-blog": "Blog",
                    "toggle-btn": "EN",
                    "clients-title": "Nuestros \nPartners",
                    "clients-desc": "Organizaciones e instituciones educativas que confían en nuestra simbiosis digital para potenciar la formación de sus equipos.",
                    "footer-text": "© 2026 Rasika Producciones. Todos los derechos reservados."
                },
                en: {
                    "nav-demos": "Demos",
                    "nav-lms": "LMS & Bots",
                    "nav-clients": "Clients",
                    "nav-pricing": "Pricing",
                    "nav-blog": "Blog",
                    "toggle-btn": "ES",
                    "clients-title": "Our \nPartners",
                    "clients-desc": "Organizations and educational institutions that trust our digital symbiosis to empower their teams' training.",
                    "footer-text": "© 2026 Rasika Productions. All rights reserved."
                }
            };

            if(toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    currentLang = currentLang === "es" ? "en" : "es";
                    document.documentElement.lang = currentLang;

                    document.querySelectorAll('[data-i18n]').forEach(el => {
                        const key = el.getAttribute('data-i18n');
                        if (translations[currentLang][key]) {
                            if (key === 'clients-title') {
                                el.innerHTML = translations[currentLang][key].replace('\n', '<br class="hidden sm:block"/>');
                                el.innerHTML = el.innerHTML.replace('Partners', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Partners</span>');
                            } else {
                                el.innerText = translations[currentLang][key];
                            }
                        }
                    });
                    
                    toggleBtn.innerText = translations[currentLang]["toggle-btn"];
                });
            }
        });
    </script>
    
    <Chatbot />
</body>
</html>
