---
// src/pages/pricing.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.pricing;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .price-toggle:checked + label { background-color: #5EA6B0; border-color: #5EA6B0; }
        .price-toggle:checked + label > div { transform: translateX(24px); }
        .saas-card { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .saas-card:hover { transform: translateY(-8px); }
        .desc-text strong { color: #fff; font-weight: 700; }
        
        /* Floating CTA Animation (Bounce Kept Intact on Wrapper) */
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }
        
        /* Bottom Scroll Glow Class (Scale removed to prevent tail separation and bounce overrides) */
        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }
        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }

        /* --- REFINED: Ultra-soft Cyan Message Glow + Subtle Bounce --- */
        @keyframes msg-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(94, 166, 176, 0.05); transform: translateY(0); }
            50% { box-shadow: 0 0 20px rgba(94, 166, 176, 0.15); transform: translateY(-4px); }
        }
        .animate-msg-glow { animation: msg-glow 3s infinite ease-in-out; }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <!-- VIDEO BACKGROUND -->
    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-50 mix-blend-screen filter saturate-150 contrast-150">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
    <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <!-- FLOATING CTA (Clean Bubble - Zero Borders, Scale removed to preserve tail) -->
    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="openMentorWithMessage()">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            ¡Pruébame! <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <!-- HERO HEADER -->
    <section class="pt-36 pb-12 px-6 relative text-center">
        <div class="max-w-4xl mx-auto">
            <div class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-rasika-accent uppercase bg-rasika-accent/10 rounded-full border border-rasika-accent/20">
                Transparencia & Escalabilidad
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-white" data-i18n="pricing-title">
                Modelos de Inversión <br class="hidden sm:block"/> 
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Flexibles</span>
            </h1>
            <p class="text-lg text-gray-400 font-medium leading-relaxed" data-i18n="pricing-desc">
                Desde cápsulas lineales hasta agentes de IA integrados. Todo lo que necesitas para planificar el presupuesto de tu academia digital en 2026.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-24 relative z-10 space-y-24">

        <!-- NOTA ACLARATORIA -->
        <div class="w-full bg-[#1A1D21] border-l-4 border-rasika-accent p-6 rounded-r-2xl flex items-start gap-4 shadow-lg">
            <i data-lucide="alert-circle" class="w-5 h-5 text-white shrink-0 mt-0.5"></i>
            <p class="text-gray-300 text-sm leading-relaxed"><strong class="text-white">Nota:</strong> Los precios están expresados en UF (Unidad de Fomento). Los plazos de producción corresponden a días hábiles estimados y comienzan a partir de la recepción de los guiones/contenidos finales aprobados. Los rangos de tiempo representan el tiempo promedio de navegación/reproducción del usuario.</p>
        </div>

        <!-- SECTION 1: Activos Lineales -->
        <section>
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                    <span class="w-1.5 h-8 bg-rasika-accent block rounded-full"></span>
                    1. Activos de Producción de Video y Medios
                </h2>
                <p class="text-gray-400 ml-5">Activos lineales modulares. Pueden entregarse como MP4 independientes o integrarse en paquetes interactivos.</p>
            </div>

            <div class="overflow-x-auto rounded-[2rem] ring-1 ring-inset ring-white/10 bg-rasika-surface/60 backdrop-blur-md shadow-2xl">
                <table class="w-full text-left border-collapse min-w-[900px]">
                    <thead>
                        <tr class="bg-black/40 text-gray-300 text-xs uppercase tracking-widest border-b border-white/10">
                            <th class="p-6 w-[20%] font-semibold">Tipo de Activo</th>
                            <th class="p-6 w-[35%] font-semibold">Descripción e Inclusiones</th>
                            <th class="p-6 text-center font-semibold">Corto <span class="block text-[10px] text-gray-500 normal-case mt-1">(1 a 5 min)</span></th>
                            <th class="p-6 text-center font-semibold">Medio <span class="block text-[10px] text-gray-500 normal-case mt-1">(5 a 10 min)</span></th>
                            <th class="p-6 text-center font-semibold">Largo <span class="block text-[10px] text-gray-500 normal-case mt-1">(10 a 20 min)</span></th>
                            <th class="p-6 text-center font-semibold w-[15%]">Demos</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-white/5">
                        <tr class="bg-white/5 transition-colors">
                            <td class="p-6 font-semibold text-white">Plazos de Producción</td>
                            <td class="p-6 text-gray-400">Días hábiles estándar requeridos.</td>
                            <td class="p-6 text-center font-medium">5 días</td>
                            <td class="p-6 text-center font-medium">7 a 10 días</td>
                            <td class="p-6 text-center font-medium">10 a 14 días</td>
                            <td class="p-6 text-center text-gray-500">-</td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Video con IA Ultra-Realista</td>
                            <td class="p-6 text-gray-400 desc-text">Videos en alta definición. Permite elementos de marca o adición de personajes, e incluye locución generada por IA y subtítulos opcionales</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">15 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">20 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">40 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Secuencia de Aprendizaje', 'IA Ultra-Realista', 'Clase Ejecutiva UC', '2024', 'Videos en alta definición con presentadores hiperrealistas mediante Inteligencia Artificial.', '/videos/standalone/ai_ultrarealistic.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Cápsulas de Video (IA + Boards)</td>
                            <td class="p-6 text-gray-400 desc-text">Secuencias de video con IA combinadas con boards animados. <br><br><strong>Incluye:</strong> Generación de video con IA, transiciones en motion graphics, boards de texto e íconos animados, locución sincronizada y subtítulos.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">25 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">35 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">50 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Cápsula Explicativa', 'IA + Boards Animados', 'Clase Ejecutiva UC', '2024', 'Secuencias de video con IA combinadas con boards animados e íconos.', '/videos/standalone/ai_plus_boards.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Video Presentador (Estudio)</td>
                            <td class="p-6 text-gray-400 desc-text">Presentador humano profesional grabado en estudio. <br><br><strong>Incluye:</strong> Tiempo de estudio, vestuario, edición de video, corrección de color, postproducción, chroma key y subtítulos. <br><strong>Excluye</strong> arte, mobiliario y utilería.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">25 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">35 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">50 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Curso de Liderazgo', 'Video Presentador (Estudio)', 'Cencosud', '2023', 'Presentador humano profesional grabado en estudio para comunicaciones directas.', '/videos/standalone/presenter_actor.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Video Role-Playing (Estudio)</td>
                            <td class="p-6 text-gray-400 desc-text">Escenarios con múltiples actores grabados en estudio para demostrar habilidades blandas o procedimientos. <br><br><strong>Incluye:</strong> Hasta 2 actores, tiempo de estudio, vestuario, edición, corrección de color, postproducción, chroma key y subtítulos. <br><strong>Excluye</strong> arte, mobiliario y utilería.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">40 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">60 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">100 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Simulador de Atención', 'Video Role-Playing (Estudio)', 'Cencosud', '2024', 'Entrenamiento de habilidades blandas usando múltiples actores y escenarios reales.', '/videos/standalone/roleplay_actors.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Video Enhance con IA</td>
                            <td class="p-6 text-gray-400 desc-text">¡Potencia tus escenarios con múltiples actores grabados en estudio mediante fondos animados realistas generados con inteligencia artificial! Elige el fondo y el vestuario deseado y nosotros nos encargamos del resto. <br><br><strong>Incluye:</strong> Hasta dos fondos realistas y dos sets de vestuario o EPP. <br><strong>Excluye:</strong> Cambios de personajes, cambios en el guion, cambios de idioma o efectos especiales.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">8 UF<span class="block text-[10px] text-gray-500 font-semibold mt-1">por minuto</span></td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">6 UF<span class="block text-[10px] text-gray-500 font-semibold mt-1">por minuto</span></td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">5 UF<span class="block text-[10px] text-gray-500 font-semibold mt-1">por minuto</span></td>
                            <td class="p-6 text-center">
                                <a href="/demos/?demo=video-enhance-ia" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Comparar <i data-lucide="scan-line" class="w-3 h-3"></i></a>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">2D Motion Graphics (Flat Design)</td>
                            <td class="p-6 text-gray-400 desc-text">Videos explicativos utilizando Flat design moderno. <br><br><strong>Incluye:</strong> Storyboard a medida, animación 2D, locución, música de fondo y subtítulos.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">40 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">60 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">80 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Video Operacional', '2D Motion Graphics', 'AMSA', '2023', 'Animación 2D con diseño de storyboard a medida y elementos visuales dinámicos.', '/videos/standalone/2D_motion_graphics.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Videos de Marketing de Alta Calidad</td>
                            <td class="p-6 text-gray-400 desc-text">Videos promocionales o explicativos premium. <br><br><strong>Incluye:</strong> Videos de stock en 4K de primer nivel, locutor humano profesional, licenciamiento de música premium, edición de alto nivel y subtítulos.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">100 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">150 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">200 UF</td>
                            <td class="p-6 text-center">
                                <button type="button" onclick="launchDemo('Video Promocional', 'Marketing Premium 4K', 'Glencore', '2023', 'Pieza audiovisual de alta gama con material de stock 4K y locución profesional.', '/videos/standalone/premium_marketing_4K_stock.mp4')" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent">Ver Demo <i data-lucide="play" class="w-3 h-3"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- SECTION 2: SCORM -->
        <section>
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                    <span class="w-1.5 h-8 bg-rasika-accent block rounded-full"></span>
                    2. Módulos Interactivos HTML y SCORM
                </h2>
                <p class="text-gray-400 ml-5">Paquetes interactivos que requieren diseño instruccional, envoltura en HTML y navegación compleja por parte del usuario. Estos módulos envuelven cualquiera de los activos multimedia de la tabla anterior.</p>
            </div>

            <div class="overflow-x-auto rounded-[2rem] ring-1 ring-inset ring-white/10 bg-rasika-surface/60 backdrop-blur-md shadow-2xl">
                <table class="w-full text-left border-collapse min-w-[900px]">
                    <thead>
                        <tr class="bg-black/40 text-gray-300 text-xs uppercase tracking-widest border-b border-white/10">
                            <th class="p-6 w-[20%] font-semibold">Entregable Interactivo</th>
                            <th class="p-6 w-[35%] font-semibold">Descripción e Inclusiones</th>
                            <th class="p-6 text-center font-semibold">Nivel 1 <span class="block text-[10px] text-gray-500 normal-case mt-1">(10 a 20 min)</span></th>
                            <th class="p-6 text-center font-semibold">Nivel 2 <span class="block text-[10px] text-gray-500 normal-case mt-1">(20 a 40 min)</span></th>
                            <th class="p-6 text-center font-semibold">Nivel 3 <span class="block text-[10px] text-gray-500 normal-case mt-1">(40 a 60 min)</span></th>
                            <th class="p-6 text-center font-semibold w-[15%]">Demos</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-white/5">
                        <tr class="bg-white/5 transition-colors">
                            <td class="p-6 font-semibold text-white">Plazos de Producción de Contenido</td>
                            <td class="p-6 text-gray-400">Días hábiles estándar requeridos.</td>
                            <td class="p-6 text-center font-medium">10 a 14 días</td>
                            <td class="p-6 text-center font-medium">15 a 20 días</td>
                            <td class="p-6 text-center font-medium">20 a 25 días</td>
                            <td class="p-6 text-center text-gray-500">-</td>
                        </tr>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="p-6 font-bold text-white">Curso Estándar SCORM / HTML5</td>
                            <td class="p-6 text-gray-400 desc-text">Desarrollado con Adobe Captivate, Rise 360 o código HTML5 a medida. Compatible con SCORM 1.2. <br><br><strong>Incluye:</strong> Diseño instruccional, integración de activos multimedia, hotspots interactivos, formato de texto alternativo (alt-text) y evaluaciones/controles de conocimiento.</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">40 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">80 UF</td>
                            <td class="p-6 text-center font-bold text-rasika-accent text-lg">100 UF</td>
                            <td class="p-6 text-center flex flex-col gap-3">
                                <button type="button" onclick="launchDemo('Transformación Digital', 'Curso SCORM', 'Clase Ejecutiva UC', '2023', 'Curso interactivo con evaluaciones gamificadas.', 'https://eycapacitacion.talentlms.com/unit/view/id:3500')" class="inline-flex justify-center items-center gap-2 px-4 py-2 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] rounded-xl font-bold transition-all text-xs border border-white/10 hover:border-transparent w-full">Demo 1 <i data-lucide="play" class="w-3 h-3"></i></button>
