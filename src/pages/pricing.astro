    <!-- INTERNACIONALIZACIÓN, TOGGLE Y LÓGICA DE MODAL -->
    <script is:inline>
        // Mobile Menu Toggle Logic
document.addEventListener('DOMContentLoaded', () => {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if(mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
            // Toggle visibility and flexbox stacking
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            
            // Swap hamburger icon for 'X' icon
            const icon = mobileBtn.querySelector('i');
            if (mobileMenu.classList.contains('hidden')) {
                icon.setAttribute('data-lucide', 'menu');
            } else {
                icon.setAttribute('data-lucide', 'x');
            }
            if(window.lucide) lucide.createIcons();
        });
    }
});
    
        // Open Mentor depending on the plan chosen
        window.openMentorWithPlan = function(planKey) {
            const planMap = {
                'Proyecto': 'Proyecto',
                'Corporativo': 'Empresa',
                'Institucional': 'Institución'
            };
            const planName = planMap[planKey] || planKey;

            const fab = document.getElementById('mentor-fab');
            const chatWindow = document.getElementById('mentor-window');
            const tooltip = document.getElementById('mentor-cta-tooltip');
            
            if (tooltip) tooltip.style.display = 'none';

            if (fab && chatWindow && chatWindow.style.display === 'none') {
                fab.click();
                
                setTimeout(() => {
                    const msgBox = document.getElementById('mentor-messages');
                    if (msgBox) {
                        const msgDiv = document.createElement('div');
                        // Utilizing the ultra-soft animate-msg-glow
                        msgDiv.className = 'bg-[#2A2F35] text-gray-200 border border-white/5 p-3 rounded-2xl rounded-tl-sm text-sm self-start max-w-[85%] mt-2 mb-2 animate-msg-glow';
                        msgDiv.innerHTML = `Veo que te interesa CourseMentor para tu <strong>${planName}</strong>. Para comenzar, ¿con quién tengo el gusto?`;
                        msgBox.appendChild(msgDiv);
                        msgBox.scrollTop = msgBox.scrollHeight;
                        
                        if(window.mentorChatHistory) {
                            window.mentorChatHistory.push(`CourseMentor: Veo que te interesa CourseMentor para tu ${planName}. Para comenzar, ¿con quién tengo el gusto?`);
                        }
                    }
                }, 500);
            }
        };

        // Fallback for floating CTA
        window.openMentorWithMessage = function() {
            window.openMentorWithPlan('Proyecto');
        };

        // Hide tooltip if user opens the chatbot manually
        document.addEventListener('DOMContentLoaded', () => {
            const fab = document.getElementById('mentor-fab');
            if(fab) {
                fab.addEventListener('click', () => {
                    const tooltip = document.getElementById('mentor-cta-tooltip');
                    if(tooltip) tooltip.style.display = 'none';
                });
            }
        });

        // Scroll Observer for Bottom Floating CTA Glow
        window.addEventListener('scroll', () => {
            const tooltip = document.getElementById('mentor-cta-tooltip');
            if (!tooltip) return;
            const scrollPosition = window.innerHeight + window.scrollY;
            const threshold = document.body.offsetHeight - 200;
            if (scrollPosition >= threshold) {
                tooltip.classList.add('cta-glow-active');
            } else {
                tooltip.classList.remove('cta-glow-active');
            }
        });

        // Demo Modal Logic
        const modal = document.getElementById('demo-modal');
        const demoTitleModal = document.getElementById('demo-title-modal');
        const demoSubtitle = document.getElementById('demo-subtitle');
        const demoClient = document.getElementById('demo-client');
        const demoYear = document.getElementById('demo-year');
        const demoDescModal = document.getElementById('demo-desc-modal');

        function launchDemo(courseName, formatType, clientName, year, description, courseUrl) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => modal.classList.remove('opacity-0'), 10);
            
            demoTitleModal.innerText = courseName;
            demoSubtitle.innerText = `Desplegando formato: ${formatType}`;
            demoClient.innerText = clientName;
            demoYear.innerText = year;
            demoDescModal.innerText = description;

            const playerArea = document.getElementById('player-container');
            
            if (courseUrl.toLowerCase().endsWith('.mp4')) {
                playerArea.innerHTML = `
                    <div class="w-fit max-w-full rounded-3xl overflow-hidden shadow-2xl ring-1 ring-inset ring-white/10 bg-black relative flex items-center justify-center isolate [transform:translateZ(0)]">
                        <video src="${courseUrl}" controls autoplay class="max-w-full w-auto max-h-[65vh] outline-none block rounded-3xl"></video>
                    </div>
                `;
            } else {
                playerArea.innerHTML = `
                    <div class="w-full aspect-video rounded-3xl overflow-hidden shadow-2xl ring-1 ring-inset ring-white/10 bg-[#0f1114] relative flex items-center justify-center isolate [transform:translateZ(0)]" style="max-height: 65vh; max-width: calc(65vh * 16 / 9);">
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-500 z-0 pointer-events-none">
                            <i data-lucide="loader-2" class="w-12 h-12 animate-spin mb-4 text-rasika-accent"></i>
                            <p class="text-sm font-medium tracking-wide">Simulando despliegue de recurso...</p>
                        </div>
                        <iframe src="${courseUrl}" class="relative z-10 w-full h-full border-0 bg-white rounded-3xl" allowfullscreen></iframe>
                    </div>
                `;
                if (window.lucide) lucide.createIcons();
            }

            window.mentorActiveCourse = courseName + " (" + formatType + ")";

            setTimeout(() => {
                const fab = document.getElementById('mentor-fab');
                const chatWindow = document.getElementById('mentor-window');
                if (chatWindow && chatWindow.style.display === 'none' && fab) {
                    fab.click();
                }
            }, 10000);
        }

        function closeDemo() {
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                
                const playerArea = document.getElementById('player-container');
                if(playerArea) {
                    playerArea.innerHTML = `
                        <div class="w-full aspect-video max-h-[65vh] rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 bg-[#0f1114] flex flex-col items-center justify-center text-gray-500 shadow-2xl" style="max-width: calc(65vh * 16 / 9);">
                            <i data-lucide="loader-2" class="w-12 h-12 animate-spin mb-4 text-rasika-accent"></i>
                            <p class="text-sm font-medium tracking-wide">Cerrando recurso...</p>
                        </div>
                    `;
                }
                if (window.lucide) lucide.createIcons();
            }, 300);
            window.mentorActiveCourse = "Catálogo General";
        }

        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();

            // Toggle Billing Logic
            const toggle = document.getElementById('billing-toggle');
            const prices = document.querySelectorAll('.price-val');

            if(toggle) {
                toggle.addEventListener('change', () => {
                    prices.forEach(price => {
                        const monthly = price.getAttribute('data-monthly');
                        const yearly = price.getAttribute('data-yearly');
                        price.style.opacity = '0';
                        setTimeout(() => {
                            price.textContent = toggle.checked ? `$${yearly}` : `$${monthly}`;
                            price.style.opacity = '1';
                        }, 150);
                    });
                });
            }

            // Language/i18n Logic
            let currentLang = document.documentElement.lang || "es";
            const toggleBtn = document.getElementById('lang-toggle');

            const translations = {
                es: {
                    "nav-demos": "Demos",
                    "nav-lms": "LMS & Bots",
                    "nav-clients": "Clientes",
                    "nav-blog": "Blog",
                    "nav-pricing": "Precios",
                    "toggle-btn": "EN",
                    "pricing-title": "Modelos de Inversión\nFlexibles",
                    "pricing-desc": "Desde cápsulas lineales hasta agentes de IA integrados. Todo lo que necesitas para planificar el presupuesto de tu academia digital en 2026.",
                    "footer-text": "© 2026 Rasika Producciones. Todos los derechos reservados."
                },
                en: {
                    "nav-demos": "Demos",
                    "nav-lms": "LMS & Bots",
                    "nav-clients": "Clients",
                    "nav-blog": "Blog",
                    "nav-pricing": "Pricing",
                    "toggle-btn": "ES",
                    "pricing-title": "Flexible Investment\nModels",
                    "pricing-desc": "From linear capsules to integrated AI agents. Everything you need to budget your digital academy in 2026.",
                    "footer-text": "© 2026 Rasika Productions. All rights reserved."
                }
            };

            if(toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    currentLang = currentLang === "es" ? "en" : "es";
                    document.documentElement.lang = currentLang;

                    document.querySelectorAll('[data-i18n]').forEach(el => {
                        const key = el.getAttribute('data-i18n');
                        if (translations[currentLang][key]) {
                            if (key === 'pricing-title') {
                                el.innerHTML = translations[currentLang][key].replace('\n', '<br class="hidden sm:block"/>');
                                el.innerHTML = el.innerHTML.replace('Flexibles', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Flexibles</span>').replace('Models', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Models</span>');
                            } else {
                                el.innerText = translations[currentLang][key];
                            }
                        }
                    });
                    
                    toggleBtn.innerText = translations[currentLang]["toggle-btn"];
                });
            }
        });
    </script>
    
