    <div id="lead-form-confirmation" class="fixed inset-0 z-[1000] hidden items-center justify-center bg-black/70 backdrop-blur-md px-6">
        <div class="max-w-md w-full rounded-3xl bg-[#1E2226] border border-white/10 shadow-2xl p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-rasika-accent text-[#0a0b0d] flex items-center justify-center mx-auto mb-5">
                <i data-lucide="check" class="w-7 h-7"></i>
            </div>
            <h3 class="text-2xl font-extrabold text-white mb-3" data-i18n="form-confirm-title">¡Gracias por tu interés!</h3>
            <p class="text-gray-300 leading-relaxed mb-6" data-i18n="form-confirm-desc">Tu solicitud fue recibida. CourseMentor se abrirá para ayudarte a precisar el alcance.</p>
            <button id="lead-form-confirm-close" class="px-6 py-3 rounded-xl bg-rasika-accent text-[#0a0b0d] font-bold hover:bg-[#88d6e0] transition-colors">OK</button>
        </div>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('lead-form');
            if (!form) return;

            form.addEventListener('submit', async (event) => {
                event.preventDefault();

                const config = document.getElementById('page-supabase-config');
                const SUPABASE_URL = config?.getAttribute('data-url');
                const SUPABASE_ANON_KEY = config?.getAttribute('data-key');

                if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
                    console.warn('Missing Supabase page config.');
                    return;
                }

                const nameInput = document.getElementById('lead-name');
                const emailInput = document.getElementById('lead-email');
                const companyInput = document.getElementById('lead-company');
                const projectInput = document.getElementById('lead-project');
                const submitButton = document.getElementById('lead-submit');

                const name = (nameInput?.value || '').trim();
                const email = (emailInput?.value || '').trim();
                const company = (companyInput?.value || '').trim();
                const project = (projectInput?.value || '').trim();

                localStorage.setItem('mentorFormRequestSubmitted', 'true');
                localStorage.setItem('mentorFormProjectContext', project || '');

                if (!name || !email) return;

                if (submitButton) {
                    submitButton.disabled = true;
                    submitButton.classList.add('opacity-60', 'cursor-not-allowed');
                }

                const existingLeadIdBeforeForm = localStorage.getItem('mentorLeadId');
                const existingLeadId = existingLeadIdBeforeForm;
                let leadId = existingLeadId && existingLeadId.trim() ? existingLeadId.trim() : null;

                const leadPayload = {
                    name: name,
                    email: email,
                    company_name: company || 'Pendiente',
                    traffic_source: document.referrer || 'Website Form',
                    lead_id: leadId,
                    language: document.documentElement.lang === 'en' ? 'en' : 'es',
                    session_id: window.rasikaAnalytics?.sessionId || null,
                    page_path: window.location.pathname,
                    website: ''
                };

                try {
                    const captureResponse = await fetch(SUPABASE_URL.replace(/\/$/, '') + '/functions/v1/contact-capture', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'apikey': SUPABASE_ANON_KEY,
                            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                        },
                        body: JSON.stringify(leadPayload)
                    });

                    if (!captureResponse.ok) {
                        console.warn('Lead capture failed:', await captureResponse.text());
                        return;
                    }

                    const captureResult = await captureResponse.json();
                    leadId = captureResult?.lead_id || null;
                    if (!leadId) return;

                    localStorage.setItem('mentorLeadId', leadId);
                    localStorage.setItem('mentorUserName', name);
                    localStorage.setItem('mentorEmail', email);
                    localStorage.setItem('mentorEmailKnown', 'true');

                    if (company) {
                        localStorage.setItem('mentorCompanyKnown', 'true');
                        localStorage.setItem('mentorCompanyName', company);
                    } else {
                        localStorage.removeItem('mentorCompanyKnown');
                        localStorage.removeItem('mentorCompanyName');
                    }

                    // Mark a one-time form-based extension for the upcoming proxy sprint.
                    // This is only a marker for now; openai-proxy must enforce the 15 + 5 policy server-side.
                    localStorage.setItem('mentorFormRequestSubmitted', 'true');
                    localStorage.setItem('rasika_chat_open', 'true');

                    if (existingLeadIdBeforeForm) {
                        await fetch(SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/chat_messages', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'apikey': SUPABASE_ANON_KEY,
                                'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                            },
                            body: JSON.stringify({
                                lead_id: leadId,
                                role: 'system',
                                content: 'FORM_EXTENSION_GRANTED',
                                channel: 'website'
                            })
                        }).catch((error) => {
                            console.warn('Form extension marker save failed:', error);
                        });
                    }

                    const pendingContext =
                        "Solicitud enviada desde formulario:\n" +
                        "Nombre: " + name + "\n" +
                        "Empresa: " + (company || "No indicada") + "\n" +
                        "Email: " + email + "\n" +
                        "Proyecto: " + (project || "No especificado");

                    // Do not pre-save this as a chat message.
                    // The chatbot will send it as the user's first message so the LLM can process it normally.
                    localStorage.setItem('mentorPendingFormContext', pendingContext);
                    localStorage.setItem('mentorFormRequestSubmitted', 'true');

                    const tooltip = document.getElementById('mentor-cta-tooltip');
                    if (tooltip) tooltip.style.display = 'none';

                    const confirmation = document.getElementById('lead-form-confirmation');
                    if (confirmation) {
                        confirmation.classList.remove('hidden');
                        confirmation.classList.add('flex');
                        if (window.lucide) lucide.createIcons();
                    }

                    const closeConfirmation = document.getElementById('lead-form-confirm-close');
                    if (closeConfirmation && confirmation) {
                        closeConfirmation.onclick = function () {
                            confirmation.classList.add('hidden');
                            confirmation.classList.remove('flex');
                        };
                    }

                    setTimeout(() => {
                        const fab = document.getElementById('mentor-fab');
                        const chatWindow = document.getElementById('mentor-window');

                        if (chatWindow && chatWindow.style.display === 'none' && fab) {
                            fab.click();
                        } else if (fab) {
                            fab.click();
                        }
                    }, 150);

                } catch (error) {
                    console.warn('Lead form submission failed:', error);
                } finally {
                    if (submitButton) {
                        submitButton.disabled = false;
                        submitButton.classList.remove('opacity-60', 'cursor-not-allowed');
                    }
                }
            });
        });
    </script>
    <SiteAnalytics />
    <Chatbot />
</body>
</html>
