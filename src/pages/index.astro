---
// src/pages/index.astro
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const seo = seoPages.home;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .animate-float-bounce {
            animation: float-bounce 2s infinite ease-in-out;
        }

        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }

        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <div
        id="page-supabase-config"
        data-url={supabaseUrl}
        data-key={supabaseAnonKey}
        style="display:none;"
    ></div>

    <!-- VIDEO BACKGROUND -->
    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-40 mix-blend-screen filter saturate-50 contrast-125">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
   <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <!-- Floating Chatbot CTA -->
    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="document.getElementById('mentor-fab').click(); this.style.display='none';">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            <span data-i18n="cta-bubble">¡Pruébame!</span> <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <!-- HERO SECTION -->
    <main class="max-w-7xl mx-auto px-6 pt-36 pb-12 relative z-10 flex flex-col items-center md:items-start text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-rasika-accent/10 border border-rasika-accent/20 text-rasika-accent text-xs font-bold uppercase tracking-widest mb-8">
            <span class="w-2 h-2 rounded-full bg-rasika-accent animate-pulse"></span>
            <span data-i18n="hero-badge">Aprendizaje digital 2026</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6 leading-tight max-w-4xl" data-i18n="hero-title">
            E-Learning & <br class="hidden md:block" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Digital Symbiosis</span>
        </h1>
        
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl font-medium mb-10 leading-relaxed" data-i18n="hero-desc">
            Transformamos el conocimiento corporativo en experiencias inmersivas. Producimos contenido SCORM de alto nivel, integraciones de LMS y automatizaciones de IA.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/demos" class="px-8 py-4 bg-rasika-accent text-[#0a0b0d] font-bold rounded-xl hover:bg-[#88d6e0] hover:scale-105 transition-all flex items-center justify-center gap-2">
                <span data-i18n="hero-cta-1">Explorar Demos</span>
                <i data-lucide="play-circle" class="w-5 h-5"></i>
            </a>
            <a href="#contacto" onclick="document.getElementById('contacto').scrollIntoView({ behavior: 'smooth', block: 'center' }); return false;" class="px-8 py-4 bg-white/5 text-white border border-white/10 font-bold rounded-xl hover:bg-white/10 transition-all flex items-center justify-center">
                <span data-i18n="hero-cta-2">Cotiza tu proyecto</span>
            </a>
        </div>
    </main>

    <!-- CINEMATIC SLIDER SECTION -->
    <section class="max-w-7xl mx-auto px-6 py-12 relative z-10">
        <!-- Contenedor con aspecto dinámico: 3:4 en móviles, 4:3 en tablets, 16:9 en desktop, respetando el límite máximo de altura del viewport -->
        <div class="relative w-full rounded-[2rem] ring-1 ring-inset ring-white/10 shadow-2xl bg-rasika-dark overflow-hidden isolate group aspect-[3/4] sm:aspect-[4/3] md:aspect-video min-h-[450px] max-h-[calc(100vh-8rem)]">
            
            <!-- Carrusel Track -->
            <div id="services-slider" class="flex w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]">
                
                <!-- SLIDE 1: Standalone -->
                <div class="w-full h-full shrink-0 flex flex-col relative">
                    <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-50">
                        <source src="/videos/glimpses/video_capsules.mp4" type="video/mp4">
                    </video>
                    <div class="absolute inset-0 bg-gradient-to-t from-rasika-dark via-rasika-dark/40 to-transparent"></div>
                    <div class="relative z-10 mt-auto p-8 md:p-14 max-w-3xl">
                        <i data-lucide="film" class="w-12 h-12 text-rasika-accent mb-6 drop-shadow-lg"></i>
                        <h3 class="text-3xl md:text-5xl font-extrabold text-white mb-4 tracking-tight" data-i18n="srv-1-title">Cápsulas de Video</h3>
                        <p class="text-gray-300 text-base md:text-lg mb-8 leading-relaxed font-medium" data-i18n="srv-1-desc">Producción lineal en 2D Motion Graphics, IA Ultra-realista, grabaciones de estudio y Chroma Key con IA generativa.</p>
                        <div class="flex flex-wrap gap-3">
                            <a href="/demos" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm">
                                <span data-i18n="srv-link">Ver catálogo</span> <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </a>
                            <a href="/chroma-key-ia/" class="inline-flex items-center gap-2 px-6 py-3 bg-black/30 hover:bg-white/10 text-white border border-white/20 rounded-xl font-bold transition-all backdrop-blur-sm">
                                <span data-i18n="srv-chroma-link">Chroma Key con IA</span> <i data-lucide="sparkles" class="w-4 h-4 text-rasika-accent"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- SLIDE 2: Interactive -->
                <div class="w-full h-full shrink-0 flex flex-col relative">
                    <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-50">
                        <source src="/videos/glimpses/interactive_scorm.mp4" type="video/mp4">
                    </video>
                    <div class="absolute inset-0 bg-gradient-to-t from-rasika-dark via-rasika-dark/40 to-transparent"></div>
                    <div class="relative z-10 mt-auto p-8 md:p-14 max-w-3xl">
                        <i data-lucide="mouse-pointer-click" class="w-12 h-12 text-rasika-accent mb-6 drop-shadow-lg"></i>
                        <h3 class="text-3xl md:text-5xl font-extrabold text-white mb-4 tracking-tight" data-i18n="srv-2-title">Cursos Interactivos</h3>
                        <p class="text-gray-300 text-base md:text-lg mb-8 leading-relaxed font-medium" data-i18n="srv-2-desc">Empaquetado SCORM y HTML5 combinando diseño instruccional, evaluaciones gamificadas y bloques interactivos inmersivos.</p>
                        <a href="/cursos-interactivos" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm">
                            <span data-i18n="srv-link">Ver catálogo</span> <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                    </div>
                </div>

                <!-- SLIDE 3: LMS & Bots -->
                <div class="w-full h-full shrink-0 flex flex-col relative">
                    <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover opacity-50">
                        <source src="/videos/glimpses/talentlms_demo.mp4" type="video/mp4">
                    </video>
                    <div class="absolute inset-0 bg-gradient-to-t from-rasika-dark via-rasika-dark/40 to-transparent"></div>
                    <div class="relative z-10 mt-auto p-8 md:p-14 max-w-3xl">
                        <i data-lucide="cpu" class="w-12 h-12 text-rasika-accent mb-6 drop-shadow-lg"></i>
                        <h3 class="text-3xl md:text-5xl font-extrabold text-white mb-4 tracking-tight" data-i18n="srv-3-title">LMS & Automatización</h3>
                        <p class="text-gray-300 text-base md:text-lg mb-8 leading-relaxed font-medium" data-i18n="srv-3-desc">Integraciones nativas para TalentLMS y Moodle, chatbots educativos personalizados y webhooks de datos CRM.</p>
                        <a href="/lms" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/20 hover:border-transparent rounded-xl font-bold transition-all backdrop-blur-sm">
                            <span data-i18n="srv-link-tech">Explorar tecnología</span> <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                    </div>
                </div>

            </div>

            <!-- Controles Inferiores (Puntos) -->
            <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-2 z-20">
                <button onclick="window.goToSlide(0)" class="slider-dot w-8 h-1.5 rounded-full bg-rasika-accent transition-all duration-300"></button>
                <button onclick="window.goToSlide(1)" class="slider-dot w-2 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-all duration-300"></button>
                <button onclick="window.goToSlide(2)" class="slider-dot w-2 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-all duration-300"></button>
            </div>

            <!-- Flechas de Navegación Laterales (Visibles en desktop al pasar el cursor) -->
            <button onclick="window.prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 p-3 rounded-full bg-black/30 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 hidden sm:flex items-center justify-center backdrop-blur-sm">
                <i data-lucide="chevron-left" class="w-6 h-6"></i>
            </button>
            <button onclick="window.nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 p-3 rounded-full bg-black/30 hover:bg-rasika-accent hover:text-[#0a0b0d] border border-white/10 hover:border-transparent text-white opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 hidden sm:flex items-center justify-center backdrop-blur-sm">
                <i data-lucide="chevron-right" class="w-6 h-6"></i>
            </button>
            
        </div>
    </section>

    <!-- FORMULARIO DE CONTACTO BREVE -->
    <section id="contacto" class="max-w-4xl mx-auto px-6 py-24 relative z-10">
        <div class="bg-gradient-to-br from-[#1E2226]/95 to-black/80 backdrop-blur-md rounded-[2rem] p-8 md:p-12 ring-1 ring-inset ring-white/10 shadow-2xl">
            <div class="text-center mb-10">
                <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3 tracking-tight" data-i18n="form-title">Cotiza tu proyecto</h2>
                <p class="text-gray-400 font-medium" data-i18n="form-desc">Completa este breve formulario o interactúa con CourseMentor para un presupuesto inmediato.</p>
            </div>
            
            <form id="lead-form" class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <input
                        id="lead-name"
                        type="text"
                        data-i18n-placeholder="form-name-placeholder"
                        placeholder="Tu Nombre"
                        required
                        class="w-full bg-[#141619] border border-white/10 text-white placeholder-gray-500 rounded-xl px-5 py-4 focus:border-rasika-accent focus:ring-1 focus:ring-rasika-accent outline-none transition-all"
                    >
                    <input
                        id="lead-email"
                        type="email"
                        data-i18n-placeholder="form-email-placeholder"
                        placeholder="Correo Corporativo"
                        required
                        class="w-full bg-[#141619] border border-white/10 text-white placeholder-gray-500 rounded-xl px-5 py-4 focus:border-rasika-accent focus:ring-1 focus:ring-rasika-accent outline-none transition-all"
                    >
                </div>

                <input
                    id="lead-company"
                    type="text"
                    data-i18n-placeholder="form-company-placeholder"
                    placeholder="Empresa (opcional)"
                    class="w-full bg-[#141619] border border-white/10 text-white placeholder-gray-500 rounded-xl px-5 py-4 focus:border-rasika-accent focus:ring-1 focus:ring-rasika-accent outline-none transition-all"
                >

                <textarea
                    id="lead-project"
                    data-i18n-placeholder="form-project-placeholder"
                    placeholder="Cuéntanos brevemente sobre tu proyecto o curso..."
                    rows="4"
                    class="w-full bg-[#141619] border border-white/10 text-white placeholder-gray-500 rounded-xl px-5 py-4 focus:border-rasika-accent focus:ring-1 focus:ring-rasika-accent outline-none transition-all resize-none"
                ></textarea>
                
                <button
                    id="lead-submit"
                    type="submit"
                    class="w-full bg-rasika-accent text-[#0a0b0d] font-bold rounded-xl py-4 hover:bg-[#88d6e0] transition-colors flex justify-center items-center gap-2"
                >
                    <span data-i18n="form-submit">Enviar Solicitud</span>
                    <i data-lucide="send" class="w-4 h-4"></i>
                </button>
            </form>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-white/5 bg-rasika-dark/80 relative z-10 mt-10">
        <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 font-medium">
            <p data-i18n="footer-text">© 2026 Rasika Producciones. Todos los derechos reservados.</p>
            <div class="flex gap-6">
                <a href="/lms" class="hover:text-rasika-accent transition-colors">LMS & Bots</a>
                <a href="/demos" class="hover:text-rasika-accent transition-colors">Demos</a>
                <a href="/blog" class="hover:text-rasika-accent transition-colors">Blog</a>
            </div>
        </div>
    </footer>

    <!-- LÓGICA DEL SLIDER -->
    <script is:inline>
// Mobile Menu Toggle Logic
document.addEventListener('DOMContentLoaded', () => {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if(mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
            // Toggle visibility and flexbox stacking
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            
            // Swap hamburger icon for 'X' icon
            const icon = mobileBtn.querySelector('i');
            if (mobileMenu.classList.contains('hidden')) {
                icon.setAttribute('data-lucide', 'menu');
            } else {
                icon.setAttribute('data-lucide', 'x');
            }
            if(window.lucide) lucide.createIcons();
        });
    }
});

        // GLOW EFFECT SCROLL LISTENER (More robust height calculation)
        window.addEventListener('scroll', () => {
            const tooltip = document.getElementById('mentor-cta-tooltip');
            if (!tooltip) return;
            
            // Usamos Math.max para compatibilidad entre diferentes navegadores
            const docHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight);
            const scrollPosition = window.innerHeight + window.scrollY;
            const threshold = docHeight - 200; // Activa 200px antes del final
            
            if (scrollPosition >= threshold) {
                tooltip.classList.add('cta-glow-active');
            } else {
                tooltip.classList.remove('cta-glow-active');
            }
        });


        document.addEventListener('DOMContentLoaded', () => {
            let currentSlide = 0;
            const totalSlides = 3;
            let slideInterval;

            const slider = document.getElementById('services-slider');
            const dots = document.querySelectorAll('.slider-dot');

            window.updateSlider = function() {
                slider.style.transform = `translateX(-${currentSlide * 100}%)`;
                
                dots.forEach((dot, index) => {
                    if (index === currentSlide) {
                        dot.className = 'slider-dot w-8 h-1.5 rounded-full bg-rasika-accent transition-all duration-300';
                    } else {
                        dot.className = 'slider-dot w-2 h-1.5 rounded-full bg-white/30 hover:bg-white/60 transition-all duration-300';
                    }
                });
            };

            window.nextSlide = function() {
                currentSlide = (currentSlide + 1) % totalSlides;
                window.updateSlider();
                window.resetInterval();
            };

            window.prevSlide = function() {
                currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                window.updateSlider();
                window.resetInterval();
            };

            window.goToSlide = function(index) {
                currentSlide = index;
                window.updateSlider();
                window.resetInterval();
            };

            window.startInterval = function() {
                slideInterval = setInterval(() => {
                    currentSlide = (currentSlide + 1) % totalSlides;
                    window.updateSlider();
                }, 6000); // Cambia de slide cada 6 segundos
            };

            window.resetInterval = function() {
                clearInterval(slideInterval);
                window.startInterval();
            };

            // Iniciar slider automático
            window.startInterval();
        });
    </script>

    <!-- INTERNACIONALIZACIÓN (i18n) -->
    <script is:inline>
        const translations = {
            es: {
                "nav-demos": "Demos",
                "nav-lms": "LMS & Bots",
                "nav-clients": "Clientes",
                "nav-blog": "Blog",
                "nav-pricing": "Precios",
                "toggle-btn": "EN",
                "hero-badge": "Aprendizaje digital 2026",
                "hero-title": "E-Learning &\nDigital Symbiosis",
                "hero-desc": "Transformamos el conocimiento corporativo en experiencias inmersivas. Producimos contenido SCORM de alto nivel, integraciones de LMS y automatizaciones de IA.",
                "hero-cta-1": "Explorar Demos",
                "hero-cta-2": "Cotiza tu proyecto",
                "srv-1-title": "Cápsulas de Video",
                "srv-1-desc": "Producción lineal en 2D Motion Graphics, IA Ultra-realista, grabaciones de estudio y Chroma Key con IA generativa.",
                "srv-2-title": "Cursos Interactivos",
                "srv-2-desc": "Empaquetado SCORM y HTML5 combinando diseño instruccional, evaluaciones gamificadas y bloques interactivos inmersivos.",
                "srv-3-title": "LMS & Automatización",
                "srv-3-desc": "Integraciones nativas para TalentLMS y Moodle, chatbots educativos personalizados y webhooks de datos CRM.",
                "srv-link": "Ver catálogo",
                "srv-chroma-link": "Chroma Key con IA",
                "srv-link-tech": "Explorar tecnología",
                "form-title": "Cotiza tu proyecto",
                "form-desc": "Completa este breve formulario o interactúa con CourseMentor para un presupuesto inmediato.",
                "form-name-placeholder": "Tu Nombre",
                "form-email-placeholder": "Correo Corporativo",
                "form-company-placeholder": "Empresa (opcional)",
                "form-project-placeholder": "Cuéntanos brevemente sobre tu proyecto o curso...",
                "form-submit": "Enviar Solicitud",
                "form-confirm-title": "¡Gracias por tu interés!",
                "form-confirm-desc": "Tu solicitud fue recibida. CourseMentor se abrirá para ayudarte a precisar el alcance.",
