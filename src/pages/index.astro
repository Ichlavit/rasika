        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();

            let currentLang = "es";
            const toggleBtn = document.getElementById('lang-toggle');

            toggleBtn.addEventListener('click', () => {
                currentLang = currentLang === "es" ? "en" : "es";
                document.documentElement.lang = currentLang;

                document.querySelectorAll('[data-i18n]').forEach(el => {
                    const key = el.getAttribute('data-i18n');
                    if (translations[currentLang][key]) {
                        if (key === 'hero-title') {
                            el.innerHTML = translations[currentLang][key].replace('\n', '<br class="hidden md:block" />');
                            el.innerHTML = el.innerHTML.replace('Digital Symbiosis', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Digital Symbiosis</span>');
                        } else {
                            el.innerText = translations[currentLang][key];
                        }
                    }
                });
                

                document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                    const key = el.getAttribute('data-i18n-placeholder');
                    if (translations[currentLang][key]) {
                        el.setAttribute('placeholder', translations[currentLang][key]);
                    }
                });
                
                toggleBtn.innerText = translations[currentLang]["toggle-btn"];
            });
        });
