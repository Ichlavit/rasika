                        >
                            <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
                                <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
                                    <source src={demo.thumbnail_url} type="video/mp4" />
                                </video>
                                <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
                                <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
                                    <i data-lucide={demo.icon_name || 'play'} class:list={[demo.icon_name === 'monitor-play' ? 'w-8 h-8 text-white' : demo.icon_name === 'mouse-pointer-2' ? 'w-8 h-8 text-white ml-0.5' : 'w-8 h-8 text-white ml-1']}></i>
                                </div>
                            </div>
                            <div class="p-6 flex-1 flex flex-col relative z-10">
                                <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
