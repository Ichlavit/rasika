---
// src/pages/demos.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.demos;

type DemoCatalogItem = {
    slug: string;
    service_id: string;
    service_content_id: string | null;
    section_key: 'standalone_videos' | 'interactive_scorm';
    sort_order: number;
    category: 'video' | 'interactive';
    demo_name: string;
    format_type: string;
    client_name: string | null;
    project_year: string | null;
    description: string;
    source_url: string;
    thumbnail_url: string;
    media_type: 'video' | 'interactive';
    custom_width: string | null;
    tag_label: string;
    card_title: string;
    card_description: string;
    icon_name: string;
    cta_label: string;
};

const demoFields = [
    'slug',
    'service_id',
    'service_content_id',
    'section_key',
    'sort_order',
    'category',
    'demo_name',
    'format_type',
    'client_name',
    'project_year',
    'description',
    'source_url',
    'thumbnail_url',
    'media_type',
    'custom_width',
    'tag_label',
    'card_title',
    'card_description',
    'icon_name',
    'cta_label',
].join(',');

async function fetchDemoCatalog(): Promise<DemoCatalogItem[]> {
    const supabaseUrl = (import.meta.env.SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').replace(/\/$/, '');
    const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

    if (!supabaseUrl || !supabaseKey) {
        console.warn('Missing Supabase env vars for demo catalog build.');
        return [];
    }

    const response = await fetch(
        `${supabaseUrl}/rest/v1/demo_catalog?select=${demoFields}&is_active=eq.true&order=sort_order.asc`,
        {
            headers: {
                apikey: supabaseKey,
                Authorization: `Bearer ${supabaseKey}`,
            },
        },
    );

    if (!response.ok) {
        console.warn(`Could not fetch demo catalog: ${response.status}`);
        return [];
    }

    return (await response.json()) as DemoCatalogItem[];
}

const demoCatalog = await fetchDemoCatalog();

const sectionConfigs = [
    {
        key: 'standalone_videos',
        sectionId: 'section-standalone-videos',
        carouselId: 'carousel-1',
        title: 'Videos Independientes',
        description: 'Activos lineales modulares (Animaciones 2D, IA y grabaciones en estudio).',
    },
    {
        key: 'interactive_scorm',
        sectionId: 'section-interactive-scorm',
        carouselId: 'carousel-2',
        title: 'Experiencias Interactivas & SCORM',
        description: 'Navegación interactiva, simuladores de software y módulos empaquetados para LMS tradicionales.',
    },
].map((section) => ({
    ...section,
    demos: demoCatalog.filter((demo) => demo.section_key === section.key),
}));
---

<!DOCTYPE html>
