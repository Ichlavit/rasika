                            {section.title}
                        </h2>
                        <p class="text-gray-400 font-medium">{section.description}</p>
                    </div>
                    <div class="flex gap-3 shrink-0">
                        <button type="button" data-carousel-control="left" data-carousel-target={section.carouselId} class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all" aria-label={`Desplazar ${section.title} a la izquierda`}>
                            <i data-lucide="chevron-left" class="w-5 h-5"></i>
                        </button>
                        <button type="button" data-carousel-control="right" data-carousel-target={section.carouselId} class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all" aria-label={`Desplazar ${section.title} a la derecha`}>
