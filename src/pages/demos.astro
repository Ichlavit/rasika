---
// src/pages/demos.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.demos;

type DemoCatalogItem = {
    slug: string;
    service_id: string;
    service_content_id: string | null;
    section_key: 'standalone_videos' | 'interactive_scorm';
    sort_order: number;
    category: 'video' | 'interactive';
    demo_name: string;
    format_type: string;
    client_name: string | null;
    project_year: string | null;
    description: string;
    source_url: string;
    thumbnail_url: string;
    media_type: 'video' | 'interactive' | 'video_enhance';
    comparison_source_url: string | null;
    custom_width: string | null;
    tag_label: string;
    card_title: string;
    card_description: string;
    icon_name: string;
    cta_label: string;
};

const demoFields = [
    'slug',
    'service_id',
    'service_content_id',
    'section_key',
    'sort_order',
    'category',
    'demo_name',
    'format_type',
    'client_name',
    'project_year',
    'description',
    'source_url',
    'comparison_source_url',
    'thumbnail_url',
    'media_type',
    'custom_width',
    'tag_label',
    'card_title',
    'card_description',
    'icon_name',
    'cta_label',
].join(',');

async function fetchDemoCatalog(): Promise<DemoCatalogItem[]> {
    const supabaseUrl = (import.meta.env.SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').replace(/\/$/, '');
    const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

    if (!supabaseUrl || !supabaseKey) {
        console.warn('Missing Supabase env vars for demo catalog build.');
        return [];
    }

    const response = await fetch(
        `${supabaseUrl}/rest/v1/demo_catalog?select=${demoFields}&is_active=eq.true&order=sort_order.asc`,
        {
            headers: {
                apikey: supabaseKey,
                Authorization: `Bearer ${supabaseKey}`,
            },
        },
    );

    if (!response.ok) {
        console.warn(`Could not fetch demo catalog: ${response.status}`);
        return [];
    }

    return (await response.json()) as DemoCatalogItem[];
}

const demoCatalog = await fetchDemoCatalog();

const sectionConfigs = [
    {
        key: 'standalone_videos',
        sectionId: 'section-standalone-videos',
        carouselId: 'carousel-1',
        title: 'Videos Independientes',
        description: 'Activos lineales modulares (Animaciones 2D, IA y grabaciones en estudio).',
    },
    {
        key: 'interactive_scorm',
        sectionId: 'section-interactive-scorm',
        carouselId: 'carousel-2',
        title: 'Experiencias Interactivas & SCORM',
        description: 'Navegación interactiva, simuladores de software y módulos empaquetados para LMS tradicionales.',
    },
].map((section) => ({
    ...section,
    demos: demoCatalog.filter((demo) => demo.section_key === section.key),
}));
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }

        :global(.video-enhance-range) {
            appearance: none;
            -webkit-appearance: none;
            background: transparent;
            cursor: ew-resize;
        }
        :global(.video-enhance-range)::-webkit-slider-runnable-track {
            height: 100%;
            background: transparent;
        }
        :global(.video-enhance-range)::-webkit-slider-thumb {
            appearance: none;
            -webkit-appearance: none;
            width: 48px;
            height: 100%;
            background: transparent;
            border: 0;
        }
        :global(.video-enhance-range)::-moz-range-track {
            height: 100%;
            background: transparent;
            border: 0;
        }
        :global(.video-enhance-range)::-moz-range-thumb {
            width: 48px;
            height: 100%;
            background: transparent;
            border: 0;
        }
        :global(.video-enhance-scrub-surface) {
            cursor: ew-resize;
            touch-action: none;
        }
        :global([data-video-enhance-player]),
        :global([data-video-enhance-player] *) {
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            user-select: none;
            -webkit-user-drag: none;
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Bottom Scroll Glow Classes */
        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }
        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <!-- Dynamic Animated Background -->
    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-40 mix-blend-screen filter saturate-50 contrast-125">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
  <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <!-- Floating Chatbot CTA -->
    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="document.getElementById('mentor-fab').click(); this.style.display='none';">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            <span data-i18n="cta-bubble">¡Pruébame!</span> <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <!-- Hero Section -->
    <header class="pt-36 pb-16 relative z-10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-rasika-accent/10 border border-rasika-accent/20 text-rasika-accent text-xs font-bold mb-6">
                <i data-lucide="play-circle" class="w-3.5 h-3.5"></i> <span data-i18n="demos-badge">Catálogo Visual</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight leading-tight" data-i18n="demos-title">
                Explora el poder de la <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Simbiosis Digital</span>
            </h1>
            <p class="text-lg text-gray-400 max-w-2xl leading-relaxed" data-i18n="demos-desc">
                Sumérgete en nuestra galería de experiencias de aprendizaje. Desde video inmersivo hasta módulos SCORM interactivos.
            </p>
        </div>
    </header>

    <section class="border-y border-white/10 bg-[#101215]/95 relative z-10" aria-labelledby="chroma-service-title">
        <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
            <div class="max-w-4xl">
                <p class="text-rasika-accent text-xs font-extrabold uppercase tracking-widest mb-3" data-i18n="chroma-eyebrow">Nuevo servicio audiovisual · Santiago de Chile</p>
                <h2 id="chroma-service-title" class="text-2xl md:text-3xl font-extrabold text-white mb-3" data-i18n="chroma-title">Chroma Key con IA generativa en Chile</h2>
                <p class="text-gray-400 leading-relaxed" data-i18n="chroma-copy">Actores reales dan vida a la escena mientras la IA generativa crea locaciones, vestuario y extras. Conservamos la actuación humana y ampliamos la producción sin repetir cada rodaje.</p>
            </div>
            <a href="/chroma-key-ia/" class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-white/5 border border-white/15 text-white font-bold rounded-lg hover:bg-rasika-accent hover:text-[#0a0b0d] hover:border-transparent transition-colors shrink-0">
                <span data-i18n="chroma-link">Conocer el servicio</span> <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-6 pb-24 relative z-10">
        {sectionConfigs.map((section, index) => (
            <section id={section.sectionId} class:list={[index > 0 && 'mt-8', 'scroll-mt-28']}>
                <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
                    <div>
                        <h2 class="text-3xl font-bold text-white mb-2 tracking-tight flex items-center gap-3">
                            {section.title}
                        </h2>
                        <p class="text-gray-400 font-medium">{section.description}</p>
                    </div>
                    <div class="flex gap-3 shrink-0">
                        <button type="button" data-carousel-control="left" data-carousel-target={section.carouselId} class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all" aria-label={`Desplazar ${section.title} a la izquierda`}>
                            <i data-lucide="chevron-left" class="w-5 h-5"></i>
                        </button>
                        <button type="button" data-carousel-control="right" data-carousel-target={section.carouselId} class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all" aria-label={`Desplazar ${section.title} a la derecha`}>
                            <i data-lucide="chevron-right" class="w-5 h-5"></i>
                        </button>
                    </div>
                </div>

                <div id={section.carouselId} class="flex overflow-x-auto snap-x snap-mandatory gap-8 pb-12 pt-4 px-4 -mx-4 no-scrollbar scroll-smooth">
                    {section.demos.map((demo) => (
                        <article
                            id={`demo-${demo.slug}`}
                            data-demo-card
                            data-demo-slug={demo.slug}
                            role="button"
                            tabindex="0"
                            class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]"
                            aria-label={`Ver demo: ${demo.card_title}`}
                        >
                            <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
                                <video autoplay muted loop playsinline preload="metadata" poster={demo.slug === 'video-enhance-ia' ? '/images/demos/video-enhance-ia.jpg' : undefined} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
                                    <source src={demo.thumbnail_url} type="video/mp4" />
                                </video>
                                <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
                                <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
                                    <i data-lucide={demo.icon_name || 'play'} class:list={[demo.icon_name === 'monitor-play' ? 'w-8 h-8 text-white' : demo.icon_name === 'mouse-pointer-2' ? 'w-8 h-8 text-white ml-0.5' : 'w-8 h-8 text-white ml-1']}></i>
                                </div>
                            </div>
                            <div class="p-6 flex-1 flex flex-col relative z-10">
                                <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
                                    {demo.tag_label}
                                </div>
                                <h3 class="text-xl font-bold text-white mb-2 leading-tight">{demo.card_title}</h3>
                                <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">{demo.card_description}</p>
                                <button type="button" class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
                                    {demo.cta_label || 'Ver Demo'} <i data-lucide="arrow-right" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </article>
                    ))}
                </div>
            </section>
        ))}
    </main>

    <footer class="border-t border-white/5 bg-rasika-dark/80 relative z-10 mt-12">
        <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 font-medium">
            <p data-i18n="footer-text">© 2026 Rasika Producciones. Todos los derechos reservados.</p>
            <div class="flex gap-6">
                <a href="https://linkedin.com" target="_blank" class="hover:text-rasika-accent transition-colors">LinkedIn</a>
                <a href="#" class="hover:text-rasika-accent transition-colors">Términos</a>
            </div>
        </div>
    </footer>

    <!-- CINEMATIC MODAL (THEATER MODE) -->
    <div id="demo-modal" class="fixed inset-0 z-[200] hidden items-center justify-center opacity-0 transition-opacity duration-300">
        <!-- Fullscreen backdrop -->
        <div class="absolute inset-0 bg-[#0a0b0d]/95 backdrop-blur-md" onclick="closeDemo()"></div>
        
        <!-- Floating Close Button -->
        <button onclick="closeDemo()" class="absolute top-6 right-6 z-50 w-12 h-12 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center text-white transition-colors border border-white/10 shadow-lg">
            <i data-lucide="x" class="w-6 h-6"></i>
        </button>
        
        <!-- The Floating Player Container -->
        <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 flex flex-col items-center" id="player-container">
            <!-- Content gets injected here -->
        </div>
        
        <!-- Title and Category -->
        <div class="absolute bottom-8 md:bottom-12 left-1/2 -translate-x-1/2 z-20 text-center w-full px-6 pointer-events-none">
            <h3 id="demo-title" class="text-2xl md:text-3xl font-bold text-white mb-2 drop-shadow-lg"></h3>
            <p id="demo-category" class="text-rasika-accent text-sm md:text-base font-bold uppercase tracking-widest drop-shadow"></p>
        </div>
    </div>

    <script define:vars={{ demoCatalog }}>
        window.rasikaDemoCatalog = demoCatalog;
    </script>

    <!-- SCRIPTS -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();
            
            const urlParams = new URLSearchParams(window.location.search);
            const referredBy = urlParams.get('ref');
            if (referredBy && referredBy !== window.mentorLeadId) {
                localStorage.setItem('rasika_referred_by', referredBy);
            }

            document.querySelectorAll('[data-carousel-control]').forEach((button) => {
                button.addEventListener('click', () => {
                    scrollCarousel(button.getAttribute('data-carousel-control'), button.getAttribute('data-carousel-target'));
                });
            });

            document.querySelectorAll('[data-demo-card]').forEach((card) => {
                card.addEventListener('click', () => {
                    window.openDemoBySlug(card.getAttribute('data-demo-slug'));
                });

                card.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        window.openDemoBySlug(card.getAttribute('data-demo-slug'));
                    }
                });
            });

            const requestedDemo = urlParams.get('demo');
            if (requestedDemo) {
                setTimeout(() => window.openDemoBySlug(requestedDemo), 250);
            }
        });

// Mobile Menu Toggle Logic
document.addEventListener('DOMContentLoaded', () => {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if(mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
            // Toggle visibility and flexbox stacking
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            
            // Swap hamburger icon for 'X' icon
            const icon = mobileBtn.querySelector('i');
            if (mobileMenu.classList.contains('hidden')) {
                icon.setAttribute('data-lucide', 'menu');
            } else {
                icon.setAttribute('data-lucide', 'x');
            }
            if(window.lucide) lucide.createIcons();
        });
    }
});

        // GLOW EFFECT SCROLL LISTENER (More robust height calculation)
        window.addEventListener('scroll', () => {
            const tooltip = document.getElementById('mentor-cta-tooltip');
            if (!tooltip) return;
            
            // Usamos Math.max para compatibilidad entre diferentes navegadores
            const docHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight);
            const scrollPosition = window.innerHeight + window.scrollY;
            const threshold = docHeight - 200; // Activa 200px antes del final
            
            if (scrollPosition >= threshold) {
                tooltip.classList.add('cta-glow-active');
            } else {
                tooltip.classList.remove('cta-glow-active');
            }
        });

        // Horizontal scrolling function for the carousels
        window.scrollCarousel = function(direction, id) {
            const carousel = document.getElementById(id);
            if (!carousel) return;
            const scrollAmount = 400; // adjust as needed
            if(direction === 'left') {
                carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            } else {
                carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            }
        }

        function getDemoBySlug(slug) {
            const safeSlug = String(slug || '').trim();
            const catalog = Array.isArray(window.rasikaDemoCatalog) ? window.rasikaDemoCatalog : [];
            return catalog.find((demo) => demo.slug === safeSlug) || null;
        }

        window.openDemoBySlug = function(slug) {
            const demo = getDemoBySlug(slug);
            if (!demo) return false;

            const card = document.getElementById('demo-' + demo.slug);
            if (card) {
                card.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
            }

            window.launchDemo(
                demo.demo_name,
                demo.format_type,
                demo.client_name || '',
                demo.project_year || '',
                demo.description || '',
                demo.source_url,
                demo.media_type,
                demo.custom_width || null,
                {
                    serviceId: demo.service_id,
                    serviceContentId: demo.service_content_id,
                    serviceName: demo.format_type,
                    demoName: demo.demo_name,
                    demoSlug: demo.slug,
                    comparisonSourceUrl: demo.comparison_source_url || null
                }
            );

            return true;
        };

        window.rasikaUiActions = window.rasikaUiActions || {};
        window.rasikaUiActions.openDemo = window.openDemoBySlug;

        // --- TRANSLATIONS DICTIONARY ---
        const translations = {
            es: {
                "nav-demos": "Demos",
                "nav-lms": "LMS & Bots",
                "nav-clients": "Clientes",
                "nav-pricing": "Precios",
                "nav-blog": "Blog",
                "toggle-btn": "EN",
                "cta-bubble": "¡Pruébame!",
                "demos-badge": "Catálogo Visual",
