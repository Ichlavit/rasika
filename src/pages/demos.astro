            }
        };

        const toggleBtn = document.getElementById('lang-toggle');
        let currentLang = "es";

        if(toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                currentLang = currentLang === "es" ? "en" : "es";
                document.documentElement.lang = currentLang;

                document.querySelectorAll('[data-i18n]').forEach(el => {
                    const key = el.getAttribute('data-i18n');
                    if (translations[currentLang][key]) {
                        el.innerHTML = translations[currentLang][key];
                    }
                });
                
                toggleBtn.innerText = translations[currentLang]["toggle-btn"];
            });
        }

        // --- THE UPGRADED CINEMATIC ROUTER ---
        // Notice we added 'customWidth' as the final optional parameter
        window.launchDemo = function(courseName, formatType, client, year, description, source, mediaType = 'video', customWidth = null, serviceMeta = null) {
            // Canonical service context for CourseMentor. Prefer real services.id over UI/display labels.
            if (customWidth && typeof customWidth === 'object' && !serviceMeta) {
                serviceMeta = customWidth;
                customWidth = null;
            }

            const modal = document.getElementById('demo-modal');
            const playerArea = document.getElementById('player-container');
            const titleEl = document.getElementById('demo-title');
            const categoryEl = document.getElementById('demo-category');
            
            if (titleEl) titleEl.innerText = courseName;
            if (categoryEl) categoryEl.innerText = formatType;
            
            let contentHtml = '';

            // Inject Video OR Iframe cleanly into the floating container
            if (mediaType === 'video') {
                contentHtml = `<video src="${source}" controls autoplay playsinline class="w-full h-full object-cover"></video>`;
            } else if (mediaType === 'interactive') {
                // Background white ensures transparent SCORM backgrounds look correct.
                contentHtml = `<iframe src="${source}" class="w-full h-full border-0 bg-white" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
            }

            // SMART SIZING: Use exact dimensions if requested, otherwise default to massive 16:9
            let containerStyle = customWidth 
                ? `max-width: ${customWidth}; aspect-ratio: 1024/627;` 
                : `max-width: calc(75vh * 16 / 9); aspect-ratio: 16/9;`;

            // Removed 'aspect-video' from Tailwind classes to allow the dynamic aspect-ratio to override it
            playerArea.innerHTML = `
                <div class="w-full max-h-[75vh] lg:max-h-[85vh] rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 bg-[#0f1114] shadow-2xl flex items-center justify-center relative transition-all duration-500" style="${containerStyle}">
                    ${contentHtml}
                </div>
            `;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            requestAnimationFrame(() => {
                modal.classList.remove('opacity-0');
            });
            
            // Sync with Chatbot using canonical service data. Do not pass mockup/display labels.
            if (window.setMentorCourse && serviceMeta && serviceMeta.serviceId) {
                window.setMentorCourse({
                    serviceId: serviceMeta.serviceId,
                    serviceContentId: serviceMeta.serviceContentId || null,
                    demoSlug: serviceMeta.demoSlug || null,
                    label: serviceMeta.serviceName || formatType || courseName,
                    serviceName: serviceMeta.serviceName || formatType || courseName,
                    demoName: serviceMeta.demoName || courseName
                });
            } else if (window.setMentorCourse) {
                window.setMentorCourse(courseName);
            } else {
                window.mentorActiveCourse = courseName;
            }
            setTimeout(() => {
                const fab = document.getElementById('mentor-fab');
                const chatWindow = document.getElementById('mentor-window');
                if (chatWindow && chatWindow.style.display === 'none' && fab) {
                    fab.click();
                }
            }, 10000);
        }

        window.closeDemo = function() {
            const modal = document.getElementById('demo-modal');
            
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                
                // Reset the container to the loader state to stop audio/video/iframes playing in background
                const playerArea = document.getElementById('player-container');
                if(playerArea) {
                    playerArea.innerHTML = `
                        <div class="w-full aspect-video max-h-[65vh] rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 bg-[#0f1114] flex flex-col items-center justify-center text-gray-500 shadow-2xl" style="max-width: calc(65vh * 16 / 9);">
                            <i data-lucide="loader-2" class="w-12 h-12 animate-spin mb-4 text-rasika-accent"></i>
                            <p class="text-sm font-medium tracking-wide">Cerrando recurso...</p>
                        </div>
                    `;
                }
                if (window.lucide) lucide.createIcons();
            }, 300);
            
            if (window.setMentorCourse) {
                window.setMentorCourse("Catálogo General");
            } else {
                window.mentorActiveCourse = "Catálogo General";
            }
        }
    </script>
    
    <Chatbot />
</body>
</html>
