---
// src/pages/demos.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.demos;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }
        
        /* Bottom Scroll Glow Classes */
        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }
        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <!-- Dynamic Animated Background -->
    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-40 mix-blend-screen filter saturate-50 contrast-125">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
  <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <!-- Floating Chatbot CTA -->
    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="document.getElementById('mentor-fab').click(); this.style.display='none';">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            <span data-i18n="cta-bubble">¡Pruébame!</span> <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <!-- Hero Section -->
    <header class="pt-36 pb-16 relative z-10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-rasika-accent/10 border border-rasika-accent/20 text-rasika-accent text-xs font-bold mb-6">
                <i data-lucide="play-circle" class="w-3.5 h-3.5"></i> <span data-i18n="demos-badge">Catálogo Visual</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight leading-tight" data-i18n="demos-title">
                Explora el poder de la <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">Simbiosis Digital</span>
            </h1>
            <p class="text-lg text-gray-400 max-w-2xl leading-relaxed" data-i18n="demos-desc">
                Sumérgete en nuestra galería de experiencias de aprendizaje. Desde video inmersivo hasta módulos SCORM interactivos.
            </p>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pb-24 relative z-10">
        
        <!-- CATEGORY 1: Standalone Videos -->
        <section>
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
                <div>
                    <h2 class="text-3xl font-bold text-white mb-2 tracking-tight flex items-center gap-3">
                        Videos Independientes
                    </h2>
                    <p class="text-gray-400 font-medium">Activos lineales modulares (Animaciones 2D, IA y grabaciones en estudio).</p>
                </div>
                <div class="flex gap-3 shrink-0">
                    <button onclick="scrollCarousel('left', 'carousel-1')" class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all">
                        <i data-lucide="chevron-left" class="w-5 h-5"></i>
                    </button>
                    <button onclick="scrollCarousel('right', 'carousel-1')" class="p-3 rounded-full bg-white/5 border border-white/10 hover:bg-rasika-accent/10 hover:border-rasika-accent hover:text-rasika-accent text-white transition-all">
                        <i data-lucide="chevron-right" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <!-- CAROUSEL -->
            <div id="carousel-1" class="flex overflow-x-auto snap-x snap-mandatory gap-8 pb-12 pt-4 px-4 -mx-4 no-scrollbar scroll-smooth">
                
                <div onclick="launchDemo('Video operacional para operarios en faenas mineras', '2D Motion Graphics (Flat Design)', 'AMSA', '2023', 'Videos explicativos utilizando Flat design moderno. Incluye: Storyboard a medida, animación 2D, locución, música de fondo y subtítulos.', '/videos/standalone/2D_motion_graphics.mp4', 'video', null, { serviceId: '083651d6-9f56-479f-9aec-36279119aeda', serviceName: '2D Motion Graphics (Flat Design)', demoName: 'Video operacional para operarios en faenas mineras' })" 
                     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
                    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
                        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
                            <source src="/videos/standalone/2D_motion_graphics.mp4" type="video/mp4">
                        </video>
                        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
                        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
                            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col relative z-10">
                        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
                            Flat Design Moderno
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2 leading-tight">Video Operacional AMSA</h3>
                        <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">Animación 2D con diseño de storyboard a medida y elementos visuales dinámicos.</p>
                        <button class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
                            Ver Demo <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <div onclick="launchDemo('Cápsula de video del curso Transformación Digital en el Estado', 'Cápsulas de Video (IA + Boards)', 'Clase Ejecutiva UC', '2024', 'Secuencias de video con IA combinadas con boards animados. Incluye: Generación de video con IA, transiciones en motion graphics, boards de texto e íconos.', '/videos/standalone/ai_plus_boards.mp4', 'video', null, { serviceId: '8010eada-20de-45b1-b1c4-e618a94cd8f1', serviceName: 'Cápsulas de Video (IA + Boards)', demoName: 'Cápsula de video del curso Transformación Digital en el Estado' })" 
                     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
                    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
                        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
                            <source src="/videos/standalone/ai_plus_boards.mp4" type="video/mp4">
                        </video>
                        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
                        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
                            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col relative z-10">
                        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
                            Cápsula de Video IA
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2 leading-tight">Clase Ejecutiva UC</h3>
                        <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">Secuencias de video con IA combinadas de forma fluida con gráficas y textos animados.</p>
                        <button class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
                            Ver Demo <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <div onclick="launchDemo('Curso Estrategia Corporativa para Ejecutivos', 'Video con IA Ultra-Realista', 'Clase Ejecutiva UC', '2024', 'Videos en alta definición. Permite elementos de marca o adición de personajes, e incluye locución generada por IA y subtítulos opcionales.', '/videos/standalone/ai_ultrarealistic.mp4', 'video', null, { serviceId: '5e452688-9ad1-4857-ad71-11259886dbfa', serviceName: 'Video con IA Ultra-Realista', demoName: 'Curso Estrategia Corporativa para Ejecutivos' })" 
                     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
                    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
                        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
                             <source src="/videos/standalone/ai_ultrarealistic.mp4" type="video/mp4">
                        </video>
                        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
                        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
                            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
                        </div>
                    </div>
                    <div class="p-6 flex-1 flex flex-col relative z-10">
                        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
                            Alta Definición IA
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2 leading-tight">Secuencia Clase Ejecutiva</h3>
                        <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">Generación de presentadores hiperrealistas mediante Inteligencia Artificial de vanguardia.</p>
                        <button class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
                            Ver Demo <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <div onclick="launchDemo('Video de nuevas tecnologías de Glencore para inversionistas', 'Videos de Marketing de Alta Calidad', 'Glencore', '2023', 'Videos promocionales o explicativos premium. Incluye: Videos de stock en 4K de primer nivel, locutor humano profesional, licenciamiento de música y edición de alto nivel.', '/videos/standalone/premium_marketing_4K_stock.mp4', 'video', null, { serviceId: '515473fb-6e6e-434c-a4b8-c33678368c42', serviceName: 'Videos de Marketing de Alta Calidad', demoName: 'Video de nuevas tecnologías de Glencore para inversionistas' })" 
     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
            <source src="/videos/standalone/premium_marketing_4K_stock.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
        </div>
    </div>
    <div class="p-6 flex-1 flex flex-col relative z-10">
        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
            Producción Premium 4K
        </div>
        <h3 class="text-xl font-bold text-white mb-2 leading-tight">Video Promocional Glencore</h3>
        <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">Pieza audiovisual de alta gama con material de stock 4K y locución profesional.</p>
        <button class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
            Ver Demo <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>
</div>

<div onclick="launchDemo('Video de cierre del curso Líderes por primera vez', 'Video Presentador (Estudio)', 'Cencosud', '2023', 'Presentador humano profesional grabado en estudio. Incluye: Tiempo de estudio, vestuario, edición de video, corrección de color, postproducción y chroma key.', '/videos/standalone/presenter_actor.mp4', 'video', null, { serviceId: '5594e6ab-917a-487a-8a1d-dca4bf12e185', serviceName: 'Video Presentador (Estudio)', demoName: 'Video de cierre del curso Líderes por primera vez' })" 
     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
            <source src="/videos/standalone/presenter_actor.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
        </div>
    </div>
    <div class="p-6 flex-1 flex flex-col relative z-10">
        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
            Grabación en Estudio
        </div>
        <h3 class="text-xl font-bold text-white mb-2 leading-tight">Cencosud Liderazgo</h3>
        <p class="text-gray-400 text-sm mb-6 flex-1 leading-relaxed">Comunicación oficial y directa a través de un actor presentador profesional.</p>
        <button class="w-full py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-semibold group-hover:bg-rasika-accent group-hover:border-transparent group-hover:text-[#0a0b0d] transition-all duration-300 flex justify-center items-center gap-2">
            Ver Demo <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>
</div>

<div onclick="launchDemo('Líderes por primera vez', 'Video Role-Playing (Estudio)', 'Cencosud', '2024', 'Escenarios con múltiples actores grabados en estudio para demostrar habilidades blandas o procedimientos. Incluye: Hasta 2 actores, tiempo de estudio, edición y postproducción.', '/videos/standalone/roleplay_actors.mp4', 'video', null, { serviceId: '994f43f1-e367-4001-b1b8-b3433754a654', serviceName: 'Video Role-Playing (Estudio)', demoName: 'Líderes por primera vez' })" 
     class="video-card snap-start shrink-0 w-[320px] sm:w-[380px] bg-rasika-surface/95 rounded-3xl ring-1 ring-inset ring-white/10 hover:ring-white/30 shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer group flex flex-col relative overflow-hidden isolate [transform:translateZ(0)]">
    <div class="h-48 bg-[#0a0c0e] relative flex items-center justify-center rounded-t-[23px] overflow-hidden">
        <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700">
            <source src="/videos/standalone/roleplay_actors.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-rasika-surface via-transparent to-transparent pointer-events-none"></div>
        <div class="relative z-10 w-16 h-16 bg-black/40 rounded-full flex items-center justify-center group-hover:scale-110 group-hover:bg-rasika-accent/90 transition-all duration-300 border border-white/20 group-hover:border-transparent">
            <i data-lucide="play" class="w-8 h-8 text-white ml-1"></i>
        </div>
    </div>
    <div class="p-6 flex-1 flex flex-col relative z-10">
        <div class="text-[10px] font-extrabold text-rasika-accent mb-3 uppercase tracking-widest flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-rasika-accent animate-pulse"></span>
            Role-Playing Estudio
        </div>
