        const toggleBtn = document.getElementById('lang-toggle');
        let currentLang = "es";

        if(toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                currentLang = currentLang === "es" ? "en" : "es";
                document.documentElement.lang = currentLang;

                document.querySelectorAll('[data-i18n]').forEach(el => {
                    const key = el.getAttribute('data-i18n');
                    if (translations[currentLang][key]) {
                        el.innerHTML = translations[currentLang][key];
                    }
                });
                
                toggleBtn.innerText = translations[currentLang]["toggle-btn"];
            });
        }

        let activeVideoEnhanceCleanup = null;

        function initVideoEnhancePlayer(player) {
            const resultVideo = player.querySelector('[data-enhance-result]');
            const originalVideo = player.querySelector('[data-enhance-original]');
            const originalLayer = player.querySelector('[data-enhance-original-layer]');
            const range = player.querySelector('[data-enhance-range]');
            const divider = player.querySelector('[data-enhance-divider]');
            const scrubSurface = player.querySelector('[data-enhance-scrub-surface]');
            const playButton = player.querySelector('[data-enhance-play]');
            const muteButton = player.querySelector('[data-enhance-mute]');
            const fullscreenButton = player.querySelector('[data-enhance-fullscreen]');
            const startButton = player.querySelector('[data-enhance-start]');
            const loading = player.querySelector('[data-enhance-loading]');
            const status = player.querySelector('[data-enhance-status]');
            const instruction = player.querySelector('[data-enhance-instruction]');

            if (!resultVideo || !originalVideo || !originalLayer || !range || !divider) return () => {};

            let frameRequest = 0;
            let destroyed = false;
            let originalPlayPending = false;
            let pointerDragging = false;
            let touchDragging = false;
            let userInteracted = false;
            let autoSweepTimer = 0;
            let autoSweepRequest = 0;
            let resizeObserver = null;
            const usesPointerEvents = 'PointerEvent' in window;

            const updateIcons = () => {
                if (playButton) {
                    playButton.setAttribute('aria-label', resultVideo.paused ? 'Reproducir comparación' : 'Pausar comparación');
                    playButton.innerHTML = `<i data-lucide="${resultVideo.paused ? 'play' : 'pause'}" class="w-4 h-4"></i>`;
                }
                if (muteButton) {
                    muteButton.setAttribute('aria-label', resultVideo.muted ? 'Activar audio' : 'Silenciar audio');
                    muteButton.innerHTML = `<i data-lucide="${resultVideo.muted ? 'volume-x' : 'volume-2'}" class="w-4 h-4"></i>`;
                }
                if (window.lucide) lucide.createIcons();
            };

            const setComparisonPosition = (value) => {
                const position = Math.min(100, Math.max(0, Number(value) || 0));
                originalLayer.style.width = `${position}%`;
                divider.style.left = `${position}%`;
                range.value = String(position);
                range.setAttribute('aria-valuetext', `${Math.round(position)}% original, ${Math.round(100 - position)}% resultado IA`);
            };

            const sizeOriginalVideo = () => {
                const bounds = player.getBoundingClientRect();
                if (!bounds.width || !bounds.height) return;
                originalVideo.style.width = `${bounds.width}px`;
                originalVideo.style.height = `${bounds.height}px`;
            };

            const stopAutoSweep = () => {
                window.clearTimeout(autoSweepTimer);
                autoSweepTimer = 0;
                cancelAnimationFrame(autoSweepRequest);
                autoSweepRequest = 0;
            };

            const markUserInteraction = () => {
                userInteracted = true;
                stopAutoSweep();
                if (instruction) {
                    instruction.textContent = window.matchMedia?.('(max-width: 767px)').matches
                        ? 'Desliza sin mantener presionado'
                        : 'Desliza para comparar';
                }
            };

            const setPositionFromClientX = (clientX) => {
                if (!scrubSurface) return;
                const bounds = scrubSurface.getBoundingClientRect();
                if (!bounds.width) return;
                setComparisonPosition(((clientX - bounds.left) / bounds.width) * 100);
            };

            const startAutoSweep = () => {
                if (destroyed || userInteracted || autoSweepRequest) return;

                autoSweepTimer = 0;
                const startedAt = performance.now();
                if (instruction) instruction.textContent = 'Comparación automática · desliza para controlar';

                const animate = (now) => {
                    if (destroyed || userInteracted) return;
                    const phase = ((now - startedAt) % 6000) / 6000;
                    setComparisonPosition(50 + (Math.sin(phase * Math.PI * 2) * 30));
                    autoSweepRequest = requestAnimationFrame(animate);
                };

                autoSweepRequest = requestAnimationFrame(animate);
            };

            const scheduleAutoSweep = () => {
                const isMobile = window.matchMedia?.('(max-width: 767px)').matches;
                const reduceMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
                if (!isMobile || reduceMotion || userInteracted || autoSweepTimer || autoSweepRequest) return;
                autoSweepTimer = window.setTimeout(startAutoSweep, 1200);
            };

            const onPointerDown = (event) => {
                if (!scrubSurface) return;
                markUserInteraction();
                pointerDragging = true;
                setPositionFromClientX(event.clientX);
            };

            const onPointerMove = (event) => {
                if (!pointerDragging) return;
                setPositionFromClientX(event.clientX);
            };

            const onPointerEnd = () => {
                const wasDragging = pointerDragging;
                pointerDragging = false;
                if (wasDragging) alignOriginal(true);
            };

            const onTouchStart = (event) => {
                const touch = event.touches[0];
                if (!touch) return;
                markUserInteraction();
                touchDragging = true;
                setPositionFromClientX(touch.clientX);
                event.preventDefault();
            };

            const onTouchMove = (event) => {
                const touch = event.touches[0];
                if (!touchDragging || !touch) return;
                setPositionFromClientX(touch.clientX);
                event.preventDefault();
            };

            const onTouchEnd = () => {
                const wasDragging = touchDragging;
                touchDragging = false;
                if (wasDragging) alignOriginal(true);
            };

            const suppressNativeGesture = (event) => {
                event.preventDefault();
            };

            const alignOriginal = (force = false) => {
                if (originalVideo.readyState < 2 || resultVideo.readyState < 2) return;
                const offset = originalVideo.currentTime - resultVideo.currentTime;
                const drift = Math.abs(offset);

                if (force || drift > 0.25) {
                    originalVideo.currentTime = resultVideo.currentTime;
                    originalVideo.playbackRate = resultVideo.playbackRate;
                    return;
                }

                const correction = drift < 0.03
                    ? 0
                    : Math.max(-0.04, Math.min(0.04, -offset * 0.2));
                const targetRate = resultVideo.playbackRate + correction;
                if (Math.abs(originalVideo.playbackRate - targetRate) > 0.005) {
                    originalVideo.playbackRate = targetRate;
                }
            };

            const resumeOriginal = () => {
                if (
                    destroyed ||
                    resultVideo.paused ||
                    !originalVideo.paused ||
                    originalVideo.readyState < 2 ||
                    originalPlayPending
                ) return;

                originalPlayPending = true;
                originalVideo.play()
                    .catch(() => {})
                    .finally(() => {
                        originalPlayPending = false;
                    });
            };

            const monitorSync = () => {
                if (destroyed) return;
                if (!resultVideo.paused) {
                    resumeOriginal();
                    if (!pointerDragging && !touchDragging) alignOriginal();
                }
                frameRequest = requestAnimationFrame(monitorSync);
            };

            const startPlayback = async () => {
                originalVideo.muted = true;
                alignOriginal(true);
                try {
                    await Promise.all([resultVideo.play(), originalVideo.play()]);
                    alignOriginal(true);
                    startButton?.classList.add('hidden');
                    startButton?.classList.remove('flex');
                    if (status) status.textContent = 'Comparación reproduciéndose';
                } catch (error) {
                    startButton?.classList.remove('hidden');
                    startButton?.classList.add('flex');
                    if (status) status.textContent = 'Presiona reproducir para iniciar la comparación';
                }
                updateIcons();
            };

            const togglePlayback = () => {
                if (resultVideo.paused) {
                    startPlayback();
                } else {
                    resultVideo.pause();
                    originalVideo.pause();
                }
            };

            const markReady = () => {
                if (resultVideo.readyState >= 2 && originalVideo.readyState >= 2) {
                    loading?.classList.add('hidden');
                    alignOriginal(true);
                    scheduleAutoSweep();
                }
            };

            range.addEventListener('input', () => {
                markUserInteraction();
                setComparisonPosition(range.value);
            });
            if (scrubSurface) {
                if (usesPointerEvents) {
                    scrubSurface.addEventListener('pointerdown', onPointerDown);
                    window.addEventListener('pointermove', onPointerMove);
                    window.addEventListener('pointerup', onPointerEnd);
                    window.addEventListener('pointercancel', onPointerEnd);
                } else {
                    scrubSurface.addEventListener('touchstart', onTouchStart, { passive: false });
                    window.addEventListener('touchmove', onTouchMove, { passive: false });
                    window.addEventListener('touchend', onTouchEnd);
                    window.addEventListener('touchcancel', onTouchEnd);
                }
            }
            player.addEventListener('contextmenu', suppressNativeGesture);
            player.addEventListener('dragstart', suppressNativeGesture);
            player.addEventListener('selectstart', suppressNativeGesture);
            player.addEventListener('gesturestart', suppressNativeGesture, { passive: false });
            playButton?.addEventListener('click', togglePlayback);
            startButton?.addEventListener('click', startPlayback);
            muteButton?.addEventListener('click', () => {
                resultVideo.muted = !resultVideo.muted;
                updateIcons();
            });
            fullscreenButton?.addEventListener('click', () => {
                if (player.requestFullscreen) player.requestFullscreen();
            });
            resultVideo.addEventListener('play', () => {
                alignOriginal(true);
                resumeOriginal();
                startButton?.classList.add('hidden');
                startButton?.classList.remove('flex');
                updateIcons();
            });
            resultVideo.addEventListener('pause', () => {
                originalVideo.pause();
                originalVideo.playbackRate = resultVideo.playbackRate;
                updateIcons();
            });
            resultVideo.addEventListener('seeking', () => alignOriginal(true));
            resultVideo.addEventListener('seeked', () => alignOriginal(true));
            resultVideo.addEventListener('ratechange', () => alignOriginal(true));
            resultVideo.addEventListener('volumechange', updateIcons);
            resultVideo.addEventListener('loadeddata', markReady);
            resultVideo.addEventListener('canplay', markReady);
            originalVideo.addEventListener('loadeddata', markReady);
            originalVideo.addEventListener('canplay', markReady);

            sizeOriginalVideo();
            if ('ResizeObserver' in window) {
                resizeObserver = new ResizeObserver(sizeOriginalVideo);
                resizeObserver.observe(player);
            }
            window.addEventListener('resize', sizeOriginalVideo);
            setComparisonPosition(range.value || 50);
            resultVideo.muted = true;
            originalVideo.muted = true;
            resultVideo.load();
            originalVideo.load();
            updateIcons();
            monitorSync();
            scheduleAutoSweep();
            startPlayback();

            return () => {
                destroyed = true;
                stopAutoSweep();
                cancelAnimationFrame(frameRequest);
                if (usesPointerEvents) {
                    window.removeEventListener('pointermove', onPointerMove);
                    window.removeEventListener('pointerup', onPointerEnd);
                    window.removeEventListener('pointercancel', onPointerEnd);
                } else {
                    window.removeEventListener('touchmove', onTouchMove);
                    window.removeEventListener('touchend', onTouchEnd);
                    window.removeEventListener('touchcancel', onTouchEnd);
                }
                player.removeEventListener('contextmenu', suppressNativeGesture);
                player.removeEventListener('dragstart', suppressNativeGesture);
                player.removeEventListener('selectstart', suppressNativeGesture);
                player.removeEventListener('gesturestart', suppressNativeGesture);
                resizeObserver?.disconnect();
                window.removeEventListener('resize', sizeOriginalVideo);
                resultVideo.pause();
                originalVideo.pause();
            };
        }

        // --- THE UPGRADED CINEMATIC ROUTER ---
        window.launchDemo = function(courseName, formatType, client, year, description, source, mediaType = 'video', customWidth = null, serviceMeta = null) {
            window.mentorSuppressAutoOpen = mediaType === 'video_enhance';

            // Canonical service context for CourseMentor. Prefer real services.id over UI/display labels.
            if (customWidth && typeof customWidth === 'object' && !serviceMeta) {
                serviceMeta = customWidth;
                customWidth = null;
            }

            const modal = document.getElementById('demo-modal');
            const playerArea = document.getElementById('player-container');
            const titleEl = document.getElementById('demo-title');
            const categoryEl = document.getElementById('demo-category');
            
            if (titleEl) titleEl.innerText = courseName;
            if (categoryEl) categoryEl.innerText = formatType;
            
            let contentHtml = '';

            if (activeVideoEnhanceCleanup) {
                activeVideoEnhanceCleanup();
                activeVideoEnhanceCleanup = null;
            }

            // Inject video, comparison player or iframe into the floating container.
            if (mediaType === 'video') {
                contentHtml = `<video src="${source}" controls autoplay playsinline class="w-full h-full object-cover"></video>`;
            } else if (mediaType === 'video_enhance') {
                const comparisonSource = serviceMeta?.comparisonSourceUrl || '';
                contentHtml = `
                    <div data-video-enhance-player class="relative w-full h-full overflow-hidden bg-black select-none">
                        <video data-enhance-result src="${source}" poster="/images/demos/video-enhance-ia.jpg" preload="auto" loop muted playsinline webkit-playsinline draggable="false" class="absolute inset-0 w-full h-full object-cover"></video>
                        <div data-enhance-original-layer class="absolute inset-y-0 left-0 overflow-hidden" style="width: 50%; contain: paint; will-change: width;">
                            <video data-enhance-original src="${comparisonSource}" preload="auto" loop muted playsinline webkit-playsinline draggable="false" class="absolute left-0 top-0 max-w-none object-cover"></video>
                        </div>

                        <div class="absolute inset-x-0 top-0 z-30 flex justify-between p-4 pointer-events-none text-[10px] sm:text-xs font-extrabold uppercase tracking-widest">
                            <span class="px-3 py-1.5 rounded-md bg-black/60 backdrop-blur-md text-white">Original</span>
                            <span class="px-3 py-1.5 rounded-md bg-black/60 backdrop-blur-md text-rasika-accent">Resultado IA</span>
                        </div>

                        <div data-enhance-scrub-surface class="video-enhance-scrub-surface absolute inset-x-0 top-0 bottom-14 z-40" aria-hidden="true"></div>
                        <input data-enhance-range type="range" min="0" max="100" value="50" step="0.1" class="video-enhance-range sr-only" aria-label="Comparar video original y resultado IA" />
                        <div data-enhance-divider class="absolute inset-y-0 left-1/2 z-30 w-px bg-white shadow-[0_0_14px_rgba(0,0,0,0.8)] pointer-events-none">
                            <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-[#141619]/90 border border-white/70 shadow-xl flex items-center justify-center text-white">
                                <i data-lucide="chevrons-left-right" class="w-6 h-6"></i>
                            </span>
                        </div>

                        <div data-enhance-loading class="absolute inset-0 z-20 flex items-center justify-center bg-black/30 pointer-events-none">
                            <i data-lucide="loader-circle" class="w-9 h-9 text-rasika-accent animate-spin"></i>
                        </div>
                        <button data-enhance-start type="button" class="hidden absolute inset-0 z-[60] m-auto w-16 h-16 rounded-full bg-rasika-accent text-[#0a0b0d] shadow-2xl items-center justify-center" aria-label="Reproducir comparación">
                            <i data-lucide="play" class="w-7 h-7 ml-1"></i>
                        </button>

                        <div class="absolute inset-x-0 bottom-0 z-50 h-14 px-4 flex items-center gap-2 bg-gradient-to-t from-black/90 to-transparent">
                            <button data-enhance-play type="button" class="w-9 h-9 rounded-full bg-black/50 hover:bg-white/15 border border-white/10 text-white flex items-center justify-center transition-colors" aria-label="Pausar comparación"></button>
                            <button data-enhance-mute type="button" class="w-9 h-9 rounded-full bg-black/50 hover:bg-white/15 border border-white/10 text-white flex items-center justify-center transition-colors" aria-label="Silenciar audio"></button>
                            <span data-enhance-status class="sr-only" aria-live="polite">Cargando comparación</span>
                            <span data-enhance-instruction class="flex-1 text-center text-[10px] sm:text-xs text-white/70 font-semibold">Desliza para comparar</span>
                            <button data-enhance-fullscreen type="button" class="w-9 h-9 rounded-full bg-black/50 hover:bg-white/15 border border-white/10 text-white flex items-center justify-center transition-colors" aria-label="Ver en pantalla completa">
                                <i data-lucide="maximize" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>`;
            } else if (mediaType === 'interactive') {
                // Background white ensures transparent SCORM backgrounds look correct.
                contentHtml = `<iframe src="${source}" class="w-full h-full border-0 bg-white" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
            }

            // SMART SIZING: Use exact dimensions if requested, otherwise default to massive 16:9
            let containerStyle = customWidth 
                ? `max-width: ${customWidth}; aspect-ratio: 1024/627;` 
                : `max-width: calc(75vh * 16 / 9); aspect-ratio: 16/9;`;

            // Removed 'aspect-video' from Tailwind classes to allow the dynamic aspect-ratio to override it
            playerArea.innerHTML = `
                <div class="w-full max-h-[75vh] lg:max-h-[85vh] rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 bg-[#0f1114] shadow-2xl flex items-center justify-center relative transition-all duration-500" style="${containerStyle}">
                    ${contentHtml}
                </div>
            `;

            if (mediaType === 'video_enhance') {
                // Keep the comparison usable on small screens while preserving the chat history and context.
                const collapseMentor = () => {
                    const mentorWindow = document.getElementById('mentor-window');
                    const mentorCloseButton = document.getElementById('mentor-close-btn');
                    if (mentorWindow && mentorWindow.style.display !== 'none' && mentorCloseButton) {
                        mentorCloseButton.click();
                    }
                };
                collapseMentor();
                setTimeout(collapseMentor, 250);
            }
            if (window.lucide) lucide.createIcons();

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            requestAnimationFrame(() => {
                modal.classList.remove('opacity-0');
                if (mediaType === 'video_enhance') {
                    const comparisonPlayer = playerArea.querySelector('[data-video-enhance-player]');
                    if (comparisonPlayer) activeVideoEnhanceCleanup = initVideoEnhancePlayer(comparisonPlayer);
                }
            });
            
            // Sync with Chatbot using canonical service data. Do not pass mockup/display labels.
            if (window.setMentorCourse && serviceMeta && serviceMeta.serviceId) {
                window.setMentorCourse({
                    serviceId: serviceMeta.serviceId,
                    serviceContentId: serviceMeta.serviceContentId || null,
                    demoSlug: serviceMeta.demoSlug || null,
                    label: serviceMeta.serviceName || formatType || courseName,
                    serviceName: serviceMeta.serviceName || formatType || courseName,
                    demoName: serviceMeta.demoName || courseName
                });
            } else if (window.setMentorCourse) {
                window.setMentorCourse(courseName);
            } else {
                window.mentorActiveCourse = courseName;
            }
            if (mediaType !== 'video_enhance') {
                setTimeout(() => {
                    const fab = document.getElementById('mentor-fab');
                    const chatWindow = document.getElementById('mentor-window');
                    if (chatWindow && chatWindow.style.display === 'none' && fab) {
                        fab.click();
                    }
                }, 10000);
            }
        }

        window.closeDemo = function() {
            window.mentorSuppressAutoOpen = false;

            const modal = document.getElementById('demo-modal');

            if (activeVideoEnhanceCleanup) {
                activeVideoEnhanceCleanup();
                activeVideoEnhanceCleanup = null;
            }
            
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                
                // Reset the container to the loader state to stop audio/video/iframes playing in background
                const playerArea = document.getElementById('player-container');
                if(playerArea) {
                    playerArea.innerHTML = `
                        <div class="w-full aspect-video max-h-[65vh] rounded-3xl overflow-hidden ring-1 ring-inset ring-white/10 bg-[#0f1114] flex flex-col items-center justify-center text-gray-500 shadow-2xl" style="max-width: calc(65vh * 16 / 9);">
                            <i data-lucide="loader-2" class="w-12 h-12 animate-spin mb-4 text-rasika-accent"></i>
                            <p class="text-sm font-medium tracking-wide">Cerrando recurso...</p>
                        </div>
                    `;
                }
                if (window.lucide) lucide.createIcons();
            }, 300);
            
            if (window.setMentorCourse) {
                window.setMentorCourse("Catálogo General");
            } else {
                window.mentorActiveCourse = "Catálogo General";
            }
        }
    </script>
    
    <SiteAnalytics />
    <Chatbot />
