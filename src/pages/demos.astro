    </div>

    <!-- Hero Section -->
    <header class="pt-36 pb-16 relative z-10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-rasika-accent/10 border border-rasika-accent/20 text-rasika-accent text-xs font-bold mb-6">
