---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.videoEnhance;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',
                            dark: '#141619',
                            surface: '#1E2226',
                        }
                    }
                }
            }
        }
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <style>
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }
        summary::-webkit-details-marker { display: none; }
    </style>
</head>
<body class="tech-bg bg-rasika-dark text-gray-200 font-sans min-h-screen overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">
    <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/90 backdrop-blur-xl z-50 shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
            <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
                <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones" class="w-full h-auto" />
            </a>

            <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300" aria-label="Navegación principal">
                <a href="/demos" class="hover:text-rasika-accent transition-colors">Demos</a>
                <a href="/lms" class="hover:text-rasika-accent transition-colors">LMS & Bots</a>
                <a href="/clients" class="hover:text-rasika-accent transition-colors">Clientes</a>
                <a href="/pricing" class="hover:text-rasika-accent transition-colors">Precios</a>
                <a href="/blog" class="hover:text-rasika-accent transition-colors">Blog</a>
            </nav>

            <button id="mobile-menu-btn" type="button" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors" aria-label="Abrir menú" aria-expanded="false">
                <i data-lucide="menu" class="w-7 h-7"></i>
            </button>
        </div>

        <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden" aria-label="Navegación móvil">
            <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3">Demos</a>
            <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3">LMS & Bots</a>
            <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3">Clientes</a>
            <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3">Precios</a>
            <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3">Blog</a>
        </nav>
    </header>

    <button id="mentor-page-cta" type="button" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce group" aria-label="Conversar con CourseMentor">
        <span class="w-12 h-12 sm:w-auto sm:h-auto bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold sm:px-5 sm:py-3 rounded-full sm:rounded-lg shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-colors flex items-center justify-center gap-2">
            <span class="hidden sm:inline">Conversemos sobre tu escena</span> <i data-lucide="message-circle" class="w-5 h-5 sm:w-4 sm:h-4"></i>
        </span>
    </button>

    <main>
        <section class="relative min-h-[78svh] flex items-end overflow-hidden" aria-labelledby="page-title">
            <img src="/images/demos/video-enhance-ia.jpg" alt="Actores reales integrados en una oficina generada con inteligencia artificial" class="absolute inset-0 w-full h-full object-cover object-center" />
            <div class="absolute inset-0 bg-black/65"></div>

            <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pt-32 pb-16 md:pb-20">
                <div class="max-w-4xl">
                    <div class="inline-flex items-center gap-2 text-rasika-accent text-xs md:text-sm font-bold uppercase mb-5">
                        <i data-lucide="map-pin" class="w-4 h-4"></i>
                        Servicio audiovisual · Santiago de Chile
                    </div>
                    <h1 id="page-title" class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-white leading-[1.08] mb-6">
                        Chroma Key con IA generativa en Chile
                    </h1>
                    <p class="text-xl md:text-2xl text-white font-semibold leading-relaxed max-w-3xl mb-5">
                        Nos quedamos con lo mejor de dos mundos.
                    </p>
                    <p class="text-base md:text-lg text-gray-200 leading-relaxed max-w-3xl mb-8">
                        Actores reales aportan interpretación, naturalidad y emoción, mientras la IA generativa crea locaciones, vestuario y extras que antes exigían nuevos rodajes. El resultado: escenas más ambiciosas, mayor libertad creativa y una fracción del costo de una producción equivalente.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3">
                        <a href="/demos/?demo=video-enhance-ia" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-rasika-accent text-[#0a0b0d] font-bold rounded-lg hover:bg-[#88d6e0] transition-colors">
                            <i data-lucide="scan-line" class="w-5 h-5"></i>
                            Comparar original y resultado
                        </a>
                        <a href="/pricing/#video-enhance" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-black/35 text-white border border-white/30 font-bold rounded-lg hover:bg-white/10 transition-colors">
                            <i data-lucide="calculator" class="w-5 h-5"></i>
                            Ver precios por minuto
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="border-y border-white/10 bg-[#101215]" aria-labelledby="hybrid-title">
            <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
                <div class="max-w-3xl mb-12">
                    <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Producción híbrida controlada</p>
                    <h2 id="hybrid-title" class="text-3xl md:text-5xl font-extrabold text-white mb-5">La actuación permanece. El mundo alrededor puede cambiar.</h2>
                    <p class="text-gray-400 text-lg leading-relaxed">Rasika combina rodaje profesional con postproducción asistida por IA. Conservamos la interpretación aprobada y expandimos el contexto visual sin depender de avatares ni repetir cada locación o cambio de vestuario.</p>
                </div>

                <div class="grid md:grid-cols-3 border-t border-white/10">
                    <div class="py-8 md:pr-8 md:border-r border-white/10">
                        <i data-lucide="users" class="w-7 h-7 text-rasika-accent mb-5"></i>
                        <h3 class="text-xl font-bold text-white mb-3">Talento humano</h3>
                        <p class="text-gray-400 leading-relaxed">Actores reales sostienen la intención, el ritmo, la interacción y la credibilidad de cada escena.</p>
                    </div>
                    <div class="py-8 md:px-8 md:border-r border-white/10">
                        <i data-lucide="sparkles" class="w-7 h-7 text-rasika-accent mb-5"></i>
                        <h3 class="text-xl font-bold text-white mb-3">Expansión generativa</h3>
                        <p class="text-gray-400 leading-relaxed">Creamos locaciones, vestuario, EPP, iluminación y extras coherentes con el propósito de la producción.</p>
                    </div>
                    <div class="py-8 md:pl-8">
                        <i data-lucide="layers-3" class="w-7 h-7 text-rasika-accent mb-5"></i>
                        <h3 class="text-xl font-bold text-white mb-3">Integración profesional</h3>
                        <p class="text-gray-400 leading-relaxed">Componemos, corregimos color y revisamos continuidad para que la escena final funcione como una sola pieza.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-6 py-20 md:py-28" aria-labelledby="proof-title">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
                <div class="max-w-3xl">
                    <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Prueba real</p>
                    <h2 id="proof-title" class="text-3xl md:text-5xl font-extrabold text-white mb-4">La misma actuación. Dos realidades visuales.</h2>
                    <p class="text-gray-400 text-lg leading-relaxed">Nuestra comparación utiliza la grabación original con chroma y el resultado postproducido. Desliza para examinar la integración, la nueva locación y los cambios de vestuario.</p>
                </div>
                <a href="/demos/?demo=video-enhance-ia" class="inline-flex items-center gap-2 text-rasika-accent font-bold hover:text-white transition-colors shrink-0">
                    Abrir comparación <i data-lucide="arrow-up-right" class="w-5 h-5"></i>
                </a>
            </div>

            <a href="/demos/?demo=video-enhance-ia" class="group block relative aspect-video overflow-hidden rounded-lg border border-white/10 bg-black" aria-label="Abrir demo comparativa de Chroma Key con IA Generativa">
                <img src="/images/demos/video-enhance-ia.jpg" alt="Resultado de Chroma Key con locación y vestuario generados por IA" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
                <div class="absolute inset-0 bg-black/25 group-hover:bg-black/10 transition-colors"></div>
                <span class="absolute inset-0 flex items-center justify-center">
                    <span class="w-16 h-16 rounded-full bg-[#141619]/90 border border-white/60 flex items-center justify-center text-white group-hover:bg-rasika-accent group-hover:text-[#0a0b0d] group-hover:border-transparent transition-colors">
                        <i data-lucide="chevrons-left-right" class="w-8 h-8"></i>
                    </span>
                </span>
            </a>
        </section>

        <section class="bg-[#1A1D21] border-y border-white/10" aria-labelledby="process-title">
            <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
                <div class="max-w-3xl mb-14">
                    <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Cómo trabajamos</p>
                    <h2 id="process-title" class="text-3xl md:text-5xl font-extrabold text-white mb-5">Un pipeline donde cada decisión sigue bajo control.</h2>
                    <p class="text-gray-400 text-lg leading-relaxed">La IA amplía las posibilidades; la dirección humana define qué se conserva, qué cambia y qué versión está lista para publicar.</p>
                </div>

                <ol class="grid sm:grid-cols-2 lg:grid-cols-5 border-t border-white/10">
                    <li class="py-7 lg:pr-6 lg:border-r border-white/10">
                        <span class="text-rasika-accent font-bold text-sm">01</span>
                        <h3 class="text-white font-bold mt-3 mb-2">Evaluación</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Revisamos resolución, iluminación, movimiento, encuadre y duración.</p>
                    </li>
                    <li class="py-7 lg:px-6 lg:border-r border-white/10">
                        <span class="text-rasika-accent font-bold text-sm">02</span>
                        <h3 class="text-white font-bold mt-3 mb-2">Dirección visual</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Definimos locaciones, vestuario, EPP, extras y referencias de estilo.</p>
                    </li>
                    <li class="py-7 lg:px-6 lg:border-r border-white/10">
                        <span class="text-rasika-accent font-bold text-sm">03</span>
                        <h3 class="text-white font-bold mt-3 mb-2">Extracción</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Limpiamos el chroma y preparamos a los actores para la nueva composición.</p>
                    </li>
                    <li class="py-7 lg:px-6 lg:border-r border-white/10">
                        <span class="text-rasika-accent font-bold text-sm">04</span>
                        <h3 class="text-white font-bold mt-3 mb-2">Generación</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Producimos los elementos visuales acordados y ajustamos su continuidad.</p>
                    </li>
                    <li class="py-7 lg:pl-6">
                        <span class="text-rasika-accent font-bold text-sm">05</span>
                        <h3 class="text-white font-bold mt-3 mb-2">Integración y QA</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">Componemos, corregimos color, revisamos y entregamos el máster aprobado.</p>
                    </li>
                </ol>
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-6 py-20 md:py-28" aria-labelledby="uses-title">
            <div class="max-w-3xl mb-12">
                <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Aplicaciones corporativas</p>
                <h2 id="uses-title" class="text-3xl md:text-5xl font-extrabold text-white mb-5">Una grabación puede abrir muchos escenarios.</h2>
                <p class="text-gray-400 text-lg leading-relaxed">El formato funciona especialmente bien cuando una empresa necesita representar contextos difíciles, costosos o repetitivos sin perder la presencia de actores reales.</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
                <article class="border border-white/10 bg-white/[0.03] rounded-lg p-6">
                    <i data-lucide="graduation-cap" class="w-7 h-7 text-rasika-accent mb-5"></i>
                    <h3 class="text-lg font-bold text-white mb-3">Capacitación</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Role-playing, liderazgo, servicio al cliente y conversaciones difíciles.</p>
                </article>
                <article class="border border-white/10 bg-white/[0.03] rounded-lg p-6">
                    <i data-lucide="hard-hat" class="w-7 h-7 text-rasika-accent mb-5"></i>
                    <h3 class="text-lg font-bold text-white mb-3">Seguridad y EPP</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Procedimientos, ambientes industriales y contextos de prevención de riesgos.</p>
                </article>
                <article class="border border-white/10 bg-white/[0.03] rounded-lg p-6">
                    <i data-lucide="building-2" class="w-7 h-7 text-rasika-accent mb-5"></i>
                    <h3 class="text-lg font-bold text-white mb-3">Comunicación corporativa</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Mensajes ejecutivos, inducciones y piezas internas adaptadas a distintos entornos.</p>
                </article>
                <article class="border border-white/10 bg-white/[0.03] rounded-lg p-6">
                    <i data-lucide="languages" class="w-7 h-7 text-rasika-accent mb-5"></i>
                    <h3 class="text-lg font-bold text-white mb-3">Versiones visuales</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Variantes por país, unidad de negocio, audiencia o campaña desde una base común.</p>
                </article>
            </div>
        </section>

        <section class="border-y border-white/10 bg-[#101215]" aria-labelledby="scope-title">
            <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
                <div class="max-w-3xl mb-12">
                    <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Alcance base</p>
                    <h2 id="scope-title" class="text-3xl md:text-5xl font-extrabold text-white mb-5">Qué contempla el servicio.</h2>
                    <p class="text-gray-400 text-lg leading-relaxed">El material y el movimiento determinan la viabilidad final. Antes de producir, revisamos el archivo y dejamos por escrito el alcance aprobado.</p>
                </div>

                <div class="grid md:grid-cols-2 border-t border-white/10">
                    <div class="py-8 md:pr-12 md:border-r border-white/10">
                        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3"><i data-lucide="check-circle-2" class="w-6 h-6 text-rasika-accent"></i> Incluye</h3>
                        <ul class="space-y-4 text-gray-300">
                            <li>Hasta dos fondos realistas generados con IA.</li>
                            <li>Hasta dos sets de vestuario o EPP.</li>
                            <li>Composición, integración visual y corrección de color.</li>
                            <li>Revisión técnica del material grabado con chroma.</li>
                        </ul>
                    </div>
                    <div class="py-8 md:pl-12">
                        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3"><i data-lucide="circle-slash-2" class="w-6 h-6 text-gray-500"></i> Excluye</h3>
                        <ul class="space-y-4 text-gray-400">
                            <li>Cambios de personajes o de la actuación aprobada.</li>
                            <li>Cambios de guion, idioma, edición o audio.</li>
                            <li>Efectos especiales fuera del alcance base.</li>
                            <li>Material que no supere la evaluación técnica inicial.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-5xl mx-auto px-6 py-20 md:py-28" aria-labelledby="faq-title">
            <div class="max-w-3xl mb-10">
                <p class="text-rasika-accent text-xs font-bold uppercase mb-3">Preguntas frecuentes</p>
                <h2 id="faq-title" class="text-3xl md:text-5xl font-extrabold text-white">Antes de transformar la escena.</h2>
            </div>

            <div class="border-t border-white/10">
                <details class="group border-b border-white/10 py-6">
                    <summary class="cursor-pointer flex items-center justify-between gap-6 text-white font-bold text-lg">
                        ¿Pueden trabajar con un video ya grabado?
                        <i data-lucide="plus" class="w-5 h-5 text-rasika-accent shrink-0 group-open:rotate-45 transition-transform"></i>
                    </summary>
                    <p class="text-gray-400 leading-relaxed mt-4 max-w-3xl">Sí. Evaluamos el material grabado con chroma key, su resolución, iluminación, encuadre y duración antes de definir el alcance de postproducción.</p>
                </details>
                <details class="group border-b border-white/10 py-6">
                    <summary class="cursor-pointer flex items-center justify-between gap-6 text-white font-bold text-lg">
                        ¿Se puede cambiar el vestuario o el EPP?
                        <i data-lucide="plus" class="w-5 h-5 text-rasika-accent shrink-0 group-open:rotate-45 transition-transform"></i>
                    </summary>
                    <p class="text-gray-400 leading-relaxed mt-4 max-w-3xl">Sí. El servicio base contempla hasta dos sets de vestuario o elementos de protección personal, sujetos a evaluación técnica del movimiento y la toma.</p>
                </details>
                <details class="group border-b border-white/10 py-6">
                    <summary class="cursor-pointer flex items-center justify-between gap-6 text-white font-bold text-lg">
                        ¿Se conserva la actuación y el audio original?
                        <i data-lucide="plus" class="w-5 h-5 text-rasika-accent shrink-0 group-open:rotate-45 transition-transform"></i>
                    </summary>
                    <p class="text-gray-400 leading-relaxed mt-4 max-w-3xl">Sí. Conservamos a los actores, su interpretación, el guion, el idioma, la edición y el audio aprobados, salvo que se cotice un alcance adicional.</p>
                </details>
                <details class="group border-b border-white/10 py-6">
                    <summary class="cursor-pointer flex items-center justify-between gap-6 text-white font-bold text-lg">
                        ¿Cuánto cuesta el Chroma Key con IA generativa?
                        <i data-lucide="plus" class="w-5 h-5 text-rasika-accent shrink-0 group-open:rotate-45 transition-transform"></i>
                    </summary>
                    <p class="text-gray-400 leading-relaxed mt-4 max-w-3xl">La tarifa es de 8 UF por minuto para 1 a 5 minutos terminados, 6 UF por minuto para más de 5 y hasta 10 minutos, y 5 UF por minuto para más de 10 y hasta 20 minutos. Revisa la <a href="/pricing/#video-enhance" class="text-rasika-accent hover:text-white">tabla de precios</a>.</p>
                </details>
                <details class="group border-b border-white/10 py-6">
                    <summary class="cursor-pointer flex items-center justify-between gap-6 text-white font-bold text-lg">
                        ¿Trabajan con empresas fuera de Santiago?
                        <i data-lucide="plus" class="w-5 h-5 text-rasika-accent shrink-0 group-open:rotate-45 transition-transform"></i>
                    </summary>
                    <p class="text-gray-400 leading-relaxed mt-4 max-w-3xl">Sí. Rasika opera desde Santiago de Chile y puede recibir material aprobado para postproducción desde otras regiones de Chile y Latinoamérica.</p>
                </details>
            </div>
        </section>

        <section class="border-t border-white/10 bg-rasika-accent text-[#0a0b0d]">
            <div class="max-w-7xl mx-auto px-6 py-16 md:py-20 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
                <div class="max-w-3xl">
                    <p class="text-xs font-extrabold uppercase mb-3">Tu próxima escena puede empezar en el estudio</p>
                    <h2 class="text-3xl md:text-5xl font-extrabold mb-4">Cuéntanos qué mundo necesitas construir.</h2>
                    <p class="text-lg font-semibold opacity-80 leading-relaxed">Revisamos el material, identificamos oportunidades de producción y preparamos una estimación basada en la duración total.</p>
                </div>
                <a href="/#contacto" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-[#141619] text-white font-bold rounded-lg hover:bg-black transition-colors shrink-0">
                    Cotizar proyecto <i data-lucide="arrow-right" class="w-5 h-5"></i>
                </a>
            </div>
        </section>
    </main>

    <footer class="bg-rasika-dark border-t border-white/5">
        <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 font-medium">
            <p>© 2026 Rasika Producciones. Todos los derechos reservados.</p>
            <div class="flex gap-6">
                <a href="/demos" class="hover:text-rasika-accent transition-colors">Demos</a>
                <a href="/pricing" class="hover:text-rasika-accent transition-colors">Precios</a>
                <a href="/blog" class="hover:text-rasika-accent transition-colors">Blog</a>
            </div>
        </div>
    </footer>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) window.lucide.createIcons();

            const mobileBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileBtn && mobileMenu) {
                mobileBtn.addEventListener('click', () => {
                    const isOpen = mobileMenu.classList.toggle('flex');
                    mobileMenu.classList.toggle('hidden', !isOpen);
                    mobileBtn.setAttribute('aria-expanded', String(isOpen));
                    const icon = mobileBtn.querySelector('i');
                    if (icon) icon.setAttribute('data-lucide', isOpen ? 'x' : 'menu');
                    if (window.lucide) window.lucide.createIcons();
                });
            }

            window.setMentorCourse?.('Chroma Key con IA Generativa');

            const mentorCta = document.getElementById('mentor-page-cta');
            mentorCta?.addEventListener('click', () => {
