---
// src/pages/lms.astro
import '../styles/global.css'; 
import Chatbot from '../components/Chatbot.astro';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const seo = seoPages.lms;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        rasika: {
                            accent: '#5EA6B0',    
                            dark: '#141619',      
                            surface: '#1E2226',   
                        }
                    }
                }
            }
        }
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Floating CTA Animation */
        @keyframes float-bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float-bounce { animation: float-bounce 2s infinite ease-in-out; }
        
        /* Bottom Scroll Glow Class */
        .cta-glow-active .tooltip-bubble {
            box-shadow: 0 0 40px rgba(94,166,176,0.6) !important;
            background-color: #88d6e0 !important;
        }
        .cta-glow-active .tooltip-tail {
            background-color: #88d6e0 !important;
        }

        /* Message Glow */
        @keyframes msg-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(94, 166, 176, 0.05); transform: translateY(0); }
            50% { box-shadow: 0 0 20px rgba(94, 166, 176, 0.15); transform: translateY(-4px); }
        }
        .animate-msg-glow { animation: msg-glow 3s infinite ease-in-out; }
        
        /* Article Typography styling */
        .prose p { margin-bottom: 1.5em; line-height: 1.8; color: #9ca3af; }
        .prose strong { color: #fff; font-weight: 600; }
    </style>
</head>
<body class="tech-bg text-gray-200 font-sans min-h-screen relative overflow-x-hidden selection:bg-rasika-accent selection:text-[#0a0b0d]">

    <!-- VIDEO BACKGROUND (Opacity reduced to 30% for readability) -->
    <div class="fixed inset-0 z-[-1] w-full h-full bg-rasika-dark">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-30 mix-blend-screen filter saturate-150 contrast-150">
            <source src="/videos/backgrounds/animated_bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-rasika-dark/95 via-rasika-dark/60 to-transparent pointer-events-none"></div>
    </div>

    <!-- FIXED TOP NAVIGATION -->
   <header class="fixed top-0 left-0 w-full border-b border-white/5 bg-[#141619]/80 backdrop-blur-xl z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="block w-32 sm:w-40 transition-transform hover:scale-105">
            <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones Logo" class="w-full h-auto" />
        </a>
        
        <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold text-gray-300">
            <a href="/demos" class="hover:text-rasika-accent transition-colors" data-i18n="nav-demos">Demos</a>
            <a href="/lms" class="hover:text-rasika-accent transition-colors" data-i18n="nav-lms">LMS & Bots</a>
            <a href="/clients" class="hover:text-rasika-accent transition-colors" data-i18n="nav-clients">Clientes</a>
            <a href="/pricing" class="hover:text-rasika-accent transition-colors" data-i18n="nav-pricing">Precios</a>
            <a href="/blog" class="hover:text-rasika-accent transition-colors" data-i18n="nav-blog">Blog</a>
            <button id="lang-toggle" class="border border-white/20 rounded-full px-4 py-1.5 hover:bg-white/10 transition-colors" data-i18n="toggle-btn">EN</button>
        </nav>

        <button id="mobile-menu-btn" class="block lg:hidden p-2 text-gray-300 hover:text-white transition-colors">
            <i data-lucide="menu" class="w-7 h-7"></i>
        </button>
    </div>

    <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#141619]/95 backdrop-blur-2xl border-b border-white/10 flex-col px-8 py-6 gap-6 shadow-2xl lg:hidden">
        <a href="/demos" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-demos">Demos</a>
        <a href="/lms" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-lms">LMS & Bots</a>
        <a href="/clients" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-clients">Clientes</a>
        <a href="/pricing" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-pricing">Precios</a>
        <a href="/blog" class="text-lg font-bold text-gray-200 hover:text-rasika-accent transition-colors border-b border-white/5 pb-3" data-i18n="nav-blog">Blog</a>
    </nav>
</header>

    <!-- FLOATING CTA -->
    <div id="mentor-cta-tooltip" class="fixed bottom-28 right-6 z-[90] flex flex-col items-end animate-float-bounce cursor-pointer group transition-all duration-300" onclick="openMentorWithMessage()">
        <div class="tooltip-bubble bg-rasika-accent group-hover:bg-[#88d6e0] text-[#0a0b0d] text-sm font-extrabold px-5 py-3 rounded-2xl rounded-br-sm shadow-[0_0_30px_rgba(94,166,176,0.4)] transition-all duration-300 flex items-center gap-2">
            <span data-i18n="cta-bubble">¡Pruébame!</span> <i data-lucide="sparkles" class="w-4 h-4"></i>
        </div>
        <div class="tooltip-tail w-4 h-4 bg-rasika-accent group-hover:bg-[#88d6e0] transform rotate-45 mr-4 -mt-2 transition-colors duration-300"></div>
    </div>

    <!-- HERO HEADER -->
    <section class="pt-36 pb-12 px-6 relative text-center">
        <div class="max-w-4xl mx-auto">
            <div class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-rasika-accent uppercase bg-rasika-accent/10 rounded-full border border-rasika-accent/20">
                Ecosistemas Inteligentes
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-white" data-i18n="lms-title">
                Un nuevo paradigma <br class="hidden sm:block"/> 
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-rasika-accent to-[#a0e5ee]">LMS & IA Conversacional</span>
            </h1>
            <p class="text-lg text-gray-400 font-medium leading-relaxed max-w-2xl mx-auto" data-i18n="lms-desc">
                Descubre cómo transformamos repositorios estáticos en plataformas dinámicas mediante la integración profunda de tutores virtuales y telemetría avanzada.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-24 relative z-10 space-y-32">

        <!-- SECTION 1: EDUCATIONAL BLOG (The "Why") -->
        <div class="space-y-24">
            
            <!-- Block A: The LMS limitation -->
            <section class="flex flex-col lg:flex-row gap-16 items-center">
                <!-- Visual Left -->
                <div class="w-full lg:w-5/12">
                    <div class="aspect-square rounded-[3rem] bg-gradient-to-br from-[#1E2226] to-[#141619] ring-1 ring-inset ring-white/10 shadow-2xl p-10 flex flex-col items-center justify-center text-center relative overflow-hidden isolate">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50 z-0"></div>
                        <div class="relative z-10 w-full">
                            <div class="w-24 h-24 bg-rasika-accent/10 border border-rasika-accent/20 rounded-2xl flex items-center justify-center mx-auto mb-8 shadow-[0_0_40px_rgba(94,166,176,0.2)]">
                                <i data-lucide="network" class="w-12 h-12 text-rasika-accent"></i>
                            </div>
                            <h3 class="text-3xl font-extrabold text-white mb-4" data-i18n="blog-v1-title">La Evolución del Elearning</h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-8" data-i18n="blog-v1-desc">El LMS tradicional gestiona el acceso. La IA conversacional gestiona el aprendizaje. Juntos, crean un entorno donde la retención del conocimiento se dispara.</p>
                        </div>
                    </div>
                </div>

                <!-- Prose Right -->
                <div class="w-full lg:w-7/12 prose prose-lg prose-invert max-w-none">
                    <h2 class="text-4xl font-extrabold text-white tracking-tight mb-8" data-i18n="blog-h1">¿Por qué un LMS ya no es suficiente?</h2>
                    <p data-i18n="blog-p1">Durante décadas, el <strong>Learning Management System (LMS)</strong> ha sido la columna vertebral de la formación corporativa y académica. Plataformas robustas que permiten organizar mallas curriculares, enrolar a miles de usuarios, alojar paquetes SCORM y emitir certificados. Sin embargo, su diseño fundamental responde a una era de <em>distribución pasiva</em> de contenido.</p>
                    <p data-i18n="blog-p2">El problema actual no es el acceso a la información; es el <strong>aislamiento cognitivo</strong>. Cuando un colaborador o estudiante se enfrenta a un módulo interactivo complejo o a un video instruccional denso, <strong>las dudas surgen en tiempo real</strong>. En un entorno LMS tradicional, ese usuario debe abandonar la plataforma, enviar un correo al instructor o buscar en foros internos, rompiendo el flujo de aprendizaje. Muchas veces, ante la fricción, la duda simplemente se abandona.</p>
                </div>
            </section>

            <!-- Block B: The Conversational Paradigm -->
            <section class="flex flex-col-reverse lg:flex-row gap-16 items-center">
                <!-- Prose Left -->
                <div class="w-full lg:w-7/12 prose prose-lg prose-invert max-w-none">
                    <h2 class="text-4xl font-extrabold text-white tracking-tight mb-8" data-i18n="blog-h2">El paradigma conversacional</h2>
                    <p data-i18n="blog-p3">Aquí es donde la Inteligencia Artificial interviene para cambiar las reglas del juego. Integrar agentes conversacionales (Bots) directamente en la interfaz del LMS transforma la experiencia de un monólogo institucional a un <strong>diálogo socrático personalizado</strong>.</p>
                    <p data-i18n="blog-p4">Imagina un escenario de capacitación en ventas corporativas o resolución de conflictos de liderazgo. Mientras el usuario avanza, nuestro bot ya ha procesado todo el material del curso: transcripciones de los videos, imágenes, diagramas y contenido en texto. Si un estudiante no comprende cómo aplicar una técnica, el bot no solo le recita la teoría, sino que <strong>crea escenarios dinámicos y ejemplos cotidianos para resolver sus dudas</strong>. Actúa como un tutor empático y con los pies en la tierra, construyendo confianza y acompañando el proceso de manera cercana.</p>
                    <div class="bg-[#1A1D21] border-l-4 border-rasika-accent p-6 rounded-r-2xl my-10 shadow-lg">
                        <p class="text-white text-sm m-0 italic font-medium leading-relaxed" data-i18n="blog-quote">"El LMS organiza el viaje. El Bot camina al lado del estudiante, iluminando el camino y evitando que tropiece con las dudas."</p>
                    </div>
                </div>
                
                <!-- Visual Right -->
                <div class="w-full lg:w-5/12">
                    <div class="aspect-square rounded-[3rem] bg-gradient-to-bl from-[#1E2226] to-[#141619] ring-1 ring-inset ring-white/10 shadow-2xl p-10 flex flex-col items-center justify-center text-center relative overflow-hidden isolate">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50 z-0"></div>
                        <div class="relative z-10 w-full">
                            <div class="w-24 h-24 bg-rasika-accent/10 border border-rasika-accent/20 rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_40px_rgba(94,166,176,0.2)]">
                                <i data-lucide="message-circle" class="w-12 h-12 text-rasika-accent"></i>
                            </div>
                            <h3 class="text-3xl font-extrabold text-white mb-4" data-i18n="blog-v2-title">Diálogo Socrático</h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-8" data-i18n="blog-v2-desc">Pasamos de un monólogo institucional estático a una conversación hiper-personalizada en tiempo real, conectada al contexto del usuario.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Full Width Benefits -->
            <section>
                <div class="text-center mb-12">
                    <h3 class="text-3xl font-extrabold text-white" data-i18n="blog-h3">Beneficios inmediatos de la Simbiosis</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Benefit 1 -->
                    <div class="bg-rasika-surface/40 backdrop-blur-sm p-8 rounded-[2rem] border border-white/5 shadow-xl hover:-translate-y-2 transition-transform duration-300">
                        <div class="w-14 h-14 bg-rasika-accent/10 rounded-xl flex items-center justify-center mb-6">
                            <i data-lucide="zap" class="w-7 h-7 text-rasika-accent"></i>
                        </div>
                        <h4 class="text-white font-bold text-lg mb-3" data-i18n="ben-1-t">Resolución instantánea</h4>
                        <p class="text-gray-400 text-sm leading-relaxed" data-i18n="ben-1-d">Eliminación de los cuellos de botella en soporte académico (Zero-Wait).</p>
                    </div>
                    <!-- Benefit 2 -->
                    <div class="bg-rasika-surface/40 backdrop-blur-sm p-8 rounded-[2rem] border border-white/5 shadow-xl hover:-translate-y-2 transition-transform duration-300">
                        <div class="w-14 h-14 bg-rasika-accent/10 rounded-xl flex items-center justify-center mb-6">
                            <i data-lucide="bar-chart-3" class="w-7 h-7 text-rasika-accent"></i>
                        </div>
                        <h4 class="text-white font-bold text-lg mb-3" data-i18n="ben-2-t">Telemetría cualitativa</h4>
                        <p class="text-gray-400 text-sm leading-relaxed" data-i18n="ben-2-d">Generación de reportes personalizados desde Supabase que integran interacciones con el bot, desafíos de aprendizaje y dificultades técnicas al navegar los cursos o la plataforma, nutriendo las métricas de rendimiento.</p>
                    </div>
                    <!-- Benefit 3 -->
                    <div class="bg-rasika-surface/40 backdrop-blur-sm p-8 rounded-[2rem] border border-white/5 shadow-xl hover:-translate-y-2 transition-transform duration-300">
                        <div class="w-14 h-14 bg-rasika-accent/10 rounded-xl flex items-center justify-center mb-6">
                            <i data-lucide="clock" class="w-7 h-7 text-rasika-accent"></i>
                        </div>
                        <h4 class="text-white font-bold text-lg mb-3" data-i18n="ben-3-t">Accesibilidad 24/7</h4>
                        <p class="text-gray-400 text-sm leading-relaxed" data-i18n="ben-3-d">Tutoría experta disponible en cualquier turno horario o huso geográfico continuo.</p>
                    </div>
                </div>
            </section>
        </div>

        <!-- SECTION 2: HOW WE DO IT (Moodle vs TalentLMS) -->
        <section>
            <div class="mb-16 text-center max-w-3xl mx-auto">
                <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6" data-i18n="integ-title">Integración Agnóstica</h2>
                <p class="text-gray-400 text-lg leading-relaxed" data-i18n="integ-desc">Entendemos que cada cliente tiene su propia infraestructura. Por ello conectamos y adaptamos nuestro ecosistema CourseMentor a las arquitecturas más populares del mercado.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <!-- Open Source (Moodle) Card -->
                <div class="bg-[#1A1D21] ring-1 ring-inset ring-white/10 rounded-[2.5rem] p-10 flex flex-col relative overflow-hidden group shadow-2xl">
                    <!-- Cyan Gradient -->
                    <div class="absolute top-0 right-0 w-64 h-64 bg-rasika-accent/10 blur-[80px] rounded-full translate-x-1/2 -translate-y-1/2 transition-all duration-500 group-hover:bg-rasika-accent/20"></div>
                    
                    <div class="w-16 h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center mb-8 relative z-10 p-2">
                        <img src="/images/logos/moodle_logo.svg" alt="Moodle" class="w-full h-full object-contain drop-shadow-md" />
                    </div>
                    
                    <h3 class="text-2xl font-bold text-white mb-4 relative z-10">Open Source: Moodle</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8 relative z-10 flex-1" data-i18n="integ-mo-desc">
                        Integración nativa segura. Conectamos la plataforma vía LTI/xAPI hacia nuestro backend privado (Supabase SOC2 Type 2), asegurando la hiper-personalización y el aislamiento total de la información institucional.
                    </p>
                    
                    <ul class="space-y-4 text-sm text-gray-300 relative z-10 mb-8 border-t border-white/5 pt-8">
                        <li class="flex items-start gap-3"><i data-lucide="database" class="w-5 h-5 text-rasika-accent shrink-0 mt-0.5"></i> <span><strong class="text-white">Multi-Tenancy & RLS:</strong> Datos vectoriales aislados. Operamos con APIs corporativas garantizando cero entrenamiento de LLMs públicos.</span></li>
                        <li class="flex items-start gap-3"><i data-lucide="shield-check" class="w-5 h-5 text-rasika-accent shrink-0 mt-0.5"></i> <span><strong class="text-white">Zero Retention & PII:</strong> Purgado automático de historiales de chat y anonimización de datos de identificación personal.</span></li>
                        <li class="flex items-start gap-3"><i data-lucide="eye-off" class="w-5 h-5 text-rasika-accent shrink-0 mt-0.5"></i> <span><strong class="text-white">Configuración Condicional:</strong> Apagado automático del bot durante foros evaluados, controles o exámenes.</span></li>
                    </ul>
                </div>

                <!-- Proprietary (TalentLMS) Card -->
                <div class="bg-[#1A1D21] ring-1 ring-inset ring-white/10 rounded-[2.5rem] p-10 flex flex-col relative overflow-hidden group shadow-2xl">
                    <!-- White Luminous Gradient -->
                    <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 blur-[80px] rounded-full translate-x-1/2 -translate-y-1/2 transition-all duration-500 group-hover:bg-white/20"></div>
                    
                    <div class="w-16 h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center mb-8 relative z-10 p-2">
                        <img src="/images/logos/talentlms_logo.svg" alt="TalentLMS" class="w-full h-full object-contain drop-shadow-md" />
                    </div>
                    
                    <h3 class="text-2xl font-bold text-white mb-4 relative z-10">LMS Propietario: TalentLMS</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8 relative z-10 flex-1" data-i18n="integ-tl-desc">
                        Conexión sin fricciones en entornos cerrados SaaS. Creamos un backend separado en Supabase que escucha activamente los eventos xAPI en TalentLMS, almacenando y procesando cada interacción.
                    </p>
                    
                    <ul class="space-y-4 text-sm text-gray-300 relative z-10 mb-8 border-t border-white/5 pt-8">
                        <li class="flex items-start gap-3"><i data-lucide="activity" class="w-5 h-5 text-white shrink-0 mt-0.5"></i> <span><strong class="text-white">Telemetría xAPI:</strong> Escucha de eventos en tiempo real para reconocer instantáneamente el ID de curso, unidad y usuario activo.</span></li>
                        <li class="flex items-start gap-3"><i data-lucide="brain-circuit" class="w-5 h-5 text-white shrink-0 mt-0.5"></i> <span><strong class="text-white">Hiper-Personalización:</strong> Almacenamiento del registro de interacciones con el contenido y el widget para adaptar pedagógicamente las respuestas.</span></li>
                        <li class="flex items-start gap-3"><i data-lucide="layers" class="w-5 h-5 text-white shrink-0 mt-0.5"></i> <span><strong class="text-white">Integración UI:</strong> Despliegue global del widget, sintiéndose como una pieza nativa del ecosistema TalentLMS.</span></li>
                    </ul>
                </div>

            </div>
        </section>

        <!-- SECTION 3: COURSEMENTOR ARCHITECTURE -->
        <section class="bg-gradient-to-br from-[#1E2226] to-[#141619] ring-1 ring-inset ring-white/10 rounded-[3rem] p-8 lg:p-16 shadow-2xl relative overflow-hidden isolate">
            <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-rasika-accent/5 blur-[120px] rounded-full translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
            
            <div class="flex flex-col lg:flex-row gap-16 items-center relative z-10">
                <div class="w-full lg:w-1/2">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white text-xs font-bold uppercase tracking-widest mb-6">
                        <i data-lucide="bot" class="w-4 h-4 text-rasika-accent"></i> <span data-i18n="arch-badge">Arquitectura RAG</span>
                    </div>
                    <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-6" data-i18n="arch-title">¿Cómo funciona CourseMentor?</h2>
                    <p class="text-gray-400 text-lg leading-relaxed mb-8" data-i18n="arch-desc">
                        CourseMentor no es un ChatGPT genérico insertado en tu página. Utiliza una arquitectura <strong>Retrieval-Augmented Generation (RAG) Multimodal</strong> para asegurar que las respuestas sean precisas, privadas y basadas estrictamente en tus contenidos.
                    </p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-rasika-accent/10 border border-rasika-accent/30 flex items-center justify-center shrink-0">
                                <span class="text-rasika-accent font-bold">1</span>
                            </div>
                            <div>
                                <h4 class="text-white font-bold mb-1" data-i18n="arch-s1-t">Ingesta Segura</h4>
                                <p class="text-sm text-gray-400 leading-relaxed" data-i18n="arch-s1-d">Procesamos tus PDFs, videos SCORM e infografías. Los convertimos en vectores matemáticos y los almacenamos en una base de datos vectorial privada (Supabase) con seguridad a nivel de fila (RLS).</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-rasika-accent/10 border border-rasika-accent/30 flex items-center justify-center shrink-0">
                                <span class="text-rasika-accent font-bold">2</span>
                            </div>
                            <div>
                                <h4 class="text-white font-bold mb-1" data-i18n="arch-s2-t">Recuperación Semántica</h4>
                                <p class="text-sm text-gray-400 leading-relaxed" data-i18n="arch-s2-d">Cuando un alumno hace una pregunta en tu LMS, nuestro sistema busca en milisegundos los fragmentos exactos de tu material que contienen la respuesta.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-10 h-10 rounded-full bg-rasika-accent/10 border border-rasika-accent/30 flex items-center justify-center shrink-0">
                                <span class="text-rasika-accent font-bold">3</span>
                            </div>
                            <div>
