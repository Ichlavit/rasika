                window.mentorCustomGreetingText = window.mentorCustomGreetingHTML.replace(/<[^>]*>?/gm, '');
                
                // 2. Click the FAB. Chatbot.astro takes over, saves to DB, and prints to UI!
                fab.click();
            }
        };

