            if (tooltip) tooltip.style.display = 'none';

            if (fab) {
                const isEn = document.documentElement.lang === 'en';
                // 1. Just set the global variables
                window.mentorCustomGreetingHTML = isEn 
                    ? "Hi! I am CourseMentor. I am natively integrated here. Do you have any technical questions about how we connect to your LMS?"
