        function parseCsv(text) {
            const rows = [];
            let row = [];
            let value = '';
            let quoted = false;
            for (let index = 0; index < text.length; index += 1) {
                const char = text[index];
                if (char === '"' && quoted && text[index + 1] === '"') { value += '"'; index += 1; continue; }
                if (char === '"') { quoted = !quoted; continue; }
                if (char === ',' && !quoted) { row.push(value); value = ''; continue; }
                if ((char === '\n' || char === '\r') && !quoted) {
                    if (char === '\r' && text[index + 1] === '\n') index += 1;
                    row.push(value); value = '';
                    if (row.some(cell => cell.trim())) rows.push(row);
                    row = [];
                    continue;
                }
                value += char;
            }
            row.push(value);
            if (row.some(cell => cell.trim())) rows.push(row);
            return rows;
        }

        function normalizeCsvHeader(value) {
            return String(value || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
        }

        function csvContactRows(text) {
            const parsed = parseCsv(text);
            if (parsed.length < 2) return [];
            const headers = parsed[0].map(normalizeCsvHeader);
            const aliases = {
                email: ['email', 'correo', 'correo_electronico'],
                full_name: ['full_name', 'nombre', 'name', 'nombre_completo'],
                company_name: ['company_name', 'empresa', 'company', 'organizacion'],
                phone: ['phone', 'telefono', 'celular'],
                lifecycle_stage: ['lifecycle_stage', 'etapa', 'estado'],
                language: ['language', 'idioma'],
                source_detail: ['source_detail', 'origen', 'fuente'],
                newsletter_consent: ['newsletter_consent', 'consentimiento_newsletter', 'consentimiento', 'suscrito']
            };
            const indexFor = key => aliases[key].map(alias => headers.indexOf(alias)).find(index => index >= 0);
            return parsed.slice(1).map(cells => {
                const row = {};
                Object.keys(aliases).forEach(key => {
                    const index = indexFor(key);
                    row[key] = index === undefined ? '' : String(cells[index] || '').trim();
                });
                row.newsletter_consent = ['true', '1', 'yes', 'si', 'sí', 'opt_in'].includes(String(row.newsletter_consent).toLowerCase());
                return row;
            }).filter(row => row.email);
        }

