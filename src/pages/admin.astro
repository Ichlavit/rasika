---
// src/pages/admin.astro
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const seo = seoPages.admin;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <style is:global>
        body { background-color: #0a0c0e; color: #fff; }
        
        .ql-toolbar.ql-snow { 
            background: #1E2226; 
            border-color: rgba(255,255,255,0.1); 
            border-top-left-radius: 0.5rem; 
            border-top-right-radius: 0.5rem; 
            position: sticky;
            top: -24px; 
            z-index: 50;
            box-shadow: 0 -24px 0 0 #1E2226, 0 10px 15px -3px rgba(0, 0, 0, 0.4);
        }
        
        .ql-container.ql-snow { 
            border-color: rgba(255,255,255,0.1); 
            border-bottom-left-radius: 0.5rem; 
            border-bottom-right-radius: 0.5rem; 
            background: #141619; 
            min-height: 400px; 
            font-size: 1rem; 
            color: #E5E7EB !important; 
        }
        
        .ql-snow .ql-stroke { stroke: #D1D5DB; }
        .ql-snow .ql-fill { fill: #D1D5DB; }
        .ql-snow .ql-picker { color: #D1D5DB; }

        .ql-snow .ql-editor.ql-blank::before {
            color: #9CA3AF !important; 
            opacity: 1 !important;     
            font-style: normal !important;
        }

        /* --- QUILL TOOLTIP FIX (MODAL UI) --- */
        .ql-snow .ql-tooltip {
            position: fixed !important;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            z-index: 9999 !important;
            background: #1E2226 !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 1rem !important;
            padding: 2rem !important;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.8) !important;
            color: #fff !important;
            width: 90% !important;
            max-width: 400px !important;
            margin-top: 0 !important;
            white-space: normal !important;
        }

        .ql-snow .ql-tooltip input[type="text"] {
            background: #141619 !important;
            border: 1px solid rgba(255,255,255,0.2) !important;
            color: #fff !important;
            border-radius: 0.5rem !important;
            padding: 0.75rem 1rem !important;
            width: 100% !important;
            margin: 1rem 0 !important;
            font-size: 0.9rem !important;
        }

        .ql-snow .ql-tooltip a.ql-action {
            display: inline-block !important;
            background: #5EA6B0 !important;
            color: #000 !important;
            font-weight: bold !important;
            padding: 0.5rem 1.5rem !important;
            border-radius: 0.5rem !important;
            text-decoration: none !important;
            margin-top: 0.5rem !important;
        }
        
        .ql-snow .ql-tooltip a.ql-action::after { content: "Guardar" !important; border-right: none !important; padding-right: 0 !important; }
        .ql-snow .ql-tooltip a.ql-remove { display: inline-block !important; color: #F87171 !important; font-weight: bold !important; margin-left: 1rem !important; }
        .ql-snow .ql-tooltip a.ql-remove::before { content: "Cancelar" !important; }

        .ql-snow .ql-tooltip[data-mode="link"]::before { content: "Ingresa el enlace URL:" !important; font-weight: bold; color:#9CA3AF; }
        .ql-snow .ql-tooltip[data-mode="video"]::before { content: "URL de Video o Contenido Interactivo:" !important; font-weight: bold; color:#9CA3AF; }


        /* --- SEPARATED STYLING: VIDEOS VS IMAGES --- */
        
        /* Videos/Iframes (Force 16:9 Aspect Ratio) */
        .ql-editor iframe.ql-video {
            width: 100%;
            height: auto; 
            aspect-ratio: 16/9; 
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.1);
            background-color: #0a0c0e;
            margin: 2rem 0;
            display: block;
            transition: all 0.3s ease;
        }

        /* Images/GIFs (Keep Natural Aspect Ratio) */
        .ql-editor img {
            width: 100%;
            height: auto; 
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            margin: 2rem 0;
            display: block;
            transition: all 0.3s ease;
        }

        /* Alignment Sizing (Applies to both) */
        .ql-align-left iframe.ql-video, .ql-align-left img { width: 50%; margin: 2rem auto 2rem 0; }
        .ql-align-center iframe.ql-video, .ql-align-center img { width: 75%; margin: 2rem auto; }
        .ql-align-right iframe.ql-video, .ql-align-right img { width: 50%; margin: 2rem 0 2rem auto; }
    </style>
</head>
<body class="min-h-screen flex items-start lg:items-center justify-center p-6">

    <div id="admin-config" style="display:none;" 
         data-url={supabaseUrl} 
         data-key={supabaseAnonKey}>
    </div>

    <!-- LOGIN SCREEN -->
    <div id="login-screen" class="w-full max-w-md bg-[#1E2226] p-8 rounded-2xl ring-1 ring-white/10 shadow-2xl">
        <div class="text-center mb-8">
            <i data-lucide="lock" class="w-10 h-10 text-[#5EA6B0] mx-auto mb-4"></i>
            <h1 class="text-2xl font-bold">Rasika CMS</h1>
            <p class="text-sm text-gray-400 mt-2">Ingresa tus credenciales de administrador</p>
        </div>
        
        <form id="login-form" class="space-y-4" onsubmit="handleLogin(event)">
            <input type="email" id="email" placeholder="Correo electrónico" required class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-[#5EA6B0]">
            <input type="password" id="password" placeholder="Contraseña" required class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-[#5EA6B0]">
            <p id="login-error" class="text-red-400 text-sm hidden"></p>
            <button type="submit" class="w-full bg-[#5EA6B0] text-black font-bold rounded-xl py-3 hover:bg-[#88d6e0] transition-colors">Ingresar</button>
        </form>
    </div>

    <!-- DASHBOARD SCREEN -->
    <div id="dashboard-screen" class="w-full max-w-7xl hidden flex-col min-h-[calc(100vh-3rem)] lg:h-[90vh] lg:min-h-0">
        
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-4 bg-[#1E2226] p-4 rounded-xl ring-1 ring-white/10">
            <div class="flex items-center gap-3">
                <i data-lucide="layout-dashboard" class="w-6 h-6 text-[#5EA6B0]"></i>
                <h1 id="dashboard-title" class="text-xl font-bold">Editor de Artículos</h1>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <input type="password" id="php-token" placeholder="Token Subida PHP" class="w-40 bg-[#141619] border border-white/10 rounded-lg px-3 py-1.5 outline-none text-white text-sm focus:border-[#5EA6B0]" title="La contraseña secreta de tu archivo upload.php">
                <button onclick="logout()" class="text-sm text-gray-400 hover:text-white flex items-center gap-2">
                    <i data-lucide="log-out" class="w-4 h-4"></i> Cerrar Sesión
                </button>
            </div>
        </div>

        <div class="flex items-center gap-1 mb-4 p-1 bg-[#141619] border border-white/10 rounded-lg w-fit" role="tablist" aria-label="Secciones del CMS">
            <button id="admin-tab-articles" type="button" role="tab" aria-selected="true" onclick="setAdminView('articles')" class="px-4 py-2 rounded-md bg-[#5EA6B0] text-black text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="file-pen-line" class="w-4 h-4"></i> Artículos
            </button>
            <button id="admin-tab-radar" type="button" role="tab" aria-selected="false" onclick="setAdminView('radar')" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="radar" class="w-4 h-4"></i> AI Radar
            </button>
        </div>

        <section id="articles-panel" class="flex-1 flex flex-col min-h-0" role="tabpanel">
            <div class="flex items-center gap-4 mb-4">
                <div class="flex-1 relative">
                    <select id="edit-selector" onchange="handleEditSelection(this.value)" class="w-full bg-[#1A1E22] border border-white/20 rounded-xl px-4 py-3 appearance-none outline-none text-white focus:border-[#5EA6B0] font-medium">
                        <option value="">✨ Crear Nuevo Artículo...</option>
                    </select>
                    <i data-lucide="chevron-down" class="w-5 h-5 absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
                <button onclick="document.getElementById('edit-selector').value=''; handleEditSelection('');" class="px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-sm font-bold transition-colors">
                    Limpiar
                </button>
            </div>

            <div class="flex-1 bg-[#1E2226] rounded-2xl ring-1 ring-white/10 p-6 overflow-y-auto no-scrollbar relative">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Tipo de Contenido</label>
                        <select id="post-type" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                            <option value="human">Human: Artículo Destacado</option>
                            <option value="agent">AI: Radar / Tendencia</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Título</label>
                        <input type="text" id="post-title" placeholder="Ej: El fin del SCORM..." class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Autor / Agente</label>
                        <input type="text" id="post-author" placeholder="Ej: Ignacio G." class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Categoría</label>
                        <input type="text" id="post-category" placeholder="Ej: Diseño Instruccional" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase flex justify-between">
                            <span>Ruta de la Imagen de Portada (Carpeta Public)</span>
                            <button type="button" onclick="uploadCoverImage()" class="text-[#5EA6B0] hover:text-white flex items-center gap-1 normal-case"><i data-lucide="upload" class="w-3 h-3"></i> Subir Imagen</button>
                        </label>
                        <input type="text" id="post-cover" placeholder="/images/blog/mi-portada.jpg" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                </div>

                <div class="mb-6">
                    <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Contenido del Artículo</label>
                    <div id="editor"></div>
                </div>

                <div class="flex flex-wrap justify-end gap-4 mt-6 pt-4 border-t border-white/10">
                    <button onclick="saveDraft()" id="save-btn" class="px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 font-bold transition-all flex items-center gap-2 text-gray-300">
                        <i data-lucide="save" class="w-4 h-4"></i> Guardar Borrador
                    </button>
                    <button onclick="openPreview()" class="px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 font-bold transition-all text-gray-300 flex items-center gap-2">
                        <i data-lucide="eye" class="w-4 h-4"></i> Vista Previa
                    </button>
                    <button onclick="publishPost()" id="publish-btn" class="px-8 py-3 bg-[#5EA6B0] text-black font-bold rounded-xl hover:bg-[#88d6e0] transition-colors flex items-center gap-2">
                        <i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora
                    </button>
                </div>
            </div>
        </section>

        <section id="radar-panel" class="hidden flex-col lg:flex-1 lg:min-h-0" role="tabpanel">
            <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3 mb-4">
                <div class="relative sm:w-64">
                    <select id="radar-status-filter" onchange="loadRadarQueue()" class="w-full bg-[#1A1E22] border border-white/20 rounded-lg px-4 py-2.5 appearance-none outline-none text-white focus:border-[#5EA6B0] text-sm font-medium">
                        <option value="suggested">Sugeridos</option>
                        <option value="needs_review">Requieren revisión</option>
                        <option value="approved">Aprobados</option>
                        <option value="rejected">Rechazados</option>
                        <option value="published">Publicados</option>
                        <option value="all">Todos</option>
                    </select>
                    <i data-lucide="chevron-down" class="w-4 h-4 absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none"></i>
                </div>
                <button type="button" onclick="loadRadarQueue()" class="w-10 h-10 flex items-center justify-center border border-white/10 rounded-lg text-gray-400 hover:text-white hover:bg-white/5" title="Actualizar cola">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                </button>
                <button id="radar-sources-btn" type="button" onclick="toggleRadarSources()" aria-expanded="false" class="h-10 px-3 border border-white/10 rounded-lg text-sm font-bold text-gray-300 hover:text-white hover:bg-white/5 flex items-center gap-2">
                    <i data-lucide="list-filter" class="w-4 h-4"></i> Fuentes
                </button>
                <button id="radar-run-btn" type="button" onclick="runRadarIngestion()" class="h-10 px-4 bg-[#5EA6B0] text-black rounded-lg text-sm font-bold hover:bg-[#88d6e0] flex items-center gap-2">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar fuentes
                </button>
                <div class="sm:ml-auto min-w-0 text-right">
                    <div id="radar-counts" class="text-xs text-gray-500"></div>
                    <div id="radar-run-result" class="text-xs text-gray-500 mt-1" role="status" aria-live="polite"></div>
                </div>
            </div>

            <div id="radar-sources-panel" class="hidden mb-4 border-y border-white/10 bg-[#181b1e]">
                <div class="flex items-center justify-between gap-4 px-4 py-3 border-b border-white/10">
                    <h2 class="text-xs font-bold text-gray-400 uppercase">Fuentes piloto</h2>
                    <span id="radar-last-run" class="text-xs text-gray-500"></span>
                </div>
                <div id="radar-source-list" class="divide-y divide-white/10"></div>
                <div id="radar-runs" class="border-t border-white/10 px-4 py-3 text-xs text-gray-500"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 lg:flex-1 lg:min-h-0 border border-white/10 rounded-xl overflow-visible lg:overflow-hidden bg-[#1E2226]">
                <div class="lg:col-span-5 min-h-[18rem] max-h-[24rem] lg:max-h-none lg:min-h-0 border-b lg:border-b-0 lg:border-r border-white/10 flex flex-col">
                    <div class="px-4 py-3 border-b border-white/10 text-xs font-bold text-gray-400 uppercase">Cola editorial</div>
                    <div id="radar-queue" class="flex-1 overflow-y-auto no-scrollbar p-2"></div>
                </div>

                <div class="lg:col-span-7 lg:min-h-0 flex flex-col">
                    <div id="radar-empty" class="flex-1 flex flex-col items-center justify-center text-center p-8 text-gray-500">
                        <i data-lucide="radar" class="w-9 h-9 mb-3 text-[#5EA6B0]"></i>
                        <p class="text-sm font-medium">Selecciona una sugerencia</p>
                    </div>

                    <div id="radar-detail" class="hidden lg:flex-1 overflow-visible lg:overflow-y-auto no-scrollbar p-5 md:p-6">
                        <div class="flex flex-wrap items-start gap-3 mb-5">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-2">
                                    <span id="radar-detail-status" class="text-xs font-bold uppercase px-2 py-1 rounded bg-white/5 text-gray-300"></span>
                                    <span id="radar-detail-threshold" class="text-xs font-bold"></span>
                                </div>
                                <a id="radar-detail-source-link" href="#" target="_blank" rel="noopener noreferrer" class="text-xs text-[#5EA6B0] hover:text-white inline-flex items-center gap-1">
                                    <span id="radar-detail-source"></span><i data-lucide="external-link" class="w-3 h-3"></i>
                                </a>
                            </div>
                            <div id="radar-detail-total" class="text-2xl font-bold text-white tabular-nums"></div>
                        </div>

                        <div id="radar-score-grid" class="grid grid-cols-3 md:grid-cols-6 gap-2 mb-6"></div>

                        <div class="space-y-4">
                            <div class="border-y border-white/10 py-4">
                                <div class="text-xs font-bold text-gray-400 mb-2 uppercase">Evidencia RSS original</div>
                                <div id="radar-source-title" class="text-sm font-bold text-white leading-snug"></div>
                                <div id="radar-source-excerpt" class="mt-2 text-sm text-gray-400 leading-relaxed whitespace-pre-wrap"></div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Titular sugerido</label>
                                <input id="radar-headline" type="text" class="w-full bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Síntesis editorial</label>
                                <textarea id="radar-summary" rows="6" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Por qué importa</label>
                                <textarea id="radar-why" rows="3" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Paralelismo con Rasika</label>
                                <textarea id="radar-parallelism" rows="3" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Borrador LinkedIn</label>
                                <textarea id="radar-linkedin" rows="5" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Prompt de miniatura</label>
                                <textarea id="radar-thumbnail-prompt" rows="3" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Notas de revisión</label>
                                <textarea id="radar-review-notes" rows="3" class="w-full resize-y bg-[#141619] border border-white/10 rounded-lg px-4 py-3 outline-none text-gray-200 focus:border-[#5EA6B0]"></textarea>
                            </div>
                        </div>

                        <div class="flex flex-wrap justify-end gap-3 mt-6 pt-5 border-t border-white/10">
                            <button id="radar-save-btn" type="button" onclick="saveRadarDraft()" class="px-4 py-2.5 border border-white/10 rounded-lg text-sm font-bold text-gray-300 hover:text-white hover:bg-white/5 flex items-center gap-2">
                                <i data-lucide="save" class="w-4 h-4"></i> Guardar
                            </button>
                            <button id="radar-return-btn" type="button" onclick="reviewRadarCandidate('needs_review')" class="px-4 py-2.5 border border-amber-400/30 rounded-lg text-sm font-bold text-amber-300 hover:bg-amber-400/10 flex items-center gap-2">
                                <i data-lucide="rotate-ccw" class="w-4 h-4"></i> Revisar
                            </button>
                            <button id="radar-reject-btn" type="button" onclick="reviewRadarCandidate('rejected')" class="px-4 py-2.5 border border-red-400/30 rounded-lg text-sm font-bold text-red-300 hover:bg-red-400/10 flex items-center gap-2">
                                <i data-lucide="x" class="w-4 h-4"></i> Rechazar
                            </button>
                            <button id="radar-approve-btn" type="button" onclick="reviewRadarCandidate('approved')" class="px-4 py-2.5 bg-[#5EA6B0] text-black rounded-lg text-sm font-bold hover:bg-[#88d6e0] flex items-center gap-2">
                                <i data-lucide="check" class="w-4 h-4"></i> Aprobar
                            </button>
                            <button id="radar-publish-btn" type="button" onclick="publishRadarCandidate()" class="hidden px-4 py-2.5 bg-white text-black rounded-lg text-sm font-bold hover:bg-gray-200 flex items-center gap-2">
                                <i data-lucide="send" class="w-4 h-4"></i> Publicar en Blog
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script is:inline>
        lucide.createIcons();
        
        const config = document.getElementById('admin-config');
        const SUPA_URL = config.getAttribute('data-url').replace(/\/$/, '');
        const SUPA_KEY = config.getAttribute('data-key');
        
        let currentEditingId = null;
        let currentRadarCandidate = null;
        let radarQueueLoaded = false;
        let radarSourcesLoaded = false;

        document.addEventListener('DOMContentLoaded', async () => {
            const token = sessionStorage.getItem('adminToken');
            if (token && token !== 'undefined' && token.split('.').length === 3) {
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('dashboard-screen').classList.replace('hidden', 'flex');
                
                await loadArticlesList(); 
                window.loadDraft();              
            } else {
                sessionStorage.removeItem('adminToken');
            }
        });

        // --- CUSTOM QUILL IMAGE HANDLER (CONNECTS TO UPLOAD.PHP) ---
        function customImageHandler() {
            const token = document.getElementById('php-token').value;
            if (!token) {
                alert("Por favor, ingresa el Token de Subida (PHP) en la esquina superior derecha.");
                return;
            }

            const input = document.createElement('input');
            input.setAttribute('type', 'file');
            input.setAttribute('accept', 'image/*');
            input.click();

            input.onchange = async () => {
                const file = input.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('file', file);

                try {
                    // Send to your SiteGround upload.php
                    const res = await fetch('/upload.php', {
                        method: 'POST',
                        headers: {
                            'X-Upload-Token': token,
                            'X-Upload-Path': 'blog' // Tell PHP to save in /images/blog/
                        },
                        body: formData
                    });

                    const data = await res.json();
                    
                    if (res.ok && data.success) {
                        // Insert the live image URL securely generated by the server
                        const range = quill.getSelection(true);
                        quill.insertEmbed(range.index, 'image', data.url);
                        quill.setSelection(range.index + 1);
                    } else {
                        alert("Error del servidor: " + (data.error || "Desconocido"));
                    }
                } catch (err) {
                    console.error("Upload error:", err);
                    alert("Error de conexión con upload.php.");
                }
            };
        }

