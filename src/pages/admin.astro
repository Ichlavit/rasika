---
// src/pages/admin.astro
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { seoPages } from '../data/seo';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const seo = seoPages.admin;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO {...seo} />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <style is:global>
        body { background-color: #0a0c0e; color: #fff; }
        
        .ql-toolbar.ql-snow { 
            background: #1E2226; 
            border-color: rgba(255,255,255,0.1); 
            border-top-left-radius: 0.5rem; 
            border-top-right-radius: 0.5rem; 
            position: sticky;
            top: -24px; 
            z-index: 50;
            box-shadow: 0 -24px 0 0 #1E2226, 0 10px 15px -3px rgba(0, 0, 0, 0.4);
        }
        
        .ql-container.ql-snow { 
            border-color: rgba(255,255,255,0.1); 
            border-bottom-left-radius: 0.5rem; 
            border-bottom-right-radius: 0.5rem; 
            background: #141619; 
            min-height: 400px; 
            font-size: 1rem; 
            color: #E5E7EB !important; 
        }
        
        .ql-snow .ql-stroke { stroke: #D1D5DB; }
        .ql-snow .ql-fill { fill: #D1D5DB; }
        .ql-snow .ql-picker { color: #D1D5DB; }

        .ql-snow .ql-editor.ql-blank::before {
            color: #9CA3AF !important; 
            opacity: 1 !important;     
            font-style: normal !important;
        }

        /* --- QUILL TOOLTIP FIX (MODAL UI) --- */
        .ql-snow .ql-tooltip {
            position: fixed !important;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            z-index: 9999 !important;
            background: #1E2226 !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 1rem !important;
            padding: 2rem !important;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.8) !important;
            color: #fff !important;
            width: 90% !important;
            max-width: 400px !important;
            margin-top: 0 !important;
            white-space: normal !important;
        }

        .ql-snow .ql-tooltip input[type="text"] {
            background: #141619 !important;
            border: 1px solid rgba(255,255,255,0.2) !important;
            color: #fff !important;
            border-radius: 0.5rem !important;
            padding: 0.75rem 1rem !important;
            width: 100% !important;
            margin: 1rem 0 !important;
            font-size: 0.9rem !important;
        }

        .ql-snow .ql-tooltip a.ql-action {
            display: inline-block !important;
            background: #5EA6B0 !important;
            color: #000 !important;
            font-weight: bold !important;
            padding: 0.5rem 1.5rem !important;
            border-radius: 0.5rem !important;
            text-decoration: none !important;
            margin-top: 0.5rem !important;
        }
        
        .ql-snow .ql-tooltip a.ql-action::after { content: "Guardar" !important; border-right: none !important; padding-right: 0 !important; }
        .ql-snow .ql-tooltip a.ql-remove { display: inline-block !important; color: #F87171 !important; font-weight: bold !important; margin-left: 1rem !important; }
        .ql-snow .ql-tooltip a.ql-remove::before { content: "Cancelar" !important; }

        .ql-snow .ql-tooltip[data-mode="link"]::before { content: "Ingresa el enlace URL:" !important; font-weight: bold; color:#9CA3AF; }
        .ql-snow .ql-tooltip[data-mode="video"]::before { content: "URL de Video o Contenido Interactivo:" !important; font-weight: bold; color:#9CA3AF; }


        /* --- SEPARATED STYLING: VIDEOS VS IMAGES --- */
        
        /* Videos/Iframes (Force 16:9 Aspect Ratio) */
        .ql-editor iframe.ql-video {
            width: 100%;
            height: auto; 
            aspect-ratio: 16/9; 
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.1);
            background-color: #0a0c0e;
            margin: 2rem 0;
            display: block;
            transition: all 0.3s ease;
        }

        /* Images/GIFs (Keep Natural Aspect Ratio) */
        .ql-editor img {
            width: 100%;
            height: auto; 
            border-radius: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            margin: 2rem 0;
            display: block;
            transition: all 0.3s ease;
        }

        /* Alignment Sizing (Applies to both) */
        .ql-align-left iframe.ql-video, .ql-align-left img { width: 50%; margin: 2rem auto 2rem 0; }
        .ql-align-center iframe.ql-video, .ql-align-center img { width: 75%; margin: 2rem auto; }
        .ql-align-right iframe.ql-video, .ql-align-right img { width: 50%; margin: 2rem 0 2rem auto; }

        @media (min-width: 1024px) {
            #dashboard-screen.radar-layout { height: 90vh; min-height: 0; }
        }
    </style>
</head>
<body class="min-h-screen flex items-start justify-center p-6">

    <div id="admin-config" style="display:none;" 
         data-url={supabaseUrl} 
         data-key={supabaseAnonKey}>
    </div>

    <!-- LOGIN SCREEN -->
    <div id="login-screen" class="w-full max-w-md bg-[#1E2226] p-8 rounded-2xl ring-1 ring-white/10 shadow-2xl">
        <div class="text-center mb-8">
            <i data-lucide="lock" class="w-10 h-10 text-[#5EA6B0] mx-auto mb-4"></i>
            <h1 class="text-2xl font-bold">Rasika CMS</h1>
            <p class="text-sm text-gray-400 mt-2">Ingresa tus credenciales de administrador</p>
        </div>
        
        <form id="login-form" class="space-y-4" onsubmit="handleLogin(event)">
            <input type="email" id="email" placeholder="Correo electrónico" required class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-[#5EA6B0]">
            <input type="password" id="password" placeholder="Contraseña" required class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-[#5EA6B0]">
            <p id="login-error" class="text-red-400 text-sm hidden"></p>
            <button type="submit" class="w-full bg-[#5EA6B0] text-black font-bold rounded-xl py-3 hover:bg-[#88d6e0] transition-colors">Ingresar</button>
        </form>
    </div>

    <!-- DASHBOARD SCREEN -->
    <div id="dashboard-screen" class="w-full max-w-7xl hidden flex-col min-h-[calc(100vh-3rem)]">
        
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-4 bg-[#1E2226] p-4 rounded-xl ring-1 ring-white/10">
            <div class="flex items-center gap-3">
                <i data-lucide="layout-dashboard" class="w-6 h-6 text-[#5EA6B0]"></i>
                <h1 id="dashboard-title" class="text-xl font-bold">Editor de Artículos</h1>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <input type="password" id="php-token" placeholder="Token Subida PHP" class="w-40 bg-[#141619] border border-white/10 rounded-lg px-3 py-1.5 outline-none text-white text-sm focus:border-[#5EA6B0]" title="La contraseña secreta de tu archivo upload.php">
                <button onclick="logout()" class="text-sm text-gray-400 hover:text-white flex items-center gap-2">
                    <i data-lucide="log-out" class="w-4 h-4"></i> Cerrar Sesión
                </button>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-1 mb-4 p-1 bg-[#141619] border border-white/10 rounded-lg w-fit" role="tablist" aria-label="Secciones del CMS">
            <button id="admin-tab-overview" type="button" role="tab" aria-selected="true" onclick="setAdminView('overview')" class="px-4 py-2 rounded-md bg-[#5EA6B0] text-black text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="chart-no-axes-combined" class="w-4 h-4"></i> Resumen
            </button>
            <button id="admin-tab-contacts" type="button" role="tab" aria-selected="false" onclick="setAdminView('contacts')" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="contact-round" class="w-4 h-4"></i> Contactos
            </button>
            <button id="admin-tab-articles" type="button" role="tab" aria-selected="false" onclick="setAdminView('articles')" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="file-pen-line" class="w-4 h-4"></i> Artículos
            </button>
            <button id="admin-tab-radar" type="button" role="tab" aria-selected="false" onclick="setAdminView('radar')" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="radar" class="w-4 h-4"></i> AI Radar
            </button>
            <button id="admin-tab-campaigns" type="button" role="tab" aria-selected="false" onclick="setAdminView('campaigns')" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors">
                <i data-lucide="mails" class="w-4 h-4"></i> Campañas
            </button>
        </div>

        <section id="overview-panel" class="flex-1 flex flex-col min-h-0 gap-4" role="tabpanel">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-1 p-1 bg-[#141619] border border-white/10 rounded-lg" aria-label="Periodo del informe">
                    <button type="button" data-marketing-days="7" class="px-3 py-2 rounded-md text-xs font-bold text-gray-400 hover:text-white">7 días</button>
                    <button type="button" data-marketing-days="30" class="px-3 py-2 rounded-md text-xs font-bold bg-white/10 text-white">30 días</button>
                    <button type="button" data-marketing-days="90" class="px-3 py-2 rounded-md text-xs font-bold text-gray-400 hover:text-white">90 días</button>
                </div>
                <button type="button" onclick="loadMarketingOverview(true)" class="w-10 h-10 border border-white/10 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 flex items-center justify-center" title="Actualizar métricas" aria-label="Actualizar métricas">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                </button>
            </div>

            <div id="marketing-metrics" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3"></div>

            <div class="grid grid-cols-1 xl:grid-cols-[1.55fr_1fr] gap-4">
                <section class="bg-[#1E2226] border border-white/10 rounded-lg p-5 min-h-72">
                    <div class="flex items-center justify-between gap-3 mb-6">
                        <h2 class="font-bold text-white">Sesiones y páginas vistas</h2>
                        <span id="marketing-period-label" class="text-xs text-gray-500"></span>
                    </div>
                    <div id="marketing-chart" class="h-52 flex items-end gap-1" aria-label="Actividad del sitio"></div>
                    <div class="mt-4 flex items-center gap-5 text-xs text-gray-500">
                        <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 bg-[#5EA6B0] rounded-sm"></span> Sesiones</span>
                        <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 bg-white/25 rounded-sm"></span> Páginas vistas</span>
                    </div>
                </section>

                <section class="bg-[#1E2226] border border-white/10 rounded-lg p-5">
                    <div class="flex items-center justify-between gap-3 mb-4">
                        <h2 class="font-bold text-white">Estado operativo</h2>
                        <span id="resend-status" class="text-xs font-bold text-gray-400">Verificando</span>
                    </div>
                    <div id="marketing-operational" class="space-y-3"></div>
                </section>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                <section class="bg-[#1E2226] border border-white/10 rounded-lg p-5">
                    <h2 class="font-bold text-white mb-4">Páginas principales</h2>
                    <div id="marketing-top-pages" class="space-y-3"></div>
                </section>
                <section class="bg-[#1E2226] border border-white/10 rounded-lg p-5">
                    <h2 class="font-bold text-white mb-4">Fuentes de tráfico</h2>
                    <div id="marketing-sources" class="space-y-3"></div>
                </section>
                <section class="bg-[#1E2226] border border-white/10 rounded-lg p-5">
                    <h2 class="font-bold text-white mb-4">Clics principales</h2>
                    <div id="marketing-clicks" class="space-y-3"></div>
                </section>
            </div>

            <section class="bg-[#1E2226] border border-white/10 rounded-lg overflow-hidden">
                <div class="px-5 py-4 border-b border-white/10 flex items-center justify-between gap-3">
                    <h2 class="font-bold text-white">Novedades para próxima campaña</h2>
                    <button type="button" onclick="setAdminView('campaigns')" class="text-xs font-bold text-[#88d6e0] hover:text-white">Abrir campañas</button>
                </div>
                <div id="marketing-content-queue" class="divide-y divide-white/10"></div>
            </section>
        </section>

        <section id="contacts-panel" class="hidden flex-1 flex-col min-h-0 gap-4" role="tabpanel">
            <div class="flex flex-col lg:flex-row gap-3 lg:items-center lg:justify-between">
                <div class="relative flex-1 max-w-xl">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
                    <input id="contacts-search" type="search" placeholder="Buscar por nombre, empresa o correo" class="w-full bg-[#141619] border border-white/10 rounded-lg pl-10 pr-4 py-3 outline-none text-sm focus:border-[#5EA6B0]">
                </div>
                <div class="flex flex-wrap gap-2">
                    <input id="contacts-csv" type="file" accept=".csv,text/csv" class="hidden">
                    <button type="button" onclick="document.getElementById('contacts-csv').click()" class="px-4 py-3 border border-white/10 rounded-lg text-sm font-bold text-gray-300 hover:text-white hover:bg-white/5 flex items-center gap-2">
                        <i data-lucide="file-up" class="w-4 h-4"></i> Importar CSV
                    </button>
                    <button type="button" disabled class="px-4 py-3 border border-white/10 rounded-lg text-sm font-bold text-gray-600 flex items-center gap-2 cursor-not-allowed" title="Disponible en una fase posterior">
                        <i data-lucide="user-plus" class="w-4 h-4"></i> Nuevo contacto
                    </button>
                </div>
            </div>
            <div id="contacts-summary" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
            <div class="bg-[#1E2226] border border-white/10 rounded-lg overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[880px] text-sm">
                        <thead class="bg-[#181b1e] text-xs uppercase text-gray-500">
                            <tr><th class="px-4 py-3 text-left">Contacto</th><th class="px-4 py-3 text-left">Empresa</th><th class="px-4 py-3 text-left">Etapa</th><th class="px-4 py-3 text-left">Newsletter</th><th class="px-4 py-3 text-left">Origen</th><th class="px-4 py-3 text-right">Última actividad</th></tr>
                        </thead>
                        <tbody id="contacts-table" class="divide-y divide-white/10"></tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="campaigns-panel" class="hidden flex-1 flex-col min-h-0 gap-4" role="tabpanel">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                <section class="lg:col-span-2 bg-[#1E2226] border border-white/10 rounded-lg overflow-hidden">
                    <div class="px-5 py-4 border-b border-white/10 flex items-center justify-between gap-3">
                        <h2 class="font-bold text-white">Cola editorial</h2>
                        <span id="campaign-queue-count" class="text-xs text-gray-500">0 novedades</span>
                    </div>
                    <div id="campaign-content-queue" class="divide-y divide-white/10"></div>
                </section>
                <aside class="bg-[#1E2226] border border-white/10 rounded-lg p-5 h-fit">
                    <div class="w-10 h-10 border border-[#5EA6B0]/30 bg-[#5EA6B0]/10 rounded-lg flex items-center justify-center text-[#88d6e0] mb-5"><i data-lucide="send" class="w-5 h-5"></i></div>
                    <h2 class="font-bold text-white mb-2">Nueva campaña</h2>
                    <div class="space-y-3 mt-5">
                        <button type="button" disabled class="w-full px-4 py-3 rounded-lg bg-[#5EA6B0]/30 text-[#0a0c0e]/70 font-bold cursor-not-allowed flex items-center justify-center gap-2"><i data-lucide="wand-sparkles" class="w-4 h-4"></i> Crear borrador</button>
                        <button type="button" disabled class="w-full px-4 py-3 rounded-lg border border-white/10 text-gray-600 font-bold cursor-not-allowed flex items-center justify-center gap-2"><i data-lucide="users-round" class="w-4 h-4"></i> Segmentos</button>
                        <button type="button" disabled class="w-full px-4 py-3 rounded-lg border border-white/10 text-gray-600 font-bold cursor-not-allowed flex items-center justify-center gap-2"><i data-lucide="calendar-clock" class="w-4 h-4"></i> Programar envío</button>
                    </div>
                    <p class="mt-5 text-xs leading-relaxed text-gray-500">Los envíos masivos permanecerán bloqueados hasta incorporar aprobación, previsualización y prueba de entrega.</p>
                </aside>
            </div>
            <section class="bg-[#1E2226] border border-white/10 rounded-lg overflow-hidden">
                <div class="px-5 py-4 border-b border-white/10"><h2 class="font-bold text-white">Historial de campañas</h2></div>
                <div id="campaign-history" class="divide-y divide-white/10"></div>
            </section>
        </section>

        <section id="articles-panel" class="hidden flex-1 flex-col min-h-0" role="tabpanel">
            <div class="flex items-center gap-4 mb-4">
                <div class="flex-1 relative">
                    <select id="edit-selector" onchange="handleEditSelection(this.value)" class="w-full bg-[#1A1E22] border border-white/20 rounded-xl px-4 py-3 appearance-none outline-none text-white focus:border-[#5EA6B0] font-medium">
                        <option value="">✨ Crear Nuevo Artículo...</option>
                    </select>
                    <i data-lucide="chevron-down" class="w-5 h-5 absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
                <button onclick="document.getElementById('edit-selector').value=''; handleEditSelection('');" class="px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-sm font-bold transition-colors">
                    Limpiar
                </button>
            </div>

            <div class="bg-[#1E2226] rounded-2xl ring-1 ring-white/10 p-6 relative">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Tipo de Contenido</label>
                        <select id="post-type" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                            <option value="human">Human: Artículo Destacado</option>
                            <option value="agent">AI: Radar / Tendencia</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Título</label>
                        <input type="text" id="post-title" placeholder="Ej: El fin del SCORM..." class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Autor / Agente</label>
                        <input type="text" id="post-author" placeholder="Ej: Ignacio G." class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Categoría</label>
                        <input type="text" id="post-category" placeholder="Ej: Diseño Instruccional" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Resumen para buscadores</label>
                        <textarea id="post-excerpt" rows="3" maxlength="320" placeholder="Resumen claro del artículo. Si se deja vacío, se generará desde el contenido." class="w-full resize-y bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]"></textarea>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-gray-400 mb-2 uppercase flex justify-between">
                            <span>Ruta de la Imagen de Portada (Carpeta Public)</span>
                            <button type="button" onclick="uploadCoverImage()" class="text-[#5EA6B0] hover:text-white flex items-center gap-1 normal-case"><i data-lucide="upload" class="w-3 h-3"></i> Subir Imagen</button>
                        </label>
                        <input type="text" id="post-cover" placeholder="/images/blog/mi-portada.jpg" class="w-full bg-[#141619] border border-white/10 rounded-xl px-4 py-3 outline-none text-white focus:border-[#5EA6B0]">
                    </div>
                </div>

                <div class="mb-6">
                    <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Contenido del Artículo</label>
                    <div id="editor"></div>
                </div>

                <div class="flex flex-wrap justify-end gap-4 mt-6 pt-4 border-t border-white/10">
                    <button onclick="saveDraft()" id="save-btn" class="px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 font-bold transition-all flex items-center gap-2 text-gray-300">
                        <i data-lucide="save" class="w-4 h-4"></i> Guardar Borrador
                    </button>
                    <button onclick="openPreview()" class="px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 font-bold transition-all text-gray-300 flex items-center gap-2">
                        <i data-lucide="eye" class="w-4 h-4"></i> Vista Previa
                    </button>
                    <button onclick="publishPost()" id="publish-btn" class="px-8 py-3 bg-[#5EA6B0] text-black font-bold rounded-xl hover:bg-[#88d6e0] transition-colors flex items-center gap-2">
                        <i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora
                    </button>
                </div>
            </div>
        </section>

        <section id="radar-panel" class="hidden flex-col lg:flex-1 lg:min-h-0" role="tabpanel">
            <div id="radar-governance" class="mb-4 border-y border-white/10 bg-[#181b1e] px-4 py-3 flex items-start gap-3">
                <i data-lucide="shield-check" class="mt-0.5 h-4 w-4 shrink-0 text-[#5EA6B0]"></i>
                <div class="min-w-0">
                    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                        <span class="text-xs font-bold uppercase text-gray-400">Autoridad editorial</span>
