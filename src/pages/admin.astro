        window.handleLogin = async function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const errorEl = document.getElementById('login-error');

            try {
                const res = await fetch(`${SUPA_URL}/auth/v1/token?grant_type=password`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'apikey': SUPA_KEY },
                    body: JSON.stringify({ email, password })
                });

                const data = await res.json();
                
                if (data.error || !data.access_token) {
                    errorEl.innerText = data.error_description || data.msg || "Credenciales incorrectas.";
                    errorEl.classList.remove('hidden');
                } else {
                    sessionStorage.setItem('adminToken', data.access_token);
                    document.getElementById('login-screen').classList.add('hidden');
                    document.getElementById('dashboard-screen').classList.replace('hidden', 'flex');
                    
                    await loadArticlesList(); 
                    window.loadDraft();
                }
            } catch (err) {
                console.error(err);
                errorEl.innerText = "Error de red. Revisa tu conexión o API Key.";
                errorEl.classList.remove('hidden');
            }
        }

        window.logout = function() {
            sessionStorage.removeItem('adminToken');
            currentRadarCandidate = null;
            radarQueueLoaded = false;
            radarSourcesLoaded = false;
            document.getElementById('dashboard-screen').classList.replace('flex', 'hidden');
            document.getElementById('login-screen').classList.remove('hidden');
            document.getElementById('password').value = '';
        }

        function escapeAdminHTML(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function radarStatusLabel(status) {
            return {
                discovered: 'Descubierto',
                evaluating: 'Evaluando',
                suggested: 'Sugerido',
                needs_review: 'En revisión',
                approved: 'Aprobado',
                rejected: 'Rechazado',
                published: 'Publicado',
                archived: 'Archivado',
                failed: 'Fallido'
            }[status] || status || 'Sin estado';
        }

        function formatRadarDate(value) {
            if (!value) return 'Fecha no disponible';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Fecha no disponible';
            return new Intl.DateTimeFormat('es-CL', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
            }).format(date);
        }

        async function radarRequest(path = '', options = {}) {
            const token = sessionStorage.getItem('adminToken');
            if (!token || token.split('.').length !== 3) {
                window.logout();
                throw new Error('Tu sesión expiró. Ingresa nuevamente.');
            }

            const res = await fetch(`${SUPA_URL}/functions/v1/ai-radar-admin${path}`, {
                ...options,
                headers: {
                    'Content-Type': 'application/json',
                    'apikey': SUPA_KEY,
                    'Authorization': `Bearer ${token}`,
                    ...(options.headers || {})
                }
            });
            const data = await res.json().catch(() => ({}));
            if (res.status === 401) window.logout();
            if (!res.ok) throw new Error(data.error || `Error AI Radar (${res.status})`);
            return data;
        }

        function formatRadarTimestamp(value) {
            if (!value) return 'Sin ejecución';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Sin ejecución';
            return new Intl.DateTimeFormat('es-CL', {
                day: '2-digit',
                month: 'short',
                hour: '2-digit',
                minute: '2-digit'
            }).format(date);
        }

        function radarRunStatusLabel(status) {
            return {
                queued: 'En cola',
                running: 'En curso',
                succeeded: 'Completada',
                partial: 'Parcial',
                failed: 'Fallida',
                cancelled: 'Cancelada'
            }[status] || status || 'Sin estado';
        }

        function renderRadarSources(sources) {
            const pilotKeys = new Set(['SRC-13', 'SRC-38']);
            const pilotSources = (sources || []).filter(source => pilotKeys.has(source.source_key));
            const list = document.getElementById('radar-source-list');
            if (!pilotSources.length) {
                list.innerHTML = '<div class="px-4 py-4 text-sm text-gray-500">No hay fuentes piloto configuradas.</div>';
                return;
            }

            list.innerHTML = pilotSources.map(source => {
                const healthClass = source.health_status === 'healthy'
                    ? 'text-emerald-300'
                    : source.health_status === 'degraded'
                    ? 'text-red-300'
                    : source.health_status === 'paused'
                    ? 'text-gray-500'
                    : 'text-amber-300';
                return `
                    <div class="flex flex-col sm:flex-row sm:items-center gap-3 px-4 py-3">
                        <label class="flex items-center gap-3 min-w-0 sm:flex-1 cursor-pointer">
                            <input type="checkbox" data-radar-source-id="${escapeAdminHTML(source.id)}" ${source.is_enabled ? 'checked' : ''} class="w-4 h-4 accent-[#5EA6B0]">
                            <span class="min-w-0">
                                <span class="block text-sm font-bold text-white">${escapeAdminHTML(source.organization || source.source_name)}</span>
                                <span class="block text-xs text-gray-500 truncate">${escapeAdminHTML(source.feed_or_api_url || '')}</span>
                            </span>
                        </label>
                        <div class="sm:text-right text-xs">
                            <div class="${healthClass}">${escapeAdminHTML(source.health_status || 'unverified')} · ${Number(source.last_item_count) || 0} ítems</div>
                            <div class="text-gray-500 mt-1">${escapeAdminHTML(formatRadarTimestamp(source.last_success_at || source.last_polled_at))}</div>
                            ${source.last_error ? `<div class="text-red-300 mt-1 max-w-md sm:ml-auto">${escapeAdminHTML(source.last_error)}</div>` : ''}
                        </div>
                    </div>`;
            }).join('');

            list.querySelectorAll('[data-radar-source-id]').forEach(input => {
                input.addEventListener('change', () => window.setRadarSourceEnabled(input.dataset.radarSourceId, input.checked, input));
            });
        }

        function renderRadarRuns(runs) {
            const runList = Array.isArray(runs) ? runs : [];
            const latest = runList[0];
            document.getElementById('radar-last-run').textContent = latest
                ? `Última: ${radarRunStatusLabel(latest.status)} · ${formatRadarTimestamp(latest.finished_at || latest.created_at)}`
                : 'Sin ejecuciones';
            document.getElementById('radar-runs').innerHTML = latest
                ? `<span class="text-gray-400">Última ejecución</span> · ${Number(latest.sources_succeeded) || 0}/${Number(latest.sources_considered) || 0} fuentes · ${Number(latest.candidates_created) || 0} nuevos · ${Number(latest.candidates_deduplicated) || 0} repetidos${latest.error_summary ? ` · <span class="text-red-300">${escapeAdminHTML(latest.error_summary)}</span>` : ''}`
                : 'Aún no hay ejecuciones registradas.';
        }

        window.loadRadarSources = async function() {
            const list = document.getElementById('radar-source-list');
            list.innerHTML = '<div class="px-4 py-4 text-gray-500"><i data-lucide="loader-circle" class="w-4 h-4 animate-spin"></i></div>';
            lucide.createIcons();
            try {
                const [sources, runs] = await Promise.all([
                    radarRequest('?view=sources'),
                    radarRequest('?view=runs')
                ]);
                radarSourcesLoaded = true;
                renderRadarSources(sources);
                renderRadarRuns(runs);
            } catch (error) {
                console.error('AI Radar sources error', error);
                list.innerHTML = `<div class="px-4 py-4 text-sm text-red-300">${escapeAdminHTML(error.message)}</div>`;
            }
            lucide.createIcons();
        }

        window.toggleRadarSources = async function() {
            const panel = document.getElementById('radar-sources-panel');
            const button = document.getElementById('radar-sources-btn');
            const opening = panel.classList.contains('hidden');
            panel.classList.toggle('hidden', !opening);
            button.setAttribute('aria-expanded', String(opening));
            if (opening && !radarSourcesLoaded) await window.loadRadarSources();
        }

        window.setRadarSourceEnabled = async function(sourceId, enabled, input) {
            input.disabled = true;
            try {
                await radarRequest('', {
                    method: 'POST',
                    body: JSON.stringify({ action: 'set_source_enabled', source_id: sourceId, enabled })
                });
                await window.loadRadarSources();
            } catch (error) {
                console.error('AI Radar source update error', error);
                input.checked = !enabled;
                alert(error.message);
            } finally {
                input.disabled = false;
            }
        }

        window.runRadarIngestion = async function() {
            const token = sessionStorage.getItem('adminToken');
            if (!token || token.split('.').length !== 3) return window.logout();
            const button = document.getElementById('radar-run-btn');
            const result = document.getElementById('radar-run-result');
            const original = button.innerHTML;
            button.disabled = true;
            button.innerHTML = '<i data-lucide="loader-circle" class="w-4 h-4 animate-spin"></i> Analizando';
            result.textContent = 'Leyendo RSS y evaluando novedades…';
            lucide.createIcons();

            try {
                const response = await fetch(`${SUPA_URL}/functions/v1/ai-radar-ingest`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'apikey': SUPA_KEY,
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ max_items_per_source: 5 })
                });
                const data = await response.json().catch(() => ({}));
                if (response.status === 401) window.logout();
                if (!response.ok) throw new Error(data.error || `Error de ingesta (${response.status})`);
                result.textContent = `${radarRunStatusLabel(data.status)} · ${Number(data.candidates_created) || 0} nuevos · ${Number(data.candidates_deduplicated) || 0} repetidos`;
                radarSourcesLoaded = false;
                await Promise.all([window.loadRadarQueue(), window.loadRadarSources()]);
            } catch (error) {
                console.error('AI Radar ingestion error', error);
                result.textContent = error.message;
            } finally {
                button.disabled = false;
                button.innerHTML = original;
                lucide.createIcons();
            }
        }

        window.setAdminView = async function(view) {
            const isRadar = view === 'radar';
            const articlesPanel = document.getElementById('articles-panel');
            const radarPanel = document.getElementById('radar-panel');
            const articleTab = document.getElementById('admin-tab-articles');
            const radarTab = document.getElementById('admin-tab-radar');

            articlesPanel.classList.toggle('hidden', isRadar);
            articlesPanel.classList.toggle('flex', !isRadar);
            radarPanel.classList.toggle('hidden', !isRadar);
            radarPanel.classList.toggle('flex', isRadar);
            articleTab.setAttribute('aria-selected', String(!isRadar));
            radarTab.setAttribute('aria-selected', String(isRadar));
            articleTab.className = isRadar
                ? 'px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors'
                : 'px-4 py-2 rounded-md bg-[#5EA6B0] text-black text-sm font-bold flex items-center gap-2 transition-colors';
            radarTab.className = isRadar
                ? 'px-4 py-2 rounded-md bg-[#5EA6B0] text-black text-sm font-bold flex items-center gap-2 transition-colors'
                : 'px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm font-bold flex items-center gap-2 transition-colors';
            document.getElementById('dashboard-title').textContent = isRadar ? 'AI Radar Editorial' : 'Editor de Artículos';

            if (isRadar && !radarQueueLoaded) await window.loadRadarQueue();
        }

        function renderRadarCounts(counts) {
            const order = ['suggested', 'needs_review', 'approved', 'published'];
            document.getElementById('radar-counts').textContent = order
                .map(status => `${radarStatusLabel(status)}: ${counts[status] || 0}`)
                .join(' · ');
        }

        function renderRadarQueue(items) {
            const queue = document.getElementById('radar-queue');
            if (!items.length) {
                queue.innerHTML = '<div class="h-full min-h-48 flex items-center justify-center text-sm text-gray-500 p-6 text-center">No hay sugerencias en este estado.</div>';
                return;
            }

            queue.innerHTML = items.map(item => {
                const source = item.source?.organization || item.source?.source_name || 'Fuente sin nombre';
                const active = currentRadarCandidate?.id === item.id;
                return `
                    <button type="button" data-radar-id="${escapeAdminHTML(item.id)}" class="w-full text-left p-4 mb-1 rounded-lg border ${active ? 'border-[#5EA6B0] bg-[#5EA6B0]/10' : 'border-transparent hover:border-white/10 hover:bg-white/[0.03]'} transition-colors">
                        <div class="flex items-start gap-3">
                            <span class="w-11 h-11 shrink-0 rounded-md bg-[#141619] border border-white/10 flex items-center justify-center text-sm font-bold tabular-nums ${item.passes_research_threshold ? 'text-[#88d6e0]' : 'text-amber-300'}">${Number(item.score_total) || 0}</span>
                            <span class="min-w-0 flex-1">
                                <span class="block text-sm font-bold text-white leading-snug">${escapeAdminHTML(item.source_title)}</span>
                                ${item.suggested_headline && item.suggested_headline !== item.source_title ? `<span class="block mt-1 text-xs text-gray-400 leading-snug">${escapeAdminHTML(item.suggested_headline)}</span>` : ''}
                                <span class="block mt-2 text-xs text-gray-500 truncate">${escapeAdminHTML(source)} · ${escapeAdminHTML(formatRadarDate(item.source_published_at || item.discovered_at))}</span>
                            </span>
                        </div>
                    </button>`;
            }).join('');

            queue.querySelectorAll('[data-radar-id]').forEach(button => {
                button.addEventListener('click', () => window.selectRadarCandidate(button.dataset.radarId));
            });
        }

        window.loadRadarQueue = async function() {
            const queue = document.getElementById('radar-queue');
            queue.innerHTML = '<div class="h-full min-h-48 flex items-center justify-center text-gray-500"><i data-lucide="loader-circle" class="w-5 h-5 animate-spin"></i></div>';
            lucide.createIcons();

            try {
                const status = document.getElementById('radar-status-filter').value;
                const data = await radarRequest(`?view=queue&status=${encodeURIComponent(status)}&limit=100`);
                radarQueueLoaded = true;
                renderRadarCounts(data.counts || {});
                renderRadarQueue(data.items || []);
                lucide.createIcons();
            } catch (error) {
                console.error('AI Radar queue error', error);
                queue.innerHTML = `<div class="p-6 text-sm text-red-300">${escapeAdminHTML(error.message)}</div>`;
            }
        }

        function setRadarField(id, value) {
            document.getElementById(id).value = value || '';
        }

        function updateRadarActions(candidate) {
            const editable = ['suggested', 'needs_review', 'approved'].includes(candidate.status);
            document.getElementById('radar-save-btn').classList.toggle('hidden', !editable);
            document.getElementById('radar-return-btn').classList.toggle('hidden', !['suggested', 'approved', 'rejected', 'archived', 'failed'].includes(candidate.status));
            document.getElementById('radar-reject-btn').classList.toggle('hidden', !['suggested', 'needs_review', 'approved'].includes(candidate.status));
            document.getElementById('radar-approve-btn').classList.toggle('hidden', !['suggested', 'needs_review'].includes(candidate.status));
            document.getElementById('radar-publish-btn').classList.toggle('hidden', candidate.status !== 'approved');
        }

        function renderRadarDetail(detail) {
            const candidate = detail.candidate;
            const source = detail.source || {};
            currentRadarCandidate = candidate;
            document.getElementById('radar-empty').classList.add('hidden');
            document.getElementById('radar-detail').classList.remove('hidden');
            document.getElementById('radar-detail-status').textContent = radarStatusLabel(candidate.status);
            const threshold = document.getElementById('radar-detail-threshold');
            threshold.textContent = candidate.passes_research_threshold ? 'Cumple umbral' : 'Bajo umbral';
            threshold.className = `text-xs font-bold ${candidate.passes_research_threshold ? 'text-emerald-300' : 'text-amber-300'}`;
            document.getElementById('radar-detail-total').textContent = `${candidate.score_total || 0}/100`;
            document.getElementById('radar-detail-source').textContent = `${source.organization || source.source_name || 'Fuente'} · ${formatRadarDate(candidate.source_published_at)}`;
            document.getElementById('radar-detail-source-link').href = candidate.canonical_url;
            document.getElementById('radar-source-title').textContent = candidate.source_title || '';
            document.getElementById('radar-source-excerpt').textContent = candidate.source_excerpt || 'Sin extracto disponible en el feed.';

            const scores = [
                ['Evidencia', candidate.evidence_score, 25],
                ['Autoridad', candidate.authority_score, 20],
                ['Innovación', candidate.innovation_score, 20],
                ['Rasika', candidate.rasika_alignment_score, 20],
                ['Práctica', candidate.practical_relevance_score, 10],
                ['Frescura', candidate.freshness_score, 5]
            ];
            document.getElementById('radar-score-grid').innerHTML = scores.map(([label, value, max]) => `
                <div class="bg-[#141619] border border-white/10 rounded-md p-2 text-center">
                    <div class="text-sm font-bold text-white tabular-nums">${Number(value) || 0}<span class="text-gray-600">/${max}</span></div>
                    <div class="text-[10px] text-gray-500 mt-1">${label}</div>
                </div>`).join('');

            setRadarField('radar-headline', candidate.suggested_headline || candidate.source_title);
            setRadarField('radar-summary', candidate.editorial_summary);
            setRadarField('radar-why', candidate.why_it_matters);
            setRadarField('radar-parallelism', candidate.rasika_parallelism);
            setRadarField('radar-linkedin', candidate.linkedin_copy);
            setRadarField('radar-thumbnail-prompt', candidate.thumbnail_prompt);
            setRadarField('radar-review-notes', candidate.review_notes);
            updateRadarActions(candidate);
            lucide.createIcons();
        }

        window.selectRadarCandidate = async function(id) {
            if (!/^[0-9a-f-]{36}$/i.test(id || '')) return;
            document.getElementById('radar-empty').classList.remove('hidden');
            document.getElementById('radar-empty').innerHTML = '<i data-lucide="loader-circle" class="w-6 h-6 animate-spin text-[#5EA6B0]"></i>';
            document.getElementById('radar-detail').classList.add('hidden');
            lucide.createIcons();

            try {
                const detail = await radarRequest(`?view=detail&id=${encodeURIComponent(id)}`);
                renderRadarDetail(detail);
                await window.loadRadarQueue();
            } catch (error) {
                console.error('AI Radar detail error', error);
                document.getElementById('radar-empty').innerHTML = `<p class="text-sm text-red-300">${escapeAdminHTML(error.message)}</p>`;
            }
        }

        function radarDraftPayload() {
            return {
                action: 'update_draft',
                candidate_id: currentRadarCandidate.id,
                suggested_headline: document.getElementById('radar-headline').value,
                editorial_summary: document.getElementById('radar-summary').value,
                why_it_matters: document.getElementById('radar-why').value,
                rasika_parallelism: document.getElementById('radar-parallelism').value,
                linkedin_copy: document.getElementById('radar-linkedin').value,
                thumbnail_prompt: document.getElementById('radar-thumbnail-prompt').value,
                notes: document.getElementById('radar-review-notes').value
            };
        }

        window.saveRadarDraft = async function(silent = false) {
            if (!currentRadarCandidate) return;
            const button = document.getElementById('radar-save-btn');
            const original = button.innerHTML;
            button.disabled = true;
            button.innerHTML = '<i data-lucide="loader-circle" class="w-4 h-4 animate-spin"></i> Guardando';
            lucide.createIcons();

            try {
                const candidate = await radarRequest('', {
                    method: 'POST',
                    body: JSON.stringify(radarDraftPayload())
                });
                currentRadarCandidate = candidate || currentRadarCandidate;
                if (!silent) alert('Borrador editorial guardado.');
                return true;
            } catch (error) {
                console.error('AI Radar save error', error);
                alert(error.message);
                return false;
            } finally {
                button.disabled = false;
                button.innerHTML = original;
                lucide.createIcons();
            }
        }

        window.reviewRadarCandidate = async function(status) {
            if (!currentRadarCandidate) return;
            const notes = document.getElementById('radar-review-notes').value.trim();
            if (status === 'approved' && !currentRadarCandidate.passes_research_threshold && !notes) {
                return alert('Agrega una nota para justificar la aprobación bajo el umbral de investigación.');
            }

            if (['suggested', 'needs_review', 'approved'].includes(currentRadarCandidate.status)) {
                const saved = await window.saveRadarDraft(true);
                if (!saved) return;
            }

            try {
                await radarRequest('', {
                    method: 'POST',
                    body: JSON.stringify({
                        action: 'review',
                        candidate_id: currentRadarCandidate.id,
                        status,
                        notes
                    })
                });
                currentRadarCandidate = null;
                document.getElementById('radar-detail').classList.add('hidden');
                document.getElementById('radar-empty').classList.remove('hidden');
                document.getElementById('radar-empty').innerHTML = '<i data-lucide="check-circle-2" class="w-8 h-8 mb-3 text-[#5EA6B0]"></i><p class="text-sm text-gray-400">Revisión registrada.</p>';
                await window.loadRadarQueue();
            } catch (error) {
                console.error('AI Radar review error', error);
                alert(error.message);
            }
        }

        window.publishRadarCandidate = async function() {
            if (!currentRadarCandidate || currentRadarCandidate.status !== 'approved') return;
            const confirmed = window.confirm('¿Publicar esta síntesis aprobada en el Blog? Esta acción crea una entrada visible.');
            if (!confirmed) return;

            const button = document.getElementById('radar-publish-btn');
            const original = button.innerHTML;
            button.disabled = true;
            button.innerHTML = '<i data-lucide="loader-circle" class="w-4 h-4 animate-spin"></i> Publicando';
            lucide.createIcons();

            try {
                const result = await radarRequest('', {
                    method: 'POST',
                    body: JSON.stringify({
                        action: 'publish',
                        candidate_id: currentRadarCandidate.id,
                        notes: document.getElementById('radar-review-notes').value
                    })
                });
                await loadArticlesList();
                window.location.href = result.blog_url || '/blog/';
            } catch (error) {
                console.error('AI Radar publish error', error);
                alert(error.message);
            } finally {
                button.disabled = false;
                button.innerHTML = original;
                lucide.createIcons();
            }
        }

        async function loadArticlesList() {
            const token = sessionStorage.getItem('adminToken');
            try {
                const res = await fetch(`${SUPA_URL}/rest/v1/blog_posts?select=id,title,type&order=created_at.desc`, {
                    headers: { 'apikey': SUPA_KEY, 'Authorization': `Bearer ${token}` }
                });
                if(res.ok) {
                    const data = await res.json();
                    const selector = document.getElementById('edit-selector');
                    selector.innerHTML = '<option value="">✨ Crear Nuevo Artículo...</option>';
                    data.forEach(post => {
                        const icon = post.type === 'agent' ? '🤖' : '📝';
                        selector.innerHTML += `<option value="${post.id}">${icon} ${post.title}</option>`;
                    });
                }
            } catch (e) { console.error("Error loading articles list", e); }
        }

        window.handleEditSelection = async function(id) {
            currentEditingId = id || null;
            const publishBtn = document.getElementById('publish-btn');
            
            if(!id) {
                document.getElementById('post-title').value = '';
                document.getElementById('post-author').value = '';
                document.getElementById('post-category').value = '';
                document.getElementById('post-cover').value = '';
                quill.root.innerHTML = '';
                publishBtn.innerHTML = '<i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora';
                lucide.createIcons();
                return;
            }

            publishBtn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i> Cargando datos...';
            lucide.createIcons();

            const token = sessionStorage.getItem('adminToken');
            try {
                const res = await fetch(`${SUPA_URL}/rest/v1/blog_posts?id=eq.${id}`, {
                    headers: { 'apikey': SUPA_KEY, 'Authorization': `Bearer ${token}` }
                });
                
                if (!res.ok) throw new Error("Fallo en la petición a Supabase");
                
                const data = await res.json();
                
                if(data && data[0]) {
                    const post = data[0];
                    document.getElementById('post-type').value = post.type || 'human';
                    document.getElementById('post-title').value = post.title || '';
                    document.getElementById('post-author').value = post.author || '';
                    document.getElementById('post-category').value = post.category || '';
                    document.getElementById('post-cover').value = post.cover_image || '';
                    quill.root.innerHTML = post.content_html || '';
                    
                    publishBtn.innerHTML = '<i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar Artículo';
                } else {
                    alert("El artículo fue eliminado o no existe.");
                    publishBtn.innerHTML = '<i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora';
                }
            } catch(e) { 
                console.error("Error loading article details", e); 
                alert("Error de conexión al cargar los detalles del artículo.");
                publishBtn.innerHTML = '<i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora';
            }
            lucide.createIcons();
        }

        window.saveDraft = function() {
            const draft = {
                type: document.getElementById('post-type').value,
                title: document.getElementById('post-title').value,
                author: document.getElementById('post-author').value,
                category: document.getElementById('post-category').value,
                cover_image: document.getElementById('post-cover').value,
                content: quill.root.innerHTML,
                editingId: currentEditingId 
            };
            localStorage.setItem('rasika_blog_draft', JSON.stringify(draft));
            
            const saveBtn = document.getElementById('save-btn');
            const originalHTML = saveBtn.innerHTML;
            saveBtn.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-green-400"></i> Guardado';
            lucide.createIcons();
            setTimeout(() => { saveBtn.innerHTML = originalHTML; lucide.createIcons(); }, 2000);
        }

        window.loadDraft = function() {
            const saved = localStorage.getItem('rasika_blog_draft');
            if(saved) {
                const draft = JSON.parse(saved);
                document.getElementById('post-type').value = draft.type || 'human';
                document.getElementById('post-title').value = draft.title || '';
                document.getElementById('post-author').value = draft.author || '';
                document.getElementById('post-category').value = draft.category || '';
                document.getElementById('post-cover').value = draft.cover_image || '';
                if(draft.content && draft.content !== '<p><br></p>') quill.root.innerHTML = draft.content;
                
                if(draft.editingId) {
                    currentEditingId = draft.editingId;
                    document.getElementById('edit-selector').value = draft.editingId;
                    document.getElementById('publish-btn').innerHTML = '<i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar Artículo';
                    lucide.createIcons();
                }
            }
        }

        window.openPreview = function() {
            const htmlContent = quill.root.innerHTML;
            const title = document.getElementById('post-title').value || 'Sin Título';
            const author = document.getElementById('post-author').value || 'Autor';
            const cover = document.getElementById('post-cover').value;
            
            let coverSrc = cover;
            if (cover && cover.startsWith('/')) {
                coverSrc = window.location.origin + cover;
            }
            
            const processedHtml = htmlContent.replace(/src="\//g, 'src="' + window.location.origin + '/');

            const coverHtml = coverSrc 
                ? `<img src="${coverSrc}" style="width:100%; height:300px; object-fit:cover; border-radius:1rem; margin-bottom:2rem;">` 
                : '';

            const htmlString = `
                <!DOCTYPE html>
                <html>
                <head>
                    <meta charset="UTF-8">
                    <title>Vista Previa: ${title}</title>
                    <link rel="preconnect" href="https://fonts.googleapis.com">
                    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
                    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
                    <style>
                        body { background: #141619; color: #D1D5DB; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-weight: 400; line-height: 1.8; margin: 0; padding: 3rem 1.5rem; }
                        .container { max-width: 800px; margin: 0 auto; }
                        h1, h2, h3, h4, h5, h6 { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #fff; font-weight: 700; }
                        h1 { font-size: 2.5rem; margin-bottom: 0.5rem; letter-spacing: -0.025em; }
                        h2 { font-size: 1.75rem; margin-top: 2em; margin-bottom: 1em; letter-spacing: -0.025em; }
                        h3 { font-size: 1.25rem; margin-top: 1.5em; margin-bottom: 0.75em; }
                        .meta { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #9CA3AF; font-size: 0.9rem; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
                        blockquote { border-left: 4px solid #5EA6B0; padding-left: 1.25rem; font-style: italic; color: #9CA3AF; margin: 2.5em 0; font-size: 1.1rem; }
                        strong { color: #fff; font-weight: 600; }
                        
                        /* Previsualización idéntica al CMS Separando Videos de Imagenes */
                        .content iframe { width: 100%; height: auto; aspect-ratio: 16/9; border-radius: 1rem; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); background-color: #0a0c0e; margin: 2rem 0; display: block; }
                        .content img { width: 100%; height: auto; border-radius: 1rem; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin: 2rem 0; display: block; }
                        
                        .ql-align-left iframe, .ql-align-left img { width: 50%; margin: 2rem auto 2rem 0; }
                        .ql-align-center iframe, .ql-align-center img { width: 75%; margin: 2rem auto; }
                        .ql-align-right iframe, .ql-align-right img { width: 50%; margin: 2rem 0 2rem auto; }
                        .ql-align-center { text-align: center; }
                        .ql-align-right { text-align: right; }
                        .ql-align-justify { text-align: justify; }
                    </style>
                </head>
                <body>
                    <div class="container">
                        ${coverHtml}
                        <h1>${title}</h1>
                        <div class="meta">Por ${author} • Modo Vista Previa</div>
                        <div class="content">${processedHtml}</div>
                    </div>
                </body>
                </html>
            `;
            
            const blob = new Blob([htmlString], { type: 'text/html' });
            const url = URL.createObjectURL(blob);
            window.open(url, '_blank');
        };

        window.publishPost = async function() {
            const token = sessionStorage.getItem('adminToken');
            
            if(!token || token === 'undefined' || token.split('.').length !== 3) {
                window.logout();
                return alert("Tu sesión se corrompió o expiró. Por favor, ingresa nuevamente.");
            }
            
            const btn = document.getElementById('publish-btn');
            btn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i> Procesando...';
            lucide.createIcons();

            const type = document.getElementById('post-type').value;
            const title = document.getElementById('post-title').value;
            const author = document.getElementById('post-author').value;
            const category = document.getElementById('post-category').value;
            const cover = document.getElementById('post-cover').value;
            const htmlContent = quill.root.innerHTML;
            
            const payload = {
                type: type,
                title: title,
                author: author,
                category: category,
                cover_image: cover || null,
                icon: type === 'agent' ? 'bot' : 'user',
                content_html: htmlContent
            };

            const endpoint = currentEditingId 
                ? `${SUPA_URL}/rest/v1/blog_posts?id=eq.${currentEditingId}` 
                : `${SUPA_URL}/rest/v1/blog_posts`;
                
            const httpMethod = currentEditingId ? 'PATCH' : 'POST';

            try {
                const res = await fetch(endpoint, {
                    method: httpMethod,
                    headers: {
                        'Content-Type': 'application/json',
                        'apikey': SUPA_KEY,
                        'Authorization': `Bearer ${token}`,
                        'Prefer': 'return=representation'
                    },
                    body: JSON.stringify(payload)
                });

                if(res.ok) {
                    const responseData = await res.json();
                    const savedArticleId = responseData[0]?.id || currentEditingId; 
                    
                    alert(`¡Artículo ${currentEditingId ? 'actualizado' : 'publicado'} exitosamente!`);
                    
                    localStorage.removeItem('rasika_blog_draft'); 
                    window.location.href = '/blog?article=' + savedArticleId;
                    
                } else {
                    const errData = await res.json();
                    alert("Error. Revisa los permisos de tu base de datos: " + (errData.message || "Desconocido"));
                }
            } catch (e) {
                console.error(e);
                alert("Error de red.");
            } finally {
                btn.innerHTML = currentEditingId ? '<i data-lucide="refresh-cw" class="w-4 h-4"></i> Actualizar Artículo' : '<i data-lucide="send" class="w-4 h-4"></i> Publicar Ahora';
                lucide.createIcons();
            }
        }
    </script>
</body>
</html>
