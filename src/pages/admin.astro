    <script is:inline>
        if (window.lucide) lucide.createIcons();
        
        const config = document.getElementById('admin-config');
        const SUPA_URL = config.getAttribute('data-url').replace(/\/$/, '');
        const SUPA_KEY = config.getAttribute('data-key');
        
        let currentEditingId = null;
        let currentEditingSlug = null;
        let currentEditingPublishedAt = null;
        let currentRadarCandidate = null;
        let radarQueueLoaded = false;
        let radarSourcesLoaded = false;
        let openRadarSourceId = null;
        let radarSourceCatalog = [];
        let radarStatusFilter = 'suggested';
        let marketingOverview = null;
        let marketingOverviewLoaded = false;
        let marketingContactsLoaded = false;
        let marketingPeriodDays = 30;
        let pendingCsvImport = null;
        let contactsSearchTimer = null;

        document.addEventListener('DOMContentLoaded', async () => {
            initializeRadarStatusControl();
            initializeMarketingControls();
            const token = sessionStorage.getItem('adminToken');
            if (token && token !== 'undefined' && token.split('.').length === 3) {
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('dashboard-screen').classList.replace('hidden', 'flex');
                await window.setAdminView('overview');
            } else {
                sessionStorage.removeItem('adminToken');
            }
        });

        // --- CUSTOM QUILL IMAGE HANDLER (CONNECTS TO UPLOAD.PHP) ---
        function customImageHandler() {
            const token = document.getElementById('php-token').value;
            if (!token) {
                alert("Por favor, ingresa el Token de Subida (PHP) en la esquina superior derecha.");
                return;
            }

            const input = document.createElement('input');
            input.setAttribute('type', 'file');
            input.setAttribute('accept', 'image/*');
            input.click();

            input.onchange = async () => {
                const file = input.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('file', file);

                try {
                    // Send to your SiteGround upload.php
                    const res = await fetch('/upload.php', {
                        method: 'POST',
                        headers: {
                            'X-Upload-Token': token,
                            'X-Upload-Path': 'blog' // Tell PHP to save in /images/blog/
                        },
                        body: formData
                    });

                    const data = await res.json();
                    
                    if (res.ok && data.success) {
                        // Insert the live image URL securely generated by the server
                        const range = quill.getSelection(true);
                        quill.insertEmbed(range.index, 'image', data.url);
                        quill.setSelection(range.index + 1);
                    } else {
                        alert("Error del servidor: " + (data.error || "Desconocido"));
                    }
                } catch (err) {
                    console.error("Upload error:", err);
                    alert("Error de conexión con upload.php.");
                }
            };
        }

        const editorElement = document.getElementById('editor');
        var quill;
        if (window.Quill) {
            quill = new Quill('#editor', {
                theme: 'snow',
                placeholder: 'Comienza a escribir aquí...',
                modules: {
                    toolbar: {
                        container: [
                            [{ 'header': [2, 3, false] }],
                            ['bold', 'italic', 'underline', 'blockquote'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            [{ 'align': '' }, { 'align': 'center' }, { 'align': 'right' }, { 'align': 'justify' }],
                            ['link', 'video', 'image'],
                            ['clean']
                        ],
                        handlers: { image: customImageHandler }
                    }
                }
            });
        } else {
            editorElement.contentEditable = 'true';
            editorElement.setAttribute('role', 'textbox');
            editorElement.setAttribute('aria-multiline', 'true');
            editorElement.className = 'min-h-[400px] bg-[#141619] border border-white/10 rounded-lg p-4 text-gray-200 outline-none focus:border-[#5EA6B0]';
            quill = {
                root: editorElement,
                getText: () => editorElement.innerText || '',
                getSelection: () => ({ index: 0 }),
                insertEmbed: () => {},
                setSelection: () => {}
            };
        }

        // --- COVER IMAGE UPLOADER ---
        window.uploadCoverImage = function() {
            const token = document.getElementById('php-token').value;
            if (!token) return alert("Por favor, ingresa el Token de Subida (PHP) en la esquina superior derecha.");

            const input = document.createElement('input');
            input.setAttribute('type', 'file');
            input.setAttribute('accept', 'image/*');
            input.click();

            input.onchange = async () => {
                const file = input.files[0];
                if (!file) return;

                document.getElementById('post-cover').value = "Subiendo...";

                const formData = new FormData();
                formData.append('file', file);

                try {
                    const res = await fetch('/upload.php', {
                        method: 'POST',
                        headers: {
                            'X-Upload-Token': token,
                            'X-Upload-Path': 'blog'
                        },
                        body: formData
                    });

                    const data = await res.json();
                    if (res.ok && data.success) {
                        document.getElementById('post-cover').value = data.url;
                    } else {
                        document.getElementById('post-cover').value = "";
                        alert("Error del servidor: " + (data.error || "Desconocido"));
                    }
                } catch (err) {
                    console.error("Upload error:", err);
                    document.getElementById('post-cover').value = "";
                    alert("Error de conexión al subir la imagen de portada.");
                }
            };
        }

        window.handleLogin = async function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const errorEl = document.getElementById('login-error');

            try {
                const res = await fetch(`${SUPA_URL}/auth/v1/token?grant_type=password`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'apikey': SUPA_KEY },
                    body: JSON.stringify({ email, password })
                });

                const data = await res.json();
                
                if (data.error || !data.access_token) {
                    errorEl.innerText = data.error_description || data.msg || "Credenciales incorrectas.";
                    errorEl.classList.remove('hidden');
                } else {
                    sessionStorage.setItem('adminToken', data.access_token);
                    document.getElementById('login-screen').classList.add('hidden');
                    document.getElementById('dashboard-screen').classList.replace('hidden', 'flex');
                    await window.setAdminView('overview');
                }
            } catch (err) {
                console.error(err);
                errorEl.innerText = "Error de red. Revisa tu conexión o API Key.";
                errorEl.classList.remove('hidden');
            }
        }

        window.logout = function() {
            sessionStorage.removeItem('adminToken');
            currentRadarCandidate = null;
            radarQueueLoaded = false;
            radarSourcesLoaded = false;
            openRadarSourceId = null;
            radarSourceCatalog = [];
            marketingOverview = null;
            marketingOverviewLoaded = false;
            marketingContactsLoaded = false;
            pendingCsvImport = null;
            document.getElementById('dashboard-screen').classList.replace('flex', 'hidden');
            document.getElementById('login-screen').classList.remove('hidden');
            document.getElementById('password').value = '';
        }

        function escapeAdminHTML(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        async function marketingRequest(path = '', options = {}) {
            const token = sessionStorage.getItem('adminToken');
            if (!token || token.split('.').length !== 3) {
                window.logout();
                throw new Error('Tu sesión expiró. Ingresa nuevamente.');
            }
            const response = await fetch(`${SUPA_URL}/functions/v1/marketing-admin${path}`, {
                ...options,
                headers: {
                    'Content-Type': 'application/json',
                    apikey: SUPA_KEY,
                    Authorization: `Bearer ${token}`,
                    ...(options.headers || {})
                }
            });
            const result = await response.json().catch(() => ({}));
            if (response.status === 401) window.logout();
            if (!response.ok) throw new Error(result.error || `Error de marketing (${response.status})`);
            return result;
        }

        function formatMarketingNumber(value, digits = 0) {
            return new Intl.NumberFormat('es-CL', { maximumFractionDigits: digits }).format(Number(value) || 0);
        }

        function formatMarketingDuration(seconds) {
            const value = Math.max(0, Number(seconds) || 0);
            if (value < 60) return `${Math.round(value)} s`;
            return `${Math.floor(value / 60)} min ${Math.round(value % 60)} s`;
        }

        function formatMarketingDate(value) {
            if (!value) return 'Sin actividad';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Sin actividad';
            return new Intl.DateTimeFormat('es-CL', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);
        }

        function renderMetricList(id, items) {
            const container = document.getElementById(id);
            const rows = Array.isArray(items) ? items : [];
            if (!rows.length) {
                container.innerHTML = '<p class="text-sm text-gray-600 py-5">Sin datos en este periodo.</p>';
                return;
            }
            const max = Math.max(...rows.map(item => Number(item.value) || 0), 1);
            container.innerHTML = rows.map(item => `
