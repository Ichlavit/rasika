        function setRadarStatusFilter(status, { reload = true } = {}) {
            const menu = document.getElementById('radar-status-menu');
            const option = menu.querySelector(`[data-radar-status="${status}"]`);
            if (!option) return;
            radarStatusFilter = status;
            document.getElementById('radar-status-label').textContent = radarStatusFilterLabel(status);
            menu.querySelectorAll('[data-radar-status]').forEach(button => {
                const selected = button.dataset.radarStatus === status;
                button.setAttribute('aria-selected', String(selected));
                button.className = selected
                    ? 'w-full rounded-md px-3 py-2 text-left text-sm font-medium bg-[#5EA6B0] text-black'
                    : 'w-full rounded-md px-3 py-2 text-left text-sm font-medium text-gray-300 hover:bg-white/5 hover:text-white';
            });
            closeRadarStatusMenu();
            if (reload) window.loadRadarQueue();
        }

        function initializeRadarStatusControl() {
            const control = document.getElementById('radar-status-control');
            const trigger = document.getElementById('radar-status-trigger');
            const menu = document.getElementById('radar-status-menu');
            const options = [...menu.querySelectorAll('[data-radar-status]')];

            trigger.addEventListener('click', () => {
                const isOpen = !menu.classList.contains('hidden');
                if (isOpen) closeRadarStatusMenu();
                else openRadarStatusMenu();
            });
            trigger.addEventListener('keydown', event => {
                if (!['Enter', ' ', 'ArrowDown', 'ArrowUp'].includes(event.key)) return;
                event.preventDefault();
                openRadarStatusMenu({ focusSelected: true });
            });
            options.forEach((option, index) => {
                option.addEventListener('click', () => setRadarStatusFilter(option.dataset.radarStatus));
                option.addEventListener('keydown', event => {
                    if (event.key === 'Escape') {
                        event.preventDefault();
                        closeRadarStatusMenu({ focusTrigger: true });
                        return;
                    }
                    if (!['ArrowDown', 'ArrowUp', 'Home', 'End'].includes(event.key)) return;
                    event.preventDefault();
                    const nextIndex = event.key === 'Home'
                        ? 0
                        : event.key === 'End'
                        ? options.length - 1
                        : (index + (event.key === 'ArrowDown' ? 1 : -1) + options.length) % options.length;
                    options[nextIndex].focus();
                });
            });
            document.addEventListener('click', event => {
                if (!control.contains(event.target)) closeRadarStatusMenu();
            });
        }

        function formatRadarDate(value) {
            if (!value) return 'Fecha no disponible';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Fecha no disponible';
            return new Intl.DateTimeFormat('es-CL', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
            }).format(date);
        }

        async function radarRequest(path = '', options = {}) {
            const token = sessionStorage.getItem('adminToken');
            if (!token || token.split('.').length !== 3) {
                window.logout();
                throw new Error('Tu sesión expiró. Ingresa nuevamente.');
            }

            const res = await fetch(`${SUPA_URL}/functions/v1/ai-radar-admin${path}`, {
                ...options,
                headers: {
                    'Content-Type': 'application/json',
                    'apikey': SUPA_KEY,
                    'Authorization': `Bearer ${token}`,
                    ...(options.headers || {})
                }
            });
            const data = await res.json().catch(() => ({}));
            if (res.status === 401) window.logout();
            if (!res.ok) throw new Error(data.error || `Error AI Radar (${res.status})`);
            return data;
        }

