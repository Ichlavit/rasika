---
import "../../styles/global.css";
import Chatbot from "../../components/Chatbot.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import SiteAnalytics from "../../components/SiteAnalytics.astro";
import SEO from "../../components/SEO.astro";
import {
  articlePath,
  articleWordCount,
  getPublishedBlogPosts,
  type PublishedBlogPost,
} from "../../lib/blog";
import { SITE, absoluteUrl, type SeoPage } from "../../data/seo";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: PublishedBlogPost };
const path = articlePath(post.slug);
const articleUrl = absoluteUrl(path);
const imageUrl = absoluteUrl(post.cover_image || SITE.defaultImage);
const isRadar = post.type === "agent";
const publishedDate = new Date(post.published_at);
const modifiedDate = new Date(post.updated_at || post.published_at);
const displayDate = publishedDate.toLocaleDateString("es-CL", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const articleTypeLabel = isRadar ? "Radar de tendencias en EdTech" : post.category || "Rasika Insights";
const shareUrl = encodeURIComponent(articleUrl);
const shareTitle = encodeURIComponent(post.title);

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${articleUrl}#article`,
  mainEntityOfPage: articleUrl,
  headline: post.title,
  description: post.excerpt,
  image: [imageUrl],
  datePublished: publishedDate.toISOString(),
  dateModified: modifiedDate.toISOString(),
  articleSection: articleTypeLabel,
  wordCount: articleWordCount(post.content_html),
  inLanguage: SITE.language,
  author: isRadar
    ? {
        "@type": "Organization",
        name: "Rasika AI Radar",
        url: absoluteUrl("/blog/"),
      }
    : {
        "@type": "Person",
        name: post.author,
      },
  publisher: {
    "@id": absoluteUrl("/#organization"),
  },
  isPartOf: {
    "@type": "Blog",
    "@id": absoluteUrl("/blog/#blog"),
    name: "Rasika Insights",
  },
  ...(post.source_url ? { citation: post.source_url } : {}),
};

const seo: SeoPage = {
  title: `${post.title} | Rasika Insights`,
  description: post.excerpt,
  path,
  image: post.cover_image || SITE.defaultImage,
  type: "article",
  topic: articleTypeLabel,
  keywords: [
    articleTypeLabel,
    "EdTech",
    "aprendizaje digital",
    ...(isRadar ? ["IA educativa", "tendencias EdTech"] : []),
  ],
  jsonLd: [articleJsonLd],
};
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO {...seo} />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] },
            colors: {
              rasika: {
                accent: '#5EA6B0',
                dark: '#141619',
                surface: '#1E2226',
              },
            },
          },
        },
      };
    </script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        color-scheme: dark;
        --accent: #5ea6b0;
        --accent-light: #88d6e0;
        --background: #0a0c0e;
        --surface: #141619;
        --surface-raised: #1e2226;
        --muted: #9ca3af;
      }

      * { box-sizing: border-box; }
      html { background: var(--background); scroll-behavior: smooth; }
      body {
        min-height: 100vh;
        margin: 0;
        overflow-x: hidden;
        background: var(--background);
        color: #f8fafc;
        font-family: "Plus Jakarta Sans", system-ui, sans-serif;
        letter-spacing: 0;
      }

      a { color: inherit; }
      button { font: inherit; }

      .article-nav {
        position: fixed;
        z-index: 80;
        top: 0;
        right: 0;
        left: 0;
        border-bottom: 1px solid rgba(255,255,255,.07);
        background: rgba(20,22,25,.9);
        backdrop-filter: blur(18px);
      }

      .article-nav-inner {
        display: flex;
        width: min(1180px, calc(100% - 32px));
        min-height: 74px;
        margin: 0 auto;
        align-items: center;
        justify-content: space-between;
      }

      .article-logo { display: block; width: 142px; }
      .article-logo img { display: block; width: 100%; height: auto; }
      .article-nav-links { display: flex; align-items: center; gap: 28px; }
      .article-nav-links a {
        color: #d1d5db;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
      }
      .article-nav-links a:hover { color: var(--accent-light); }

      .article-hero {
        position: relative;
        display: flex;
        min-height: min(720px, 82vh);
        margin-top: 74px;
        align-items: flex-end;
        overflow: hidden;
        background: var(--surface);
      }

      .article-hero-media,
      .article-hero-scrim,
      .article-hero-fade { position: absolute; inset: 0; }
      .article-hero-media {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .article-hero-scrim { background: rgba(7,9,11,.52); }
      .article-hero-fade {
        background: linear-gradient(to bottom, rgba(10,12,14,.08), rgba(10,12,14,.56) 52%, #0a0c0e 100%);
      }

      .article-hero-inner {
        position: relative;
        z-index: 2;
        width: min(980px, calc(100% - 40px));
        margin: 0 auto;
        padding: 96px 0 72px;
      }

      .article-kicker {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 24px;
        color: var(--accent-light);
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
      }

      .article-hero h1 {
        max-width: 920px;
        margin: 0;
        font-size: clamp(42px, 6.5vw, 78px);
        font-weight: 800;
        line-height: 1.04;
        letter-spacing: 0;
        text-wrap: balance;
      }

      .article-excerpt {
        max-width: 780px;
        margin: 28px 0 0;
        color: #d1d5db;
        font-size: clamp(17px, 2vw, 21px);
        line-height: 1.65;
      }

      .article-meta {
        display: flex;
        margin-top: 32px;
        align-items: center;
        gap: 16px;
        color: #cbd5e1;
        font-size: 14px;
      }

      .article-author-mark,
      .coursementor-avatar-static {
        flex: 0 0 auto;
        width: 48px;
        height: 48px;
        border: 1px solid rgba(94,166,176,.4);
        border-radius: 50%;
        background-color: var(--surface);
      }

      .article-author-mark {
        display: grid;
        place-items: center;
        color: var(--accent-light);
      }

      .coursementor-avatar-static {
        background-image: url('/images/svg/avatar_animated.svg');
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
      }

      .article-meta strong { display: block; color: #fff; font-size: 15px; }
      .article-meta span { display: block; margin-top: 3px; color: var(--muted); }

      .article-shell {
        display: grid;
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
        padding: 72px 0 110px;
        grid-template-columns: minmax(0, 760px) 220px;
        gap: 84px;
        justify-content: center;
      }

      .article-content {
        color: #d1d5db;
        font-size: 18px;
        line-height: 1.85;
      }
      .article-content > :first-child { margin-top: 0; }
      .article-content p { margin: 0 0 1.55em; }
      .article-content h2,
      .article-content h3,
      .article-content h4 {
        margin: 2.15em 0 .75em;
        color: #fff;
        font-weight: 750;
        line-height: 1.25;
        letter-spacing: 0;
      }
      .article-content h2 { font-size: 31px; }
      .article-content h3 { font-size: 23px; }
      .article-content strong { color: #fff; font-weight: 700; }
      .article-content a {
        color: var(--accent-light);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 4px;
      }
      .article-content ul,
      .article-content ol { margin: 0 0 1.5em; padding-left: 1.5em; }
      .article-content li { margin-bottom: .6em; }
      .article-content blockquote {
        margin: 2em 0;
        padding: .25em 0 .25em 1.35em;
        border-left: 4px solid var(--accent);
        color: #cbd5e1;
        font-style: italic;
      }
      .article-content img,
      .article-content iframe {
        display: block;
        width: 100%;
        height: auto;
        margin: 2em 0;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px;
      }
      .article-content iframe { aspect-ratio: 16/9; }

      .article-content .rasika-service-bridge {
        margin: 2.25em 0;
        padding: 24px;
        border: 1px solid rgba(94,166,176,.32);
        border-left: 4px solid var(--accent);
        border-radius: 8px;
        background: rgba(94,166,176,.08);
      }
      .article-content .rasika-service-bridge h3 { margin-top: 0; }
      .article-content .rasika-service-bridge p:last-child { margin-bottom: 0; }

      .article-share {
        position: sticky;
        top: 112px;
        display: flex;
        height: fit-content;
        flex-direction: column;
        gap: 12px;
      }
      .article-share-label {
        margin-bottom: 4px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
      }
      .article-share a,
      .article-share button {
        display: flex;
        min-height: 44px;
        padding: 0 14px;
        align-items: center;
        gap: 10px;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 8px;
        background: var(--surface);
        color: #e5e7eb;
        cursor: pointer;
        font-size: 13px;
        font-weight: 650;
        text-decoration: none;
      }
      .article-share a:hover,
      .article-share button:hover { border-color: var(--accent); color: var(--accent-light); }

      .article-mentor-cta {
        display: grid;
        margin-top: 64px;
        padding: 30px;
        grid-template-columns: 58px 1fr auto;
        align-items: center;
        gap: 22px;
        border: 1px solid rgba(94,166,176,.32);
        border-radius: 8px;
        background: var(--surface-raised);
      }
      .article-mentor-cta .coursementor-avatar-static { width: 58px; height: 58px; }
      .article-mentor-cta h2 { margin: 0 0 7px; font-size: 21px; }
      .article-mentor-cta p { margin: 0; color: var(--muted); font-size: 14px; line-height: 1.6; }
      .article-mentor-cta button {
        min-height: 46px;
        padding: 0 18px;
        border: 0;
        border-radius: 8px;
        background: var(--accent-light);
        color: #081012;
        cursor: pointer;
        font-weight: 800;
      }
      .article-mentor-cta button:hover { background: #fff; }

      .article-footer {
        border-top: 1px solid rgba(255,255,255,.07);
        background: var(--surface);
      }
      .article-footer-inner {
        display: flex;
        width: min(1120px, calc(100% - 40px));
        min-height: 110px;
        margin: 0 auto;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        color: var(--muted);
        font-size: 13px;
      }
      .article-footer a { color: #d1d5db; text-decoration: none; }

      .mobile-menu-button { display: none; }

      @media (max-width: 800px) {
        .article-nav-links { display: none; }
        .mobile-menu-button {
          display: grid;
          width: 44px;
          height: 44px;
          place-items: center;
          border: 0;
          background: transparent;
          color: #fff;
        }
        .article-hero { min-height: 690px; }
        .article-hero-inner { padding-bottom: 52px; }
        .article-hero h1 { font-size: clamp(38px, 11vw, 58px); }
        .article-shell { display: block; padding-top: 52px; }
        .article-share {
          position: static;
          display: grid;
          margin-top: 52px;
          grid-template-columns: repeat(2, minmax(0,1fr));
        }
        .article-share-label { grid-column: 1 / -1; }
        .article-mentor-cta {
          grid-template-columns: 52px 1fr;
        }
        .article-mentor-cta .coursementor-avatar-static { width: 52px; height: 52px; }
        .article-mentor-cta button { grid-column: 1 / -1; width: 100%; }
        .article-footer-inner { min-height: 150px; flex-direction: column; justify-content: center; text-align: center; }
      }
    </style>
  </head>
  <body>
    <header class="article-nav">
      <div class="article-nav-inner">
        <a class="article-logo" href="/" aria-label="Rasika Producciones">
          <img src="/images/svg/rasika_logo.svg" alt="Rasika Producciones" />
        </a>
        <nav class="article-nav-links" aria-label="Navegación principal">
          <a href="/demos/">Demos</a>
          <a href="/lms/">LMS & Bots</a>
          <a href="/clients/">Clientes</a>
          <a href="/pricing/">Precios</a>
          <a href="/blog/" aria-current="page">Blog</a>
        </nav>
        <button class="mobile-menu-button" type="button" aria-label="Abrir navegación" onclick="window.location.href='/blog/'">
          <i data-lucide="arrow-left"></i>
        </button>
      </div>
    </header>

    <main>
      <article>
        <header class="article-hero">
          {post.cover_image && <img class="article-hero-media" src={post.cover_image} alt="" fetchpriority="high" />}
          <div class="article-hero-scrim"></div>
          <div class="article-hero-fade"></div>
          <div class="article-hero-inner">
            <div class="article-kicker">
              <i data-lucide={isRadar ? "radar" : "book-open"}></i>
              <span>{articleTypeLabel}</span>
              {isRadar && <span>(potenciado por IA)</span>}
            </div>
            <h1>{post.title}</h1>
            <p class="article-excerpt">{post.excerpt}</p>
            <div class="article-meta">
              <span class="article-author-mark">
                <i data-lucide={isRadar ? "radar" : "user"}></i>
              </span>
              <div>
                <strong>{post.author}</strong>
                <span>{displayDate} · {post.read_time || "5 min de lectura"}</span>
              </div>
            </div>
          </div>
        </header>

        <div class="article-shell">
          <div>
            <div class="article-content" set:html={post.content_html}></div>

            <section class="article-mentor-cta" aria-labelledby="article-mentor-title">
              <span class="coursementor-avatar-static" role="img" aria-label="CourseMentor"></span>
              <div>
                <h2 id="article-mentor-title">¿Cómo se conecta esto con tu desafío?</h2>
                <p>Conversa sobre las ideas del artículo y cómo podrían aplicarse a un desafío real de tu organización.</p>
              </div>
              <button id="article-mentor-button" type="button">Explorar con CourseMentor</button>
            </section>
          </div>

          <aside class="article-share" aria-label="Compartir artículo">
            <div class="article-share-label">Compartir</div>
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrl}&title=${shareTitle}`} target="_blank" rel="noopener noreferrer">
              <i data-lucide="linkedin"></i><span>LinkedIn</span>
            </a>
            <a href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer">
              <i data-lucide="message-circle"></i><span>X</span>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer">
              <i data-lucide="facebook"></i><span>Facebook</span>
            </a>
            <button id="copy-article-link" type="button" data-url={articleUrl}>
              <i data-lucide="link"></i><span>Copiar enlace</span>
            </button>
            <a href="/blog/">
              <i data-lucide="arrow-left"></i><span>Volver al Blog</span>
            </a>
          </aside>
        </div>
        <div class="article-shell" style="display:block;padding-top:0;">
          <NewsletterSignup />
        </div>
      </article>
    </main>

    <footer class="article-footer">
      <div class="article-footer-inner">
        <span>© 2026 Rasika Producciones. Todos los derechos reservados.</span>
        <a href="/blog/">Rasika Insights</a>
      </div>
    </footer>

    <SiteAnalytics articleSlug={post.slug} />
    <Chatbot />

    <script
      is:inline
      define:vars={{
        articleId: post.id,
        articleTitle: post.title,
        articleIsRadar: isRadar,
      }}
    >
      if (window.lucide) window.lucide.createIcons();

      function setArticleContext() {
        if (!window.setMentorArticleContext) return;
        window.setMentorArticleContext({
          id: articleId,
          title: articleTitle,
          isRadar: articleIsRadar,
        });
      }

      setArticleContext();
      document.addEventListener("DOMContentLoaded", setArticleContext);

      document.getElementById("article-mentor-button")?.addEventListener("click", () => {
        setArticleContext();
        window.mentorCustomGreetingHTML = document.documentElement.lang === "en"
          ? `I see you read our article **"${articleTitle}"**. Would you like to explore how these ideas could apply to a learning challenge in your organization?`
          : `Veo que leíste nuestro artículo **"${articleTitle}"**. ¿Te gustaría conversar sobre cómo llevar esas ideas a la realidad de tu empresa?`;
        window.mentorCustomGreetingText = window.mentorCustomGreetingHTML;
        document.getElementById("mentor-fab")?.click();
      });

      document.getElementById("copy-article-link")?.addEventListener("click", async (event) => {
        const button = event.currentTarget;
        const label = button.querySelector("span");
        try {
          await navigator.clipboard.writeText(button.dataset.url || window.location.href);
          if (label) label.textContent = document.documentElement.lang === "en" ? "Link copied" : "Enlace copiado";
        } catch {
          if (label) label.textContent = document.documentElement.lang === "en" ? "Could not copy" : "No se pudo copiar";
        }
        window.setTimeout(() => {
          if (label) label.textContent = document.documentElement.lang === "en" ? "Copy link" : "Copiar enlace";
        }, 1800);
      });
    </script>
  </body>
</html>
