        if (!action) return null;

        if (action.type === 'open_demo') return '/demos/';
        if (action.type === 'navigate_to_page') return MENTOR_PAGE_ACTIONS[action.id] || null;
        if (action.type === 'scroll_to_section') {
            return MENTOR_SECTION_ACTIONS[action.id] ? MENTOR_SECTION_ACTIONS[action.id].path : null;
        }

        return null;
