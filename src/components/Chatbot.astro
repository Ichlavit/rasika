    function userConfirmedNavigation(text) {
        var raw = String(text || "").trim();
        var normalized = normalizeForMatch(raw);
        var words = normalized ? normalized.split(/\s+/) : [];

        if (!normalized) return false;

        if (/^(si|sí|dale|ok|okay|ya|claro|perfecto|vamos|porfa|por favor)$/.test(normalized)) {
            return true;
        }

        if (words.length <= 3 && /\b(si|sí|dale|ok|okay|claro|perfecto|vamos)\b/.test(normalized)) {
            return true;
        }

        return /\b(abre|abrir|abreme|ábreme|muestra|muestrame|muéstrame|mostrar|llevame|llévame|lleva|vamos|carga|cargalo|cárgalo|verlo|verla|quiero verlo|quiero verla)\b/.test(normalized);
    }

