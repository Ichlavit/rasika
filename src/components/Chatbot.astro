    function buildAvatar(rawSvg, uid) {
        var s = rawSvg;
        
        // 1. Remove internal SVG scale on hover (parent button handles 1.5x)
        s = s.replace(/svg:hover\s*\{\s*transform:\s*scale\([^)]+\);\s*\}/g, '');
        
        // 2. Strip solid cyan outline to allow luminous CSS gradient border
        s = s.replace(/<circle id="Outer_circle"[^>]*\/>/g, '');

        // 3. Namespace ALL IDs to fix Brand_Logo clipping and CSS animation conflicts
        var ids = [
            'linear-gradient', 'linear-gradient-2', 'linear-gradient-3',
            'favicon-tech-gradient', 'dark-bg-gradient', 'luminous-grey',
            'favicon-clip', 'Layer_1', 'Avatar', 'Neck', 'Jacket', 'Face_oval', 
            'Left_ear', 'Right_ear', 'Nose', 'Hair', 'Face_outline', 'Mouth', 
            'Left_eyebrow', 'Right_eyebrow', 'Eyes', 'Glasses_reflections', 
            'Brand_Logo', 'Floating_elements', 'Circle_upper_right', 
            'Circle_upper_left', 'Rectangle_4', 'Rectangle_3', 'Rectangle_2', 
            'Outline_2', 'Rectangle_1', 'Outline_1', 'Document_right', 'Document_left'
        ];

        ids.forEach(function(id) {
            // Replace id="..."
            s = s.split('id="' + id + '"').join('id="' + id + '-' + uid + '"');
            // Replace url(#...)
            s = s.split('url(#' + id + ')').join('url(#' + id + '-' + uid + ')');
            // FIXED: Using negative lookahead (?![a-zA-Z0-9_\-]) correctly namespaces CSS selectors without breaking subsets like #Right_eyebrow
            var cssRegex = new RegExp('#' + id + '(?![a-zA-Z0-9_\\-])', 'g');
            s = s.replace(cssRegex, '#' + id + '-' + uid);
        });

        // 4. Route generic svg:hover to the namespaced root
        s = s.replace(/svg:hover/g, '#Layer_1-' + uid + ':hover');

        return s;
    }

