    function maybeExecutePendingUiAction(userText) {
        var pendingAction = sanitizeMentorUiAction(window.mentorPendingUiAction);

        if (!pendingAction || !userConfirmedNavigation(userText)) return false;

        storePendingUiAction(null);

        var confirmationText = uiActionChangesPage(pendingAction)
            ? "Dale, te llevo ahora."
            : "Dale, lo abro ahora.";

        addMsg(confirmationText, false, false);
        saveChatMessage('assistant', confirmationText);
        window.mentorChatHistory.push("CourseMentor: " + confirmationText);

        setTimeout(function () {
            executeMentorUiAction(pendingAction, { force: true });
        }, 350);

        return true;
    }

    function executeMentorUiAction(action, options) {
        var safeAction = sanitizeMentorUiAction(action);
        if (!safeAction) return false;

        options = options || {};

        if (
            !options.force &&
            uiActionChangesPage(safeAction) &&
            !userConfirmedNavigation(options.userText)
        ) {
            storePendingUiAction(safeAction);

            if (!/[¿?]/.test(String(options.botText || ""))) {
                var promptText = "Puedo llevarte a " + describeUiAction(safeAction) + ". ¿Quieres que lo abra?";
                addMsg(promptText, false, false);
                saveChatMessage('assistant', promptText);
                window.mentorChatHistory.push("CourseMentor: " + promptText);
            }

            return false;
        }

        storePendingUiAction(null);

        if (safeAction.type === 'open_demo') {
            if (
                normalizePathname(window.location.pathname) === '/demos/' &&
                typeof window.openDemoBySlug === 'function'
            ) {
                return window.openDemoBySlug(safeAction.id);
            }

            window.location.href = '/demos/?demo=' + encodeURIComponent(safeAction.id);
            return true;
        }

        if (safeAction.type === 'navigate_to_page') {
            window.location.href = MENTOR_PAGE_ACTIONS[safeAction.id];
            return true;
        }

        if (safeAction.type === 'scroll_to_section') {
            var target = MENTOR_SECTION_ACTIONS[safeAction.id];
            var currentPath = normalizePathname(window.location.pathname);

            if (currentPath !== normalizePathname(target.path)) {
                window.location.href = target.path + (target.elementId ? '#' + target.elementId : '');
                return true;
            }

            if (!target.elementId) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
                return true;
            }

            var el = document.getElementById(target.elementId);
            if (!el) return false;

            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            return true;
        }

        return false;
    }

