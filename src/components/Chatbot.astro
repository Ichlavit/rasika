    function cleanKnownValue(value) {
        if (!value) return "";
        var v = String(value).trim();
        var normalized = v.toLowerCase();
        if (
            !v ||
            normalized === "pendiente" ||
            normalized === "desconocido" ||
            normalized === "desconocida" ||
            normalized === "visitante" ||
            normalized === "visitante anónimo" ||
            normalized === "visitante anonimo" ||
            normalized === "usuario" ||
            normalized === "cliente" ||
            normalized === "pendiente@rasika.cl"
        ) return "";
        return v;
    }

    function safeJsonParse(raw, fallback) {
        try {
            return JSON.parse(raw);
        } catch (e) {
            return fallback;
        }
    }

    function getStoredMessages() {
        return safeJsonParse(localStorage.getItem('rasika_chat_messages') || '[]', []);
    }

    function setStoredMessages(messages) {
        localStorage.setItem('rasika_chat_messages', JSON.stringify(messages.slice(-40)));
    }

    function scrollMessagesToBottom() {
        var msgBox = document.getElementById('mentor-messages');
        if (!msgBox) return;

        setTimeout(function () {
            msgBox.scrollTop = msgBox.scrollHeight;
            requestAnimationFrame(function () {
                msgBox.scrollTop = msgBox.scrollHeight;
            });
        }, 10);
    }

    function stripSystemTags(text) {
        if (!text) return "";
        return String(text)
            .replace(/\[NOMBRE:[\s\S]*?\]/ig, '')
            .replace(/\[EMPRESA:[\s\S]*?\]/ig, '')
            .replace(/\[EMAIL:[\s\S]*?\]/ig, '')
            .replace(/\[PRECIO:[\s\S]*?\]/ig, '')
            .replace(/\[SERVICIO_ID:[\s\S]*?\]/ig, '')
            .replace(/\[IDIOMA:[\s\S]*?\]/ig, '')
            .replace(/\[RESUMEN:[\s\S]*?\]/ig, '')
            .replace(/\[ENVIAR_COTIZACION:[\s\S]*?\]/ig, '')
            .replace(/\[CONSULTAR_CURSO:[\s\S]*?\]/ig, '')
            .replace(/\|\s*$/g, '')
            .trim();
    }

    function stripInternalIds(text) {
        if (!text) return "";

        return String(text)
            .replace(/\bID:\s*[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\b/gi, "")
            .replace(/\bservice_id:\s*[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\b/gi, "")
            .replace(/\b[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\b/gi, "")
            .replace(/\s{2,}/g, " ")
            .trim();
    }

    function formatText(text) {
        if (!text) return "";
        var clean = stripInternalIds(stripSystemTags(text));
        var html = clean.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-rasika-accent underline hover:text-white transition-colors">$1</a>');
        html = html.replace(/\n/g, '<br/>');
        return html;
    }

    function addMsg(text, isUser, isHistory) {
        var msgBox = document.getElementById('mentor-messages');
        var win = document.getElementById('mentor-window');
        var badge = document.getElementById('mock-badge');
        if (!msgBox) return;

        var msgDiv = document.createElement('div');

        if (isUser) {
            msgDiv.className = 'bg-rasika-accent text-[#0a0b0d] font-medium p-3 rounded-2xl rounded-tr-sm text-sm self-end max-w-[85%] break-words whitespace-pre-wrap';
            msgDiv.innerText = text || "";
        } else {
            msgDiv.className = 'bg-[#2A2F35] text-gray-200 border border-white/5 p-3 rounded-2xl rounded-tl-sm text-sm self-start max-w-[85%] break-words';
            msgDiv.innerHTML = formatText(text || "");
        }

        msgBox.appendChild(msgDiv);
        scrollMessagesToBottom();

        if (!isHistory && win && win.style.display === 'none' && badge) {
            badge.style.display = 'block';
        }
    }

    function saveChatMessage(role, content) {
        var cleanContent = role === 'assistant' ? stripInternalIds(stripSystemTags(content)) : content;
        if (!cleanContent) return;

        var localMsgs = getStoredMessages();
        localMsgs.push({ role: role, content: cleanContent });
        setStoredMessages(localMsgs);

        if (!window.mentorLeadId) return;

        fetch(SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/chat_messages', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'apikey': SUPABASE_ANON_KEY,
                'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
            },
            body: JSON.stringify({
                lead_id: window.mentorLeadId,
                role: role,
                content: cleanContent,
                channel: 'website'
            })
        }).catch(function (e) {
            console.warn("Remote chat persistence failed:", e);
        });
    }

    async function fetchServicesCatalog() {
        try {
            var queryParams = 'select=id,service_name,category,ai_context_description,pricing_tiers,inclusions,exclusions,demo_name,demo_url,public_description,tech_specs,production_time_days';
            var response = await fetch(SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/services?' + queryParams, {
                headers: {
                    'apikey': SUPABASE_ANON_KEY,
                    'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                }
            });

            if (!response.ok) return;

            var data = await response.json();
            window.mentorServicesData = Array.isArray(data) ? data : [];

            var categoryRank = { bundle: 0, scorm: 1, simulation: 2, video: 3, saas: 4 };
            var ordered = window.mentorServicesData.slice().sort(function (a, b) {
                var ar = Object.prototype.hasOwnProperty.call(categoryRank, a.category) ? categoryRank[a.category] : 9;
                var br = Object.prototype.hasOwnProperty.call(categoryRank, b.category) ? categoryRank[b.category] : 9;
                if (ar !== br) return ar - br;
                return String(a.service_name || '').localeCompare(String(b.service_name || ''), 'es');
            });

            var catalogText = "";
            var currentSection = "";

            function sectionTitle(category) {
                if (category === 'bundle') return '--- BUNDLES DIRECTOS (PREFERIR SI CALZAN) ---';
                if (category === 'scorm') return '--- SCORM / EXPERIENCIAS INTERACTIVAS ---';
                if (category === 'simulation') return '--- SIMULADORES DE SOFTWARE (USAR SOLO SI HAY PRÁCTICA DE INTERFAZ/SOFTWARE) ---';
                if (category === 'video') return '--- ACTIVOS LINEALES DE VIDEO ---';
                if (category === 'saas') return '--- SAAS / COURSEMENTOR ---';
                return '--- OTROS SERVICIOS ---';
            }

            ordered.forEach(function (item) {
                var cat = item.category || 'other';
                var nextSection = sectionTitle(cat);
                if (nextSection !== currentSection) {
                    catalogText += nextSection + "\n";
                    currentSection = nextSection;
                }

                var prices = "";
                try { prices = JSON.stringify(item.pricing_tiers || {}); } catch (e) { prices = ""; }

                catalogText += "ID: " + item.id + "\n";
                catalogText += "SERVICIO: " + item.service_name + "\n";
                catalogText += "CATEGORIA: " + cat + "\n";
                if (item.demo_name) catalogText += "DEMO_NAME: " + item.demo_name + "\n";
                if (item.demo_url) catalogText += "DEMO_URL: " + item.demo_url + "\n";
                if (item.public_description) catalogText += "DESCRIPCION_PUBLICA: " + item.public_description + "\n";
                catalogText += "CONTEXTO_COMERCIAL: " + (item.ai_context_description || "N/A") + "\n";

                if (cat === 'bundle') {
                    try {
                        var totals = item.pricing_tiers && item.pricing_tiers.bundle_totals_uf
                            ? JSON.stringify(item.pricing_tiers.bundle_totals_uf)
                            : "{}";
                        catalogText += "BUNDLE_TOTALS_UF: " + totals + "\n";
                        catalogText += "REGLA_BUNDLE: Usa estos totales directos cuando calce la combinación. No recalcules si hay una clave aplicable.\n";
                    } catch (e) {
                        catalogText += "PRECIOS: " + prices + "\n";
                    }
                } else {
                    catalogText += "PRECIOS: " + prices + "\n";
                }

                try { if (item.inclusions) catalogText += "INCLUSIONES: " + JSON.stringify(item.inclusions) + "\n"; } catch (e) {}
                try { if (item.exclusions) catalogText += "EXCLUSIONES: " + JSON.stringify(item.exclusions) + "\n"; } catch (e) {}
                try { if (item.tech_specs) catalogText += "TECH_SPECS: " + JSON.stringify(item.tech_specs) + "\n"; } catch(e) {}
                try { if (item.production_time_days) catalogText += "PLAZOS_PRODUCCION: " + JSON.stringify(item.production_time_days) + "\n"; } catch(e) {}
                catalogText += "\n";
            });

            window.mentorServicesCatalog = catalogText || "Catálogo no disponible.";
        } catch (e) {
            console.warn("Catalog fetch error:", e);
            window.mentorServicesCatalog = "Catálogo no disponible.";
        }
    }

    async function fetchDemoCatalog() {
        try {
            var queryParams = [
                'slug',
                'service_id',
                'service_content_id',
                'section_key',
                'sort_order',
                'category',
                'demo_name',
                'format_type',
                'client_name',
                'project_year',
                'description',
                'source_url',
                'media_type',
                'custom_width',
                'tag_label',
                'card_title',
                'card_description'
            ].join(',');

            var response = await fetch(
                SUPABASE_URL.replace(/\/$/, '') +
                '/rest/v1/demo_catalog?select=' +
                queryParams +
                '&is_active=eq.true&order=sort_order.asc',
                {
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                    }
                }
            );

            if (!response.ok) return;

            var data = await response.json();
            window.mentorDemoCatalogData = Array.isArray(data) ? data : [];

            window.mentorDemoCatalog = window.mentorDemoCatalogData.map(function (demo) {
                return [
                    "ID_DEMO: " + demo.slug,
                    "TITULO_TARJETA: " + (demo.card_title || ""),
                    "NOMBRE_DEMO: " + (demo.demo_name || ""),
                    "SERVICIO_ID: " + (demo.service_id || ""),
                    "SERVICE_CONTENT_ID: " + (demo.service_content_id || ""),
                    "SECCION: " + (demo.section_key || ""),
                    "TIPO: " + (demo.media_type || ""),
                    "FORMATO: " + (demo.format_type || ""),
                    "CLIENTE: " + (demo.client_name || ""),
                    "DESCRIPCION: " + (demo.card_description || demo.description || "")
                ].join("\n");
            }).join("\n\n") || "Catálogo de demos no disponible.";
        } catch (e) {
            console.warn("Demo catalog fetch error:", e);
            window.mentorDemoCatalog = "Catálogo de demos no disponible.";
        }
    }

    function resolveActiveDemo() {
        if (!Array.isArray(window.mentorDemoCatalogData)) return null;

        if (_mentorActiveDemoSlug) {
            var slug = String(_mentorActiveDemoSlug).trim();
            for (var bySlug = 0; bySlug < window.mentorDemoCatalogData.length; bySlug++) {
