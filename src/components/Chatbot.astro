    function syncMeta(meta) {
        if (!meta) return;

        if (meta.name) {
            window.mentorUserName = meta.name;
            localStorage.setItem('mentorUserName', meta.name);
        }

        if (meta.company_name) {
            window.mentorCompanyKnown = true;
            localStorage.setItem('mentorCompanyKnown', 'true');
            localStorage.setItem('mentorCompanyName', meta.company_name);
        }

        if (meta.email) {
            window.mentorEmailKnown = true;
            localStorage.setItem('mentorEmailKnown', 'true');
            localStorage.setItem('mentorEmail', meta.email);
        }

        if (meta.status === 'pending quote' || meta.status === 'quote processing' || meta.status === 'quote sent') {
            window.mentorQuoteRequested = true;
            localStorage.setItem('mentorQuoteRequested', 'true');
        }
    }

    function extractBotMessage(data) {
        if (!data || !data.output) return "Lo siento, tuve un problema procesando la respuesta.";

        for (var i = 0; i < data.output.length; i++) {
            var output = data.output[i];
            if (output.type === "message" && output.role === "assistant" && output.content) {
                for (var j = 0; j < output.content.length; j++) {
                    if (output.content[j].type === "output_text") {
                        return output.content[j].text || "";
                    }
                }
            }
        }

        return "Lo siento, tuve un problema procesando la respuesta.";
    }

    function setProcessingState(active) {
        requestInFlight = active;

        var send = document.getElementById('mentor-send');
        var input = document.getElementById('mentor-input');
        var typing = document.getElementById('mentor-typing');

        if (send) {
            send.disabled = active;
            send.classList.toggle('opacity-50', active);
            send.classList.toggle('cursor-not-allowed', active);
        }

        if (input) {
            input.disabled = false;
            input.setAttribute('aria-busy', active ? 'true' : 'false');
        }

        if (typing) {
            typing.style.display = active ? 'block' : 'none';
        }
    }

async function createAnonymousSession() {
    // Sync runtime state from localStorage before creating or loading a session.
    // This prevents duplicate leads when the form creates/updates mentorLeadId
    // after the chatbot component has already initialized.
    var storedLeadId = localStorage.getItem('mentorLeadId');
    var storedName = cleanKnownValue(localStorage.getItem('mentorUserName'));
    var storedCompany = cleanKnownValue(localStorage.getItem('mentorCompanyName'));
    var storedEmail = cleanKnownValue(localStorage.getItem('mentorEmail'));

    if (storedLeadId) {
        window.mentorLeadId = storedLeadId;
    }

    if (storedName) {
        window.mentorUserName = storedName;
    }

    if (storedCompany) {
        window.mentorCompanyKnown = true;
        localStorage.setItem('mentorCompanyKnown', 'true');
    }

    if (storedEmail) {
        window.mentorEmailKnown = true;
        localStorage.setItem('mentorEmailKnown', 'true');
    }

    var currentContext = window.mentorActiveCourse || "Catálogo General";
    var isGreetingSpecific = currentContext !== "Catálogo General";
    var hasPendingFormContext = !!localStorage.getItem('mentorPendingFormContext');

    var formSubmitted = localStorage.getItem('mentorFormRequestSubmitted') === 'true';
    var knownNameForGreeting = cleanKnownValue(window.mentorUserName);

    var greetingHTML = "";

    if (formSubmitted && knownNameForGreeting) {
        greetingHTML =
            "¡Hola, " + knownNameForGreeting + "! Gracias por tu solicitud. Para ayudarte mejor, voy a precisar contigo el objetivo formativo y el alcance.";
    } else if (isGreetingSpecific) {
        greetingHTML =
            "¡Hola! Veo que te interesó <b class='text-white'>" + currentContext + "</b>. ¿Cómo puedo ayudarte a implementarlo?";
    } else {
        greetingHTML =
            "¡Hola! Soy CourseMentor. ¿En qué puedo ayudarte hoy?";
    }

    var greetingText = greetingHTML.replace(/<[^>]*>/g, '');

    if (!mentorChatHydrated) {
        await loadPreviousChat();
    }

    var hasPriorConversation = window.mentorChatHistory.length > 0;

    if (window.mentorLeadId) {
        // If the form submitted a pending context, do not show a greeting.
        // The pending form context will be sent as the user's first message.
        if (hasPendingFormContext) {
            return;
        }

        var lastHistory = window.mentorChatHistory.length > 0
            ? window.mentorChatHistory[window.mentorChatHistory.length - 1]
            : "";

        var shouldShowFormGreeting =
            formSubmitted &&
            lastHistory.indexOf(greetingText.substring(0, 40)) === -1;

        var shouldShowDemoGreeting =
            isGreetingSpecific &&
            !formSubmitted &&
            lastHistory.indexOf(currentContext) === -1;

        if (!hasPriorConversation && (shouldShowFormGreeting || shouldShowDemoGreeting)) {
            addMsg(greetingHTML, false, false);
            window.mentorChatHistory.push("CourseMentor: " + greetingText);
            saveChatMessage('assistant', greetingText);
        }

        if (formSubmitted) {
            localStorage.removeItem('mentorFormRequestSubmitted');
        }

        return;
    }

    if (!hasPriorConversation) {
        addMsg(greetingHTML, false, false);
        window.mentorChatHistory.push("CourseMentor: " + greetingText);
    }

    if (formSubmitted) {
        localStorage.removeItem('mentorFormRequestSubmitted');
    }

    var payload = {
    name: cleanKnownValue(window.mentorUserName) || "Visitante Anónimo",
    email: "pendiente@rasika.cl",
    company_name: "Pendiente",
    traffic_source: formSubmitted
        ? "Website Form: Quote Request"
        : (document.referrer || "Direct Traffic")
    };

        try {
            var response = await fetch(SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/leads', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'apikey': SUPABASE_ANON_KEY,
                    'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
                    'Prefer': 'return=representation'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                console.warn("Lead creation failed:", await response.text());
                return;
            }

            var data = await response.json();

            if (data && data.length > 0 && data[0].id) {
                window.mentorLeadId = data[0].id;
                localStorage.setItem('mentorLeadId', window.mentorLeadId);
                if (!hasPriorConversation) saveChatMessage('assistant', greetingText);
            }
        } catch (e) {
            console.warn("Lead creation failed:", e);
        }
    }

    async function loadPreviousChat() {
        if (mentorChatHydrated) return;

        var localMsgs = getStoredMessages();

        if (localMsgs.length > 0) {
            var msgBox = document.getElementById('mentor-messages');
            if (msgBox) msgBox.innerHTML = "";

            window.mentorChatHistory = [];

            localMsgs.forEach(function (msg) {
                window.mentorChatHistory.push((msg.role === 'user' ? 'Usuario: ' : 'CourseMentor: ') + msg.content);
                addMsg(msg.content, msg.role === 'user', true);
            });

            mentorChatHydrated = true;
            return;
        }

        if (!window.mentorLeadId) {
            mentorChatHydrated = true;
            return;
        }

        try {
            var response = await fetch(SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/chat_messages?lead_id=eq.' + window.mentorLeadId + '&order=created_at.asc', {
                headers: {
                    'apikey': SUPABASE_ANON_KEY,
                    'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                }
            });

            if (!response.ok) {
                mentorChatHydrated = true;
                return;
            }

            var data = await response.json();
            var msgsToSave = [];
            var remoteMsgBox = document.getElementById('mentor-messages');
            if (remoteMsgBox) remoteMsgBox.innerHTML = "";

            window.mentorChatHistory = [];

            data.forEach(function (msg) {
                window.mentorChatHistory.push((msg.role === 'user' ? 'Usuario: ' : 'CourseMentor: ') + msg.content);
                addMsg(msg.content, msg.role === 'user', true);
                msgsToSave.push({ role: msg.role, content: msg.content });
            });

            if (msgsToSave.length > 0) setStoredMessages(msgsToSave);
            mentorChatHydrated = true;
        } catch (e) {
            console.warn("History load error:", e);
            mentorChatHydrated = true;
        }
    }

    function uploadFile(file) {
        if (!file) return;

        showUploadStatus("Subiendo " + file.name + "...", "loading");

        currentFileName = file.name;

        var ext = file.name.split('.').pop().toLowerCase();
        var isImage = ['jpg', 'jpeg', 'png', 'webp'].indexOf(ext) !== -1;

        var fd = new FormData();
        fd.append('file', file);
        fd.append('purpose', 'assistants');

        var xhr = new XMLHttpRequest();
        xhr.open("POST", PROXY_ENDPOINT, true);
        xhr.setRequestHeader("apikey", SUPABASE_ANON_KEY);
        xhr.setRequestHeader("Authorization", "Bearer " + SUPABASE_ANON_KEY);
        xhr.setRequestHeader("x-target-url", OPENAI_FILES_URL);

        xhr.onreadystatechange = function () {
            if (xhr.readyState !== 4) return;

            if (xhr.status === 200) {
                try {
                    var res = JSON.parse(xhr.responseText);
                    if (isImage) currentImageFileId = res.id;
                    else currentFileId = res.id;

                    showUploadStatus("¡Archivo listo!", "success");
                } catch (e) {
                    showUploadStatus("Error procesando archivo", "error");
                    currentFileName = "";
                }
            } else {
                showUploadStatus("Error al subir", "error");
                currentFileName = "";
            }

            var fileInput = document.getElementById('mentor-file');
            if (fileInput) fileInput.value = "";
        };

        xhr.send(fd);
    }

    async function sendMessage() {
    if (window.mentorRequestInFlight || requestInFlight) {
        return;
    }

    var input = document.getElementById('mentor-input');
    var quoteBox = document.getElementById('quote-box');
    var uploadContainer = document.getElementById('upload-status-container');

    if (!input) return;

    var val = input.value.trim();

    if (!val && !currentFileId && !currentImageFileId) return;

    window.mentorRequestInFlight = true;

    var userMessage = val || (currentImageFileId ? "Imagen enviada" : "Archivo enviado");
    var passiveEmail = extractEmailFromText(userMessage);

    addMsg(userMessage, true, false);
    saveChatMessage('user', userMessage);
    window.mentorChatHistory.push("Usuario: " + userMessage);

    input.value = "";
    input.style.height = "auto";

    if (quoteBox) quoteBox.style.display = 'none';
    if (uploadContainer) uploadContainer.innerHTML = "";

    if (maybeExecutePendingUiAction(userMessage)) {
        window.mentorRequestInFlight = false;
        return;
    }

    setProcessingState(true);

    try {
        var baseInstructions = await loadBaseInstructions();
        var instructions = buildDynamicInstructions(baseInstructions, userMessage);
        var stageDirective = buildStageDirective(userMessage, passiveEmail);

        callResponsesAPI(userMessage, instructions, stageDirective);
    } catch (e) {
        window.mentorRequestInFlight = false;
        setProcessingState(false);
        addMsg("Hubo un problema preparando la respuesta. Intenta nuevamente.", false, false);
        console.warn("sendMessage failed:", e);
    }
}

    function sendPendingFormContextIfAny() {
    var pendingContext = (localStorage.getItem('mentorPendingFormContext') || '').trim();

    if (!pendingContext || requestInFlight) return;

    var input = document.getElementById('mentor-input');
    if (!input) return;

    syncMentorStateFromLocalStorage();

    input.value = pendingContext;
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';

    localStorage.removeItem('mentorPendingFormContext');
    localStorage.removeItem('mentorFormRequestSubmitted');

    sendMessage();
}

    function syncMentorStateFromLocalStorage() {
    var storedLeadId = localStorage.getItem('mentorLeadId');
    var storedName = cleanKnownValue(localStorage.getItem('mentorUserName'));
    var storedCompany = cleanKnownValue(localStorage.getItem('mentorCompanyName'));
    var storedEmail = cleanKnownValue(localStorage.getItem('mentorEmail'));

    if (storedLeadId) {
        window.mentorLeadId = storedLeadId;
    }

    if (storedName) {
        window.mentorUserName = storedName;
    }

    if (storedCompany) {
        window.mentorCompanyKnown = true;
        localStorage.setItem('mentorCompanyKnown', 'true');
    }

    if (storedEmail) {
        window.mentorEmailKnown = true;
        localStorage.setItem('mentorEmailKnown', 'true');
    }
}

    function callResponsesAPI(query, instructions, stageDirective) {
        var xhr = new XMLHttpRequest();
        xhr.open("POST", PROXY_ENDPOINT, true);

        xhr.setRequestHeader("Content-Type", "application/json");
        xhr.setRequestHeader("apikey", SUPABASE_ANON_KEY);
        xhr.setRequestHeader("Authorization", "Bearer " + SUPABASE_ANON_KEY);
        xhr.setRequestHeader("x-target-url", OPENAI_RESPONSES_URL);
        xhr.setRequestHeader("OpenAI-Beta", "assistants=v2");
        xhr.setRequestHeader("x-lead-id", window.mentorLeadId || "");
        xhr.setRequestHeader("x-client-event-id", crypto.randomUUID ? crypto.randomUUID() : String(Date.now()));

        var recentHistory = window.mentorChatHistory.slice(-8).join("\n");

        var finalInput =
            "Historial reciente:\n" +
            recentHistory +
            "\n\n" +
            (currentQuote ? 'Contexto citado por el usuario: "' + currentQuote + '"\n\n' : '') +
            "Mensaje actual del usuario:\n" +
            query +
            "\n\n" +
            stageDirective;

        var contentArray = [{ type: "input_text", text: finalInput }];

        if (currentImageFileId) {
            contentArray.push({ type: "input_image", file_id: currentImageFileId });
        } else if (currentFileId) {
            contentArray.push({ type: "input_file", file_id: currentFileId });
        }

        var payload = {
            model: MODEL_NAME,
            instructions: instructions,
            input: [{ role: "user", content: contentArray }],
            store: true
        };

        xhr.onreadystatechange = function () {
            if (xhr.readyState !== 4) return;

            setProcessingState(false);
            window.mentorRequestInFlight = false;

    if (xhr.status === 200) {
        try {
            var data = JSON.parse(xhr.responseText);
            syncMeta(data._meta);

            var botMsg = extractBotMessage(data);
            var uiAction = sanitizeMentorUiAction(data._ui_action);

            // If backend rejected a quote, do not expose technical/pricing-matrix errors.
            // Keep the assistant helpful and conversion-oriented.
            if (data._quote_rejected) {
                var rejectedReason = data._quote_rejected.reason || "";

                if (rejectedReason === "selected_bundle_price_not_in_bundle_totals") {
                    botMsg = "Perfecto. Prepararé el desglose formal como estimación preliminar para que el equipo pueda revisarlo y ajustarlo si hace falta.";
                } else if (rejectedReason === "selected_standalone_video_for_interactive_need") {
                    botMsg = "Tiene sentido. Para preparar bien el desglose, lo tomaré como una solución con video más experiencia interactiva, y el equipo podrá ajustar el alcance si hace falta.";
                } else if (rejectedReason === "selected_simulation_without_software_need") {
                    botMsg = "Perfecto. Lo consideraré como una experiencia interactiva estándar, y el equipo podrá revisar si corresponde simulación de software o SCORM en la reunión.";
                } else {
                    botMsg = "Perfecto. Prepararé el desglose formal como estimación preliminar para que el equipo pueda revisarlo contigo.";
                }
            }

            window.mentorChatHistory.push("CourseMentor: " + botMsg);
            addMsg(botMsg, false, false);
            saveChatMessage('assistant', botMsg);

            if (uiAction) {
                setTimeout(function () {
                    executeMentorUiAction(uiAction, {
                        userText: query,
                        botText: botMsg
                    });
                }, 500);
            }

            currentFileId = null;
            currentImageFileId = null;
            currentFileName = "";
            currentQuote = "";
        } catch (e) {
            addMsg("La respuesta llegó con un formato inválido. Intenta nuevamente.", false, false);
            console.warn("Response parse error:", e);
        }

        return;
    }

            var errorText = "Falla técnica temporal. Intenta nuevamente.";
            try {
                var err = JSON.parse(xhr.responseText);
                if (err && err.error) {
                    errorText = typeof err.error === 'string' ? err.error : (err.error.message || errorText);
                }
            } catch (e) {}

            addMsg(errorText, false, false);
        };

        xhr.send(JSON.stringify(payload));
    }

    function setupEvents() {
        var fab = document.getElementById('mentor-fab');
        var win = document.getElementById('mentor-window');
        var close = document.getElementById('mentor-close-btn');
        var input = document.getElementById('mentor-input');
        var send = document.getElementById('mentor-send');
        var fileIn = document.getElementById('mentor-file');
        var msgBox = document.getElementById('mentor-messages');
        var quoteBox = document.getElementById('quote-box');
        var badge = document.getElementById('mock-badge');
        var clearQuote = document.getElementById('clear-quote');

        if (fab) {
            fab.onclick = function () {
                if (win) win.style.display = 'flex';
                fab.style.display = 'none';
                if (badge) badge.style.display = 'none';

                localStorage.setItem('rasika_chat_open', 'true');

                if (window.lucide) lucide.createIcons();

                createAnonymousSession().then(function () {
                    sendPendingFormContextIfAny();
                    scrollMessagesToBottom();
                }).catch(function (error) {
                    console.warn("Chat session init failed:", error);
                    sendPendingFormContextIfAny();
                    scrollMessagesToBottom();
                });
            };
        }

        if (close) {
            close.onclick = function () {
                win.style.display = 'none';
                fab.style.display = 'flex';
                localStorage.setItem('rasika_chat_open', 'false');
            };
        }

        if (msgBox) {
            msgBox.onmouseup = function () {
                var sel = window.getSelection().toString().trim();

                if (sel.length > 5 && quoteBox) {
                    currentQuote = sel;
                    quoteBox.style.display = 'flex';

                    var quoteText = document.getElementById('quote-text');
                    if (quoteText) quoteText.innerText = 'Citando: "' + sel.substring(0, 30) + '..."';
                }
            };
        }

        if (clearQuote) {
            clearQuote.onclick = function () {
                currentQuote = "";

                if (quoteBox) quoteBox.style.display = 'none';

                var quoteText = document.getElementById('quote-text');
                if (quoteText) quoteText.innerText = "";
            };
        }

        if (fileIn) {
            fileIn.onchange = function (e) {
                uploadFile(e.target.files[0]);
            };
        }

        if (input) {
            input.addEventListener('input', function () {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 120) + 'px';
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });
        }

        if (send) {
            send.onclick = sendMessage;
        }

        if (localStorage.getItem('rasika_chat_open') === 'true' && fab) {
            setTimeout(function () {
                fab.click();
            }, 100);
        } else if (localStorage.getItem('rasika_chat_messages')) {
            loadPreviousChat();
        }
    }

