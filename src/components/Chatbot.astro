                                '<textarea id="mentor-input" rows="1" placeholder="Escribe aquí..." class="flex-1 bg-black/40 border border-white/10 text-white placeholder-gray-500 rounded-[20px] px-4 py-2 text-sm outline-none focus:ring-1 focus:ring-rasika-accent focus:border-rasika-accent transition-all resize-none overflow-hidden min-h-[40px] max-h-[120px] leading-relaxed"></textarea>' +
                                '<button id="mentor-send" type="button" class="bg-rasika-accent text-[#0a0b0d] p-2 rounded-full w-10 h-10 flex items-center justify-center hover:bg-[#88d6e0] hover:scale-105 transition-all self-end mb-0.5"><i data-lucide="send" class="w-4 h-4"></i></button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
