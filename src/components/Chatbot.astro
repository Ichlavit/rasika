                '<button id="mentor-fab" type="button" class="w-16 h-16 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-[1.5] shadow-[0_0_20px_rgba(94,166,176,0.2)] relative group p-[2px] bg-gradient-to-br from-[#5EA6B0] via-[#1E2226] to-[#88d6e0]">' +
                    '<div class="w-full h-full bg-[#1E2226] rounded-full flex items-center justify-center overflow-hidden">' + avatarFAB + '</div>' +
                    '<span id="mock-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-rasika-accent rounded-full border-2 border-rasika-surface hidden"></span>' +
