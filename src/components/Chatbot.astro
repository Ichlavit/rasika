    function sanitizeMentorUiAction(action) {
        if (!action || typeof action !== 'object') return null;

        var type = String(action.type || '').trim();
        var id = String(action.id || '').trim();

        if (!id || id.length > 120) return null;

        if (type === 'open_demo') {
            var demo = (window.mentorDemoCatalogData || []).find(function (item) {
                return item.slug === id;
            });
            return demo ? { type: type, id: id } : null;
        }

        if (type === 'navigate_to_page') {
            return Object.prototype.hasOwnProperty.call(MENTOR_PAGE_ACTIONS, id)
                ? { type: type, id: id }
                : null;
        }

        if (type === 'scroll_to_section') {
            return Object.prototype.hasOwnProperty.call(MENTOR_SECTION_ACTIONS, id)
                ? { type: type, id: id }
                : null;
        }

        return null;
    }

