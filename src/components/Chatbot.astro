    async function fetchDemoMarkdown() {
        var service = resolveActiveService();
        var activeDemo = resolveActiveDemo();
        var contentId =
            _mentorActiveServiceContentId ||
            (activeDemo && activeDemo.service_content_id) ||
            null;

        // Only fetch tutor content when the active demo/page maps to a canonical service.
        // Display-only labels must not be used to infer service identity.
        if (!service || !service.id) {
            currentRAGContext = "";
            return;
        }

        try {
            var contentRes = await fetch(
                SUPABASE_URL.replace(/\/$/, '') +
                '/rest/v1/service_content?select=content_md,course_name,asset_description,training_tool,benefits&' +
                (contentId
                    ? 'id=eq.' + encodeURIComponent(contentId)
                    : 'service_id=eq.' + encodeURIComponent(service.id)),
                {
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                    }
                }
            );

            if (!contentRes.ok) {
                currentRAGContext = "";
                return;
            }

            var contents = await contentRes.json();
            if (!contents || contents.length === 0) {
                currentRAGContext = "";
                return;
            }

            var content = contents[0];

            currentRAGContext =
                "Servicio/Demo canónico: " + (service.service_name || "") + "\n" +
                "Nombre de curso/demo: " + (content.course_name || service.demo_name || "") + "\n" +
                "Herramienta: " + (content.training_tool || "") + "\n" +
                "Descripción: " + (content.asset_description || "") + "\n" +
                "Beneficios: " + (content.benefits || "") + "\n\n" +
                "Contenido técnico resumido:\n" +
                String(content.content_md || "").slice(0, 7000);

        } catch (e) {
            console.warn("RAG fetch error:", e);
            currentRAGContext = "";
        }
    }

