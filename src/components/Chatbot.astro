    function extractNameFromText(text) {
    var t = String(text || "").trim();

    var patterns = [
        /(?:me llamo|soy|mi nombre es)\s+([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+(?:\s+[A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)?)/i,
        /(?:hablas con|estás hablando con|estas hablando con)\s+([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+(?:\s+[A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)?)/i,
        /(?:puedes llamarme|me puedes llamar|llámame|llamame)\s+([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+(?:\s+[A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)?)/i,
        /^([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)\s+está bien/i,
        /^([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)\s+esta bien/i
    ];

    for (var i = 0; i < patterns.length; i++) {
        var match = t.match(patterns[i]);
        if (match && match[1]) {
            return match[1].trim();
        }
    }

    return "";
}

    function extractCompanyFromText(text) {
    var raw = String(text || "").trim();
    var t = raw.toLowerCase();

    // Reject obvious non-company values.
    function isBadCompanyCandidate(value) {
        var v = String(value || "").trim().toLowerCase();

        if (!v) return true;

        // Durations / quantities / scope details.
        if (/^\d+\s*(min|minuto|minutos|hora|horas|hrs|h)\b/i.test(v)) return true;
        if (/\b\d+\s*(min|minuto|minutos|hora|horas|hrs|h)\b/i.test(v)) return true;
        if (/\b(video|videos|cápsula|capsula|cápsulas|capsulas|módulo|modulo|módulos|modulos|scorm|curso|cursos)\b/i.test(v)) return true;

        // Generic non-company phrases.
        if (/^(sí|si|no|ok|dale|perfecto|claro|gracias|eso|esto|todo|nada)$/i.test(v)) return true;

        // Too long: probably a sentence, not an organization.
        if (v.split(/\s+/).length > 5) return true;

        return false;
    }

    var patterns = [
        /(?:hablas con|estás hablando con|estas hablando con)\s+[A-ZÁÉÍÓÚÑ][a-záéíóúñ]+(?:\s+[A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)?\s*,?\s+de\s+([A-ZÁÉÍÓÚÑ0-9][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,80})/i,
        /(?:sí|si)\s*,?\s+([A-ZÁÉÍÓÚÑ0-9][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,80})\s+es\s+mi\s+empresa/i,
        /([A-ZÁÉÍÓÚÑ0-9][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,80})\s+es\s+(?:mi|la)\s+empresa/i,
        /(?:mi empresa es|empresa es|la empresa es|somos de|trabajo en|trabajo para|soy de|vengo de|de la empresa)\s+([A-ZÁÉÍÓÚÑ0-9][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,80})/i,
        /(?:trabajo en|trabajo para|soy de|vengo de|somos de|somos|empresa es|la empresa es|de la empresa)\s+([A-ZÁÉÍÓÚÑ0-9][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,80})/i,
        /(?:en|para)\s+([A-ZÁÉÍÓÚÑ][A-Za-zÁÉÍÓÚÑáéíóúñ0-9&.\-\s]{1,60})\s*(?:\.|,|$)/i
    ];

    for (var i = 0; i < patterns.length; i++) {
        var match = raw.match(patterns[i]);

        if (match && match[1]) {
            var candidate = match[1]
                .replace(/[.,;:!?]+$/g, "")
                .trim();

            if (!isBadCompanyCandidate(candidate)) {
                return candidate;
            }
        }
    }

    return "";
}

function buildStageDirective(userText, passiveEmail) {
    var passiveName = extractNameFromText(userText);
    var passiveCompany = extractCompanyFromText(userText);

    // Passive local profile sync.
    // This prevents the next turn from still seeing name/company/email as unknown
    // when the user already gave the data but the model forgot to return profile_update.
    if (passiveName) {
        window.mentorUserName = passiveName;
        localStorage.setItem('mentorUserName', passiveName);
    }

    if (
        passiveCompany &&
        !/\b\d+\s*(min|minuto|minutos|hora|horas|hrs|h)\b/i.test(passiveCompany)
    ) {
        window.mentorCompanyKnown = true;
        localStorage.setItem('mentorCompanyKnown', 'true');
        localStorage.setItem('mentorCompanyName', passiveCompany);
    }

    if (passiveEmail && !window.mentorEmailKnown && !cleanKnownValue(localStorage.getItem('mentorEmail'))) {
        window.mentorEmailKnown = true;
        localStorage.setItem('mentorEmailKnown', 'true');
        localStorage.setItem('mentorEmail', passiveEmail);
    }

    var nameKnown = cleanKnownValue(window.mentorUserName) !== "";
    var nameKnownNow = nameKnown || !!passiveName;
    var companyKnown = window.mentorCompanyKnown || cleanKnownValue(localStorage.getItem('mentorCompanyName')) !== "";
    var companyKnownNow = companyKnown || !!passiveCompany;
    var emailKnown = window.mentorEmailKnown || cleanKnownValue(localStorage.getItem('mentorEmail')) !== "";
    var emailKnownNow = emailKnown || !!passiveEmail;
    var quoteRequested = window.mentorQuoteRequested;
