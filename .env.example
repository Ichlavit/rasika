# TEMPLATE ONLY. Do not put real secrets in this file.
# This file is intended to be committed to GitHub with blank values.
# Put real values in .env or .env.local, which are ignored by Git.

# Browser-exposed Supabase values used by Astro at build time.
# These are public client values, not private service-role credentials.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Supabase Edge Function secrets.
# Set these in Supabase secrets or a local-only env file, never in frontend code.
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
QUOTE_WEBHOOK_SECRET=
GOOGLE_BOOKING_URL=
SALES_EMAIL=

# SiteGround deployment values for local scripts only.
SITEGROUND_SSH_HOST=
SITEGROUND_SSH_USER=
SITEGROUND_SSH_PORT=
SITEGROUND_REMOTE_PATH=
SITEGROUND_SSH_KEY_PATH=.ssh/siteground_project_key
